     /* card / panel bg */\n    --paper:  #FFFFFF;     /* canvas */\n    --paper-2: #FAFBFE;    /* canvas warm tint */\n\n    --ink:    #0A0E2E;\n    --ink-2:  #2B3157;\n    --ink-3:  #6C7290;\n    --ink-4:  #A6ACC4;\n    --hairline: rgba(26,30,92,0.10);\n    --hairline-2: rgba(26,30,92,0.05);\n\n    /* accents */\n    --coral: #E0744A;       /* warm B2C moments (gift card) */\n    --emerald: #1F8A5B;     /* success/positive */\n\n    --r-sm: 6px;\n    --r-md: 12px;\n    --r-lg: 20px;\n    --r-xl: 28px;\n\n    --f-display: \"Vazirmatn\", \"DM Serif Display\", serif;\n    --f-body: \"Vazirmatn\", \"DM Sans\", sans-serif;\n    --f-en-display: \"DM Serif Display\", \"Vazirmatn\", serif;\n    --f-en-body: \"DM Sans\", \"Vazirmatn\", sans-serif;\n    --f-mono: ui-monospace, \"SF Mono\", Menlo, monospace;\n\n    --content-max: 1200px;\n  }\n\n  * { box-sizing: border-box; }\n  html, body { margin: 0; padding: 0; }\n  html { scroll-behavior: smooth; }\n  body {\n    font-family: var(--f-body);\n    background: var(--paper);\n    color: var(--ink);\n    font-size: 16px;\n    line-height: 1.75;\n    -webkit-font-smoothing: antialiased;\n    text-rendering: optimizeLegibility;\n  }\n\n  /* ---------- Shell ---------- */\n  .shell { display: grid; grid-template-columns: 280px 1fr; min-height: 100vh; }\n\n  /* ---------- Side nav ---------- */\n  aside.nav {\n    position: sticky; top: 0;\n    height: 100vh;\n    background: var(--navy-1);\n    color: rgba(255,255,255,0.78);\n    padding: 32px 24px 24px;\n    display: flex; flex-direction: column; gap: 18px;\n    z-index: 10;\n    border-left: 1px solid rgba(255,255,255,0.06);\n    overflow-y: auto;\n  }\n  aside.nav::-webkit-scrollbar { width: 4px; }\n  aside.nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }\n\n  .brand-mark {\n    display: flex; align-items: center; gap: 14px;\n    padding-bottom: 22px;\n    border-bottom: 1px solid rgba(255,255,255,0.08);\n  }\n  .brand-mark img { width: 42px; height: 42px; object-fit: contain; filter: brightness(1.4); }\n  .brand-mark .text .t1 { font-weight: 700; font-size: 18px; color: #fff; letter-spacing: -0.01em; }\n  .brand-mark .text .t2 { font-size: 10.5px; color: var(--sky); font-family: var(--f-en-body); letter-spacing: 0.16em; text-transform: uppercase; margin-top: 2px; }\n\n  .nav-section {\n    font-size: 10px;\n    color: rgba(255,255,255,0.4);\n    font-family: var(--f-en-body);\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    padding: 0 6px;\n    margin-top: 4px;\n    display: flex; align-items: center; gap: 10px;\n  }\n  .nav-section::after {\n    content: \"\"; flex: 1; height: 1px;\n    background: rgba(255,255,255,0.08);\n  }\n\n  nav.toc { display: flex; flex-direction: column; gap: 1px; }\n  nav.toc a {\n    display: grid;\n    grid-template-columns: 28px 1fr;\n    align-items: center;\n    gap: 8px;\n    padding: 8px 12px;\n    border-radius: 6px;\n    text-decoration: none;\n    color: rgba(255,255,255,0.65);\n    font-size: 13.5px;\n    font-weight: 500;\n    transition: all 160ms cubic-bezier(0.22,1,0.36,1);\n  }\n  nav.toc a .num {\n    font-family: var(--f-en-body);\n    font-size: 10.5px;\n    color: rgba(255,255,255,0.35);\n    font-feature-settings: \"tnum\" 1;\n    font-variant-numeric: tabular-nums;\n  }\n  nav.toc a:hover { background: rgba(255,255,255,0.05); color: #fff; }\n  nav.toc a.active {\n    background: linear-gradient(90deg, rgba(111,143,206,0.20), rgba(111,143,206,0.05));\n    color: #fff;\n    box-shadow: inset 3px 0 0 var(--sky);\n  }\n  nav.toc a.active .num { color: var(--sky); }\n\n  .nav-foot {\n    margin-top: auto;\n    padding-top: 18px;\n    border-top: 1px solid rgba(255,255,255,0.08);\n    font-size: 11px;\n    color: rgba(255,255,255,0.4);\n    line-height: 1.8;\n  }\n  .nav-foot .row { display: flex; justify-content: space-between; padding: 2px 0; }\n  .nav-foot .row .v { color: rgba(255,255,255,0.7); }\n\n  /* ---------- Content ---------- */\n  main.content { min-width: 0; background: var(--paper); }\n\n  section.page {\n    min-height: 100vh;\n    padding: 80px 88px;\n    border-bottom: 1px solid var(--hairline-2);\n    display: flex; flex-direction: column; justify-content: flex-start;\n    position: relative;\n    overflow: hidden;\n  }\n  section.page > .inner { max-width: var(--content-max); width: 100%; margin-inline: auto; position: relative; z-index: 1; }\n\n  .page-meta {\n    display: flex; justify-content: space-between; align-items: baseline;\n    font-family: var(--f-en-body);\n    font-size: 11px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--ink-3);\n    border-bottom: 1px solid var(--hairline);\n    padding-bottom: 14px;\n    margin-bottom: 56px;\n  }\n  .page-meta .left { display: flex; gap: 24px; align-items: baseline; }\n  .page-meta .num {\n    font-feature-settings: \"tnum\" 1;\n    color: var(--indigo);\n    font-weight: 700;\n  }\n  .page-meta .right { color: var(--ink-4); font-feature-settings: \"tnum\" 1; }\n\n  /* Type */\n  h1.title-fa {\n    font-family: var(--f-display);\n    font-weight: 800;\n    font-size: clamp(48px, 6.5vw, 88px);\n    letter-spacing: -0.03em;\n    line-height: 0.98;\n    color: var(--navy-1);\n    margin: 0 0 14px;\n  }\n  .title-en {\n    font-family: var(--f-en-display);\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(28px, 3vw, 40px);\n    color: var(--indigo);\n    letter-spacing: -0.01em;\n    line-height: 1;\n    margin-bottom: 32px;\n    opacity: 0.7;\n  }\n  .lede {\n    font-family: var(--f-display);\n    font-size: clamp(19px, 1.5vw, 24px);\n    line-height: 1.7;\n    color: var(--ink-2);\n    max-width: 760px;\n    font-weight: 400;\n  }\n  .body { color: var(--ink-2); line-height: 1.85; max-width: 700px; }\n  .small { font-size: 13px; color: var(--ink-3); }\n\n  /* Statement — the marquee quote on key pages */\n  .statement {\n    font-family: var(--f-display);\n    font-weight: 700;\n    font-size: clamp(28px, 3.3vw, 46px);\n    line-height: 1.35;\n    color: var(--navy-1);\n    letter-spacing: -0.025em;\n    max-width: 960px;\n    text-wrap: balance;\n    position: relative;\n    padding-right: 32px;\n  }\n  .statement::before {\n    content: \"\";\n    position: absolute;\n    right: 0; top: 18px; bottom: 18px;\n    width: 4px;\n    background: linear-gradient(to bottom, var(--indigo), var(--sky));\n    border-radius: 2px;\n  }\n  .statement .accent { color: var(--indigo); }\n\n  /* ---------- Cover ---------- */\n  .cover {\n    background: var(--navy-1);\n    color: #fff;\n    min-height: 100vh;\n    padding: 0;\n    border: 0;\n    display: grid;\n    grid-template-rows: auto 1fr auto;\n    position: relative;\n    overflow: hidden;\n  }\n  /* Logo-inspired arc background */\n  .cover::before {\n    content: \"\";\n    position: absolute;\n    top: -25%; left: -15%;\n    width: 90%; aspect-ratio: 1;\n    background:\n      radial-gradient(circle at 50% 50%,\n        rgba(111,143,206,0.20) 0%,\n        rgba(42,45,126,0.0) 60%);\n    pointer-events: none;\n  }\n  .cover .arcs {\n    position: absolute;\n    top: 0; left: 0;\n    width: 75%; aspect-ratio: 1;\n    pointer-events: none;\n    opacity: 0.65;\n  }\n  .cover .arcs-2 {\n    position: absolute;\n    bottom: -10%; right: -8%;\n    width: 45%; aspect-ratio: 1;\n    pointer-events: none;\n    opacity: 0.3;\n  }\n  .cover .arcs svg, .cover .arcs-2 svg { width: 100%; height: 100%; display: block; }\n  .cover .arcs path { stroke: #6F8FCE; fill: none; stroke-linecap: round; }\n  .cover .arcs .accent-dot { fill: #6F8FCE; }\n  .cover-top {\n    display: flex; justify-content: space-between; align-items: center;\n    padding: 40px 80px;\n    font-family: var(--f-en-body); font-size: 11.5px;\n    letter-spacing: 0.18em; text-transform: uppercase;\n    color: rgba(255,255,255,0.55);\n    position: relative; z-index: 2;\n  }\n  .cover-top .badge {\n    padding: 7px 14px;\n    border: 1px solid rgba(255,255,255,0.18);\n    border-radius: 999px;\n    color: rgba(255,255,255,0.8);\n    line-height: 1;\n    height: auto;\n    display: inline-flex;\n    align-items: center;\n  }\n  .cover-mid {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    gap: 24px;\n    max-width: var(--content-max);\n    margin-inline: auto;\n    width: 100%;\n    padding: 0 80px;\n    position: relative; z-index: 2;\n  }\n  .cover-eyebrow {\n    font-family: var(--f-en-body);\n    font-size: 12px;\n    letter-spacing: 0.24em;\n    text-transform: uppercase;\n    color: var(--sky);\n    margin-bottom: 8px;\n  }\n  .cover-title {\n    font-family: var(--f-display);\n    font-size: clamp(64px, 11vw, 180px);\n    font-weight: 800;\n    line-height: 1.25;\n    letter-spacing: 0;\n    color: #fff;\n    padding-bottom: 0.05em;\n    margin-bottom: 0.05em;\n    white-space: nowrap;\n  }\n  .cover-title .pi {\n    margin-right: 0.04em;\n  }\n  .cover-title .pi {\n    background: linear-gradient(90deg, var(--sky), #B5D2FA);\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .cover-sub {\n    font-family: var(--f-en-display);\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 2.6vw, 36px);\n    color: rgba(255,255,255,0.55);\n    letter-spacing: -0.01em;\n  }\n  .cover-meta {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 28px;\n    margin-top: 36px;\n    padding-top: 32px;\n    border-top: 1px solid rgba(255,255,255,0.12);\n    max-width: 780px;\n  }\n  .cover-meta dt { font-family: var(--f-en-body); font-size: 10.5px; color: rgba(255,255,255,0.45); letter-spacing: 0.18em; text-transform: uppercase; margin: 0; }\n  .cover-meta dd { font-family: var(--f-display); font-size: 15px; color: #fff; margin: 6px 0 0; font-weight: 500; line-height: 1.4; }\n  .cover-foot {\n    display: flex; justify-content: space-between; align-items: end;\n    padding: 32px 80px;\n    font-family: var(--f-en-body); font-size: 11.5px;\n    letter-spacing: 0.14em;\n    color: rgba(255,255,255,0.4);\n    position: relative; z-index: 2;\n  }\n  .cover-foot .scroll-hint {\n    display: flex; align-items: center; gap: 12px;\n    color: rgba(255,255,255,0.7);\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    font-size: 11px;\n  }\n  .cover-foot .scroll-hint .arrow {\n    width: 22px; height: 1px; background: var(--sky); position: relative;\n    animation: arr 2.4s ease-in-out infinite;\n  }\n  .cover-foot .scroll-hint .arrow::before {\n    content: \"\";\n    position: absolute;\n    right: 0; top: -3px;\n    width: 7px; height: 7px;\n    border-top: 1px solid var(--sky);\n    border-right: 1px solid var(--sky);\n    transform: rotate(45deg);\n  }\n  @keyframes arr { 0%, 100% { width: 22px; opacity: 0.6; } 50% { width: 36px; opacity: 1; } }\n\n  /* Grid */\n  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }\n  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }\n  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }\n\n  .card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    padding: 28px;\n    position: relative;\n  }\n  .card .label {\n    font-family: var(--f-en-body);\n    font-size: 11px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: var(--indigo);\n    margin-bottom: 10px;\n    font-weight: 500;\n  }\n  .card h3 {\n    font-family: var(--f-display);\n    font-size: 22px;\n    font-weight: 700;\n    color: var(--navy-1);\n    margin: 0 0 12px;\n    letter-spacing: -0.015em;\n  }\n  .card p { color: var(--ink-2); margin: 0; font-size: 14.5px; line-height: 1.75; }\n\n  .section-head {\n    display: flex; align-items: baseline; gap: 16px;\n    margin: 56px 0 24px;\n    padding-bottom: 14px;\n    border-bottom: 1px solid var(--hairline-2);\n  }\n  .section-head .glyph {\n    font-family: var(--f-en-body);\n    font-size: 10.5px; color: var(--indigo);\n    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600;\n    font-feature-settings: \"tnum\" 1;\n  }\n  .section-head h2 {\n    font-family: var(--f-display);\n    font-size: 26px; font-weight: 700;\n    margin: 0; color: var(--navy-1); letter-spacing: -0.015em;\n  }\n\n  /* ---------- Product architecture diagram ---------- */\n  .arch {\n    margin: 40px 0 16px;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 40px;\n    position: relative;\n  }\n  .arch-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 16px;\n    margin-bottom: 28px;\n  }\n  .product-card {\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    padding: 24px 22px;\n    background: var(--paper-2);\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    min-height: 240px;\n  }\n  .product-card.chabok { background: var(--paper); }\n  .product-card.tiam { background: var(--paper); }\n  .product-card.hamta { background: var(--paper); }\n  .product-card.gift { background: var(--paper); }\n\n  .product-card .ribbon {\n    font-family: var(--f-en-body);\n    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--ink-3);\n    margin-bottom: 18px;\n    display: flex; align-items: center; gap: 8px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n  .product-card .ribbon .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--indigo); }\n  .product-card.gift .ribbon .dot { background: var(--coral); }\n  .product-card .name {\n    font-family: var(--f-display);\n    font-size: 30px; font-weight: 700;\n    color: var(--navy-1); letter-spacing: -0.02em;\n    line-height: 1; margin-bottom: 4px;\n  }\n  .product-card .latin {\n    font-family: var(--f-en-body);\n    font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase;\n    color: var(--ink-3);\n    margin-bottom: 14px;\n  }\n  .product-card .desc {\n    font-size: 13.5px;\n    color: var(--ink-2);\n    line-height: 1.65;\n    flex: 1;\n  }\n  .product-card .who {\n    margin-top: 14px;\n    padding-top: 12px;\n    border-top: 1px dashed var(--hairline);\n    font-size: 11.5px;\n    color: var(--ink-3);\n    display: flex; justify-content: space-between; align-items: baseline;\n  }\n  .product-card .who strong { color: var(--navy-2); font-weight: 600; font-size: 12px; }\n  .product-card .timing {\n    position: absolute; top: 22px; left: 22px;\n    font-family: var(--f-mono);\n    font-size: 10.5px;\n    background: var(--navy-1);\n    color: #fff;\n    padding: 3px 8px;\n    border-radius: 4px;\n    letter-spacing: 0.05em;\n  }\n\n  /* Foundation row */\n  .arch-foundation {\n    background: var(--navy-1);\n    border-radius: var(--r-md);\n    padding: 22px 28px;\n    color: #fff;\n    display: grid;\n    grid-template-columns: 1fr auto;\n    align-items: center;\n    gap: 24px;\n  }\n  .arch-foundation .label {\n    font-family: var(--f-en-body);\n    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;\n    color: var(--sky); margin-bottom: 6px;\n  }\n  .arch-foundation .text { color: rgba(255,255,255,0.85); font-size: 14px; }\n  .arch-foundation .text strong { color: #fff; font-weight: 600; }\n  .arch-foundation .meta {\n    display: flex; gap: 32px;\n    text-align: center;\n    border-right: 1px solid rgba(255,255,255,0.12);\n    padding-right: 32px;\n  }\n  .arch-foundation .meta .stat .n {\n    font-family: var(--f-display);\n    font-size: 28px; font-weight: 700;\n    color: #fff;\n    line-height: 1;\n    font-feature-settings: \"tnum\" 1;\n  }\n  .arch-foundation .meta .stat .l {\n    font-family: var(--f-en-body);\n    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;\n    color: rgba(255,255,255,0.55);\n    margin-top: 6px;\n  }\n\n  /* Connecting flow */\n  .arch-flow {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;\n    margin-top: 16px;\n    padding: 20px 28px;\n    background: var(--cloud);\n    border-radius: var(--r-md);\n    border: 1px solid var(--hairline-2);\n    font-size: 13px;\n    color: var(--ink-2);\n  }\n  .arch-flow strong { color: var(--navy-1); }\n\n  /* Audience cards */\n  .audience-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; }\n  .aud-card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    padding: 32px;\n    position: relative;\n    overflow: hidden;\n  }\n  .aud-card.banks { background: var(--paper); color: var(--ink); border-color: var(--hairline); position: relative; }\n  .aud-card.banks::before {\n    content: \"\";\n    position: absolute; top: 0; right: 0; bottom: 0;\n    width: 4px;\n    background: linear-gradient(to bottom, var(--indigo), var(--sky));\n    border-radius: 2px 0 0 2px;\n  }\n  .aud-card .role {\n    font-family: var(--f-en-body);\n    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;\n    color: var(--ink-3); margin-bottom: 18px;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .aud-card.banks .role { color: var(--indigo); }\n  .aud-card .role .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--indigo); }\n  .aud-card.banks .role .dot { background: var(--indigo); }\n  .aud-card h3 {\n    font-family: var(--f-display);\n    font-size: 28px; font-weight: 700;\n    letter-spacing: -0.02em; margin: 0 0 4px;\n    color: var(--navy-1);\n  }\n  .aud-card.banks h3 { color: var(--navy-1); }\n  .aud-card .latin {\n    font-family: var(--f-en-display); font-style: italic;\n    color: var(--ink-3); font-size: 16px; margin-bottom: 18px;\n  }\n  .aud-card.banks .latin { color: var(--ink-3); }\n  .aud-card p { font-size: 14px; color: var(--ink-2); margin: 0 0 14px; line-height: 1.75; }\n  .aud-card.banks p { color: var(--ink-2); }\n  .aud-card .scale {\n    margin-top: 20px;\n    padding-top: 16px;\n    border-top: 1px solid var(--hairline);\n    font-family: var(--f-mono);\n    font-size: 12px;\n    color: var(--indigo);\n    display: flex; justify-content: space-between;\n  }\n  .aud-card.banks .scale { border-color: var(--hairline); color: var(--indigo); }\n  .aud-card .product-tag {\n    display: inline-block;\n    padding: 4px 10px;\n    background: var(--mist);\n    color: var(--navy-2);\n    border-radius: 4px;\n    font-size: 11.5px;\n    font-weight: 500;\n    margin-left: 6px;\n    margin-bottom: 4px;\n  }\n  .aud-card.banks .product-tag { background: var(--cloud); color: var(--indigo); }\n\n  /* Competitive map */\n  .compass {\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 24px;\n    margin-top: 32px;\n  }\n  .compass-axis {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 40px;\n    position: relative;\n    min-height: 460px;\n  }\n  .compass-axis .ax-label {\n    position: absolute;\n    font-family: var(--f-en-body);\n    font-size: 11px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: var(--ink-3);\n  }\n  .compass-axis .ax-x-l { top: 50%; right: 32px; transform: translateY(-50%); }\n  .compass-axis .ax-x-r { top: 50%; left: 32px; transform: translateY(-50%); }\n  .compass-axis .ax-y-t { top: 24px; right: 50%; transform: translateX(50%); }\n  .compass-axis .ax-y-b { bottom: 24px; right: 50%; transform: translateX(50%); }\n  .compass-axis .axis-h {\n    position: absolute; top: 50%; right: 80px; left: 80px;\n    height: 1px; background: var(--hairline);\n  }\n  .compass-axis .axis-v {\n    position: absolute; right: 50%; top: 60px; bottom: 60px;\n    width: 1px; background: var(--hairline);\n    transform: translateX(50%);\n  }\n  .compass-axis .player {\n    position: absolute;\n    padding: 8px 14px;\n    border-radius: 999px;\n    font-family: var(--f-body);\n    font-size: 13px; font-weight: 600;\n    background: var(--paper); border: 1.5px solid var(--ink-3);\n    color: var(--ink-2);\n    white-space: nowrap;\n    transform: translate(50%, -50%);\n  }\n  .compass-axis .player.us {\n    background: var(--navy-1); color: #fff; border-color: var(--navy-1);\n    padding: 12px 20px;\n    font-size: 15px;\n    box-shadow: 0 12px 32px -8px rgba(26,30,92,0.4);\n  }\n  .compass-axis .player.us::before {\n    content: \"\"; position: absolute;\n    inset: -8px; border: 2px dashed var(--sky); border-radius: 999px;\n    pointer-events: none;\n    animation: spin 30s linear infinite;\n  }\n  @keyframes spin { to { transform: rotate(360deg); } }\n\n  /* Value-prop pillars */\n  .pillars {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 0;\n    margin-top: 32px;\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    overflow: hidden;\n    background: var(--paper);\n  }\n  .pillar {\n    padding: 32px 26px;\n    border-left: 1px solid var(--hairline-2);\n    position: relative;\n    background:\n      linear-gradient(180deg, rgba(111,143,206,0.04), transparent 50%);\n  }\n  .pillar:last-child { border-left: 0; }\n  .pillar .num {\n    font-family: var(--f-en-body);\n    font-feature-settings: \"tnum\" 1;\n    font-size: 12px;\n    color: var(--indigo); font-weight: 600;\n    letter-spacing: 0.10em;\n    margin-bottom: 32px;\n    display: block;\n  }\n  .pillar h3 {\n    font-family: var(--f-display);\n    font-size: 22px;\n    font-weight: 700;\n    margin: 0 0 10px;\n    letter-spacing: -0.015em;\n    line-height: 1.2;\n    color: var(--navy-1);\n  }\n  .pillar p { font-size: 14px; color: var(--ink-2); line-height: 1.7; margin: 0; }\n\n  /* Voice cols */\n  .voice-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }\n  .voice-cols .col {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    padding: 28px 32px;\n  }\n  .voice-cols .col.dont { background: transparent; border-style: dashed; }\n  .voice-cols .col h4 {\n    font-family: var(--f-display);\n    font-size: 20px; margin: 0 0 16px;\n    display: flex; align-items: center; gap: 10px;\n    color: var(--navy-1);\n  }\n  .voice-cols .col.dont h4 { color: var(--ink-3); }\n  .voice-cols .col h4 .mark {\n    width: 24px; height: 24px;\n    border-radius: 50%;\n    display: grid; place-items: center;\n    font-size: 14px; font-weight: 700;\n  }\n  .voice-cols .col.do .mark { background: var(--indigo); color: #fff; }\n  .voice-cols .col.dont .mark { background: transparent; border: 1px solid var(--ink-4); color: var(--ink-3); }\n  .voice-cols ul { padding: 0; margin: 0; list-style: none; }\n  .voice-cols li {\n    padding: 10px 0;\n    border-bottom: 1px dashed var(--hairline-2);\n    color: var(--ink-2);\n    font-size: 14.5px;\n    line-height: 1.65;\n  }\n  .voice-cols .dont li { color: var(--ink-3); text-decoration: line-through; text-decoration-color: var(--ink-4); }\n  .voice-cols li:last-child { border-bottom: 0; }\n\n  /* Tone dial */\n  .tone-dial {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 36px;\n    margin-top: 8px;\n  }\n  .tone-dial h4 {\n    font-family: var(--f-display);\n    font-size: 22px; margin: 0 0 6px;\n    font-weight: 700; color: var(--navy-1);\n  }\n  .tone-dial .sub { color: var(--ink-3); font-size: 14px; margin-bottom: 28px; }\n  .scale-row {\n    display: grid;\n    grid-template-columns: 140px 1fr 140px;\n    gap: 20px;\n    align-items: center;\n    padding: 14px 0;\n    border-bottom: 1px solid var(--hairline-2);\n  }\n  .scale-row:last-child { border-bottom: 0; }\n  .scale-row .end { font-size: 14px; color: var(--ink-2); font-weight: 500; }\n  .scale-row .end.r { text-align: left; color: var(--ink-3); }\n  .scale-track {\n    height: 6px;\n    background: var(--cloud);\n    border-radius: 999px;\n    position: relative;\n  }\n  .scale-track .b2c-dot, .scale-track .b2b-dot {\n    position: absolute;\n    top: 50%;\n    transform: translate(50%, -50%);\n    width: 16px; height: 16px;\n    border-radius: 50%;\n    border: 2px solid var(--paper);\n  }\n  .scale-track .b2c-dot { background: var(--coral); box-shadow: 0 0 0 1px var(--coral); }\n  .scale-track .b2b-dot { background: var(--navy-1); box-shadow: 0 0 0 1px var(--navy-1); }\n  .scale-row .end .tag {\n    display: inline-block;\n    font-family: var(--f-en-body);\n    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;\n    margin-top: 2px; color: var(--ink-4);\n  }\n  .tone-legend {\n    display: flex; gap: 28px;\n    margin-top: 22px; padding-top: 22px; border-top: 1px solid var(--hairline-2);\n    font-size: 13px; color: var(--ink-3);\n  }\n  .tone-legend .item { display: flex; align-items: center; gap: 8px; }\n  .tone-legend .swatch { width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--paper); box-shadow: 0 0 0 1px var(--hairline); }\n\n  /* Samples */\n  .samples { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }\n  .sample {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    padding: 22px 24px;\n  }\n  .sample .ctx {\n    display: flex; align-items: center; gap: 8px;\n    margin-bottom: 10px;\n    font-family: var(--f-en-body);\n    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--ink-3);\n  }\n  .sample .ctx .pill {\n    padding: 3px 8px;\n    background: var(--cloud);\n    border-radius: 4px;\n    color: var(--ink-2);\n    letter-spacing: 0.06em;\n    font-weight: 600;\n  }\n  .sample .ctx .pill.b2c { background: rgba(224,116,74,0.12); color: var(--coral); }\n  .sample .ctx .pill.b2b { background: rgba(42,45,126,0.10); color: var(--indigo); }\n  .sample blockquote {\n    margin: 0;\n    font-family: var(--f-display);\n    font-size: 16.5px;\n    line-height: 1.75;\n    color: var(--navy-1);\n    font-weight: 500;\n  }\n\n  /* Archetype card */\n  .archetype {\n    display: grid;\n    grid-template-columns: 260px 1fr;\n    gap: 32px;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 32px;\n    position: relative;\n    overflow: hidden;\n  }\n  .archetype.primary {\n    background: var(--navy-1);\n    color: #fff;\n    border-color: var(--navy-1);\n  }\n  .archetype.primary::after {\n    content: \"\";\n    position: absolute;\n    top: -30%; left: -10%;\n    width: 60%; aspect-ratio: 1;\n    background: radial-gradient(circle, rgba(111,143,206,0.18), transparent 60%);\n    pointer-events: none;\n  }\n  .archetype .symbol {\n    width: 100%; aspect-ratio: 1;\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    display: grid; place-items: center;\n    background: var(--paper-2);\n    position: relative;\n    z-index: 1;\n  }\n  .archetype.primary .symbol {\n    background: rgba(255,255,255,0.04);\n    border-color: rgba(255,255,255,0.10);\n  }\n  .archetype .body { position: relative; z-index: 1; }\n  .archetype .body .pct {\n    font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;\n    color: var(--indigo); margin-bottom: 8px; font-weight: 600;\n  }\n  .archetype.primary .body .pct { color: var(--sky); }\n  .archetype .body h3 {\n    font-family: var(--f-display); font-size: 34px; font-weight: 800;\n    margin: 0 0 4px; letter-spacing: -0.025em;\n    color: var(--navy-1);\n  }\n  .archetype.primary .body h3 { color: #fff; }\n  .archetype .body .latin {\n    font-family: var(--f-en-display); font-style: italic;\n    color: var(--ink-3); font-size: 18px; margin-bottom: 16px;\n  }\n  .archetype.primary .body .latin { color: rgba(255,255,255,0.5); }\n  .archetype .body p {\n    color: var(--ink-2); font-size: 15px;\n    line-height: 1.85; max-width: 580px; margin: 0 0 12px;\n  }\n  .archetype.primary .body p { color: rgba(255,255,255,0.75); }\n  .archetype .body p strong { color: var(--navy-1); }\n  .archetype.primary .body p strong { color: #fff; }\n  .traits { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }\n  .traits span {\n    font-size: 12.5px;\n    padding: 6px 12px;\n    background: var(--cloud);\n    border: 1px solid var(--hairline);\n    border-radius: 999px;\n    color: var(--ink-2); font-weight: 500;\n  }\n  .archetype.primary .traits span {\n    background: rgba(255,255,255,0.06);\n    border-color: rgba(255,255,255,0.12);\n    color: rgba(255,255,255,0.85);\n  }\n\n  /* Pyramid */\n  .pyramid { display: flex; flex-direction: column; gap: 4px; margin-top: 24px; max-width: 900px; margin-inline: auto; }\n  .pyramid .level {\n    display: grid; grid-template-columns: 220px 1fr; gap: 20px;\n    align-items: stretch;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    overflow: hidden;\n  }\n  .pyramid .level .k {\n    background: var(--cloud);\n    padding: 18px 22px;\n    display: flex; flex-direction: column; justify-content: center;\n    border-left: 1px solid var(--hairline-2);\n  }\n  .pyramid .level .k .latin {\n    font-family: var(--f-en-body);\n    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n  }\n  .pyramid .level .k .fa {\n    font-family: var(--f-display);\n    font-weight: 700; font-size: 16px;\n    color: var(--navy-1); margin-top: 2px;\n  }\n  .pyramid .level .v {\n    padding: 18px 24px;\n    display: flex; align-items: center;\n    color: var(--ink-2);\n    font-size: 15px; line-height: 1.6;\n  }\n  .pyramid .level.essence { background: var(--navy-1); border-color: var(--navy-1); }\n  .pyramid .level.essence .k { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }\n  .pyramid .level.essence .k .latin { color: var(--sky); }\n  .pyramid .level.essence .k .fa { color: #fff; }\n  .pyramid .level.essence .v {\n    color: #fff;\n    font-family: var(--f-display);\n    font-weight: 700; font-size: 18px;\n  }\n\n  /* Tagline */\n  .tagline-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 22px; margin: 48px 0; }\n  .word-card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 48px 32px;\n    text-align: center;\n    aspect-ratio: 1;\n    display: flex; flex-direction: column; justify-content: space-between;\n    position: relative; overflow: hidden;\n  }\n  .word-card.dark { background: var(--navy-1); color: #fff; border-color: var(--navy-1); }\n  .word-card::before {\n    content: \"\";\n    position: absolute; inset: 0;\n    background: radial-gradient(circle at 50% 100%, rgba(111,143,206,0.10), transparent 60%);\n  }\n  .word-card .num {\n    font-family: var(--f-en-body); font-feature-settings: \"tnum\" 1;\n    font-size: 11.5px; color: var(--indigo); letter-spacing: 0.18em; font-weight: 700;\n    z-index: 1;\n  }\n  .word-card.dark .num { color: var(--sky); }\n  .word-card .big {\n    font-family: var(--f-display); font-weight: 800;\n    font-size: clamp(36px, 4.6vw, 64px);\n    color: var(--navy-1); letter-spacing: -0.03em; line-height: 1;\n    z-index: 1;\n  }\n  .word-card.dark .big { color: #fff; }\n  .word-card .latin {\n    font-family: var(--f-en-display); font-style: italic;\n    font-size: 17px; color: var(--ink-3);\n    z-index: 1;\n  }\n  .word-card.dark .latin { color: rgba(255,255,255,0.55); }\n\n  .final-quote {\n    font-family: var(--f-display);\n    font-weight: 700;\n    font-size: clamp(34px, 4.2vw, 62px);\n    line-height: 1.3;\n    letter-spacing: -0.025em;\n    text-wrap: balance;\n    max-width: 1000px;\n    color: var(--navy-1);\n  }\n  .final-quote .em { color: var(--indigo); }\n\n  /* Misc */\n  .num-list { list-style: none; padding: 0; margin: 24px 0 0; counter-reset: nl; }\n  .num-list li {\n    counter-increment: nl;\n    padding: 18px 0;\n    border-top: 1px solid var(--hairline-2);\n    display: grid;\n    grid-template-columns: 50px 220px 1fr;\n    gap: 24px;\n    align-items: baseline;\n  }\n  .num-list li:last-child { border-bottom: 1px solid var(--hairline-2); }\n  .num-list li::before {\n    content: counter(nl, decimal-leading-zero);\n    font-family: var(--f-en-body);\n    font-feature-settings: \"tnum\" 1;\n    color: var(--indigo);\n    font-size: 14px; font-weight: 600;\n  }\n  .num-list .term {\n    font-family: var(--f-display);\n    font-weight: 700;\n    font-size: 18px;\n    color: var(--navy-1);\n  }\n  .num-list .term .latin {\n    display: block;\n    font-family: var(--f-en-display);\n    font-style: italic;\n    font-weight: 400;\n    font-size: 13px;\n    color: var(--ink-3);\n    margin-top: 2px;\n  }\n  .num-list .desc { color: var(--ink-2); font-size: 14.5px; line-height: 1.75; }\n\n  .progress-bar {\n    position: fixed; top: 0; left: 0; right: 0;\n    height: 2px; background: transparent;\n    z-index: 100;\n  }\n  .progress-bar .fill {\n    height: 100%;\n    background: linear-gradient(90deg, var(--indigo), var(--sky));\n    width: 0;\n    transition: width 80ms linear;\n  }\n\n  @media print {\n    aside.nav { display: none; }\n    .shell { grid-template-columns: 1fr; }\n    section.page { page-break-after: always; min-height: auto; padding: 40px; }\n  }\n\n  /* Section ground tints — to break monotony */\n  section.page.tint { background: linear-gradient(180deg, var(--paper-2), var(--paper) 30%); }\n  section.page.dark {\n    background: var(--navy-1); color: #fff;\n  }\n  section.page.dark h1.title-fa { color: #fff; }\n  section.page.dark .title-en { color: var(--sky); opacity: 0.8; }\n  section.page.dark .lede { color: rgba(255,255,255,0.85); }\n  section.page.dark .statement { color: #fff; }\n  section.page.dark .page-meta { color: rgba(255,255,255,0.45); border-color: rgba(255,255,255,0.15); }\n  section.page.dark .page-meta .num { color: var(--sky); }\n  section.page.dark .page-meta .right { color: rgba(255,255,255,0.35); }\n  section.page.dark .section-head h2 { color: #fff; }\n  section.page.dark .section-head { border-color: rgba(255,255,255,0.12); }\n  section.page.dark .section-head .glyph { color: var(--sky); }\n  section.page.dark .card { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.10); }\n  section.page.dark .card h3 { color: #fff; }\n  section.page.dark .card p { color: rgba(255,255,255,0.7); }\n  section.page.dark .card .label { color: var(--sky); }\n\n  /* ==================== DESIGN SYSTEM (Volume 2) ==================== */\n\n  /* Volume divider hero */\n  .vol-divider {\n    background: var(--navy-1) !important;\n    color: #fff !important;\n    border-bottom: 0 !important;\n    overflow: hidden;\n    position: relative;\n  }\n  .vol-divider .stripe {\n    position: absolute; top: 0; bottom: 0; right: 0;\n    width: 38%;\n    background: linear-gradient(135deg, var(--indigo) 0%, var(--blue) 50%, var(--sky) 100%);\n    clip-path: polygon(30% 0, 100% 0, 100% 100%, 0% 100%);\n  }\n\n  /* ---------- Logo system ---------- */\n  .logo-hero {\n    background: var(--navy-1);\n    border-radius: var(--r-xl);\n    padding: 80px 60px;\n    display: grid;\n    place-items: center;\n    min-height: 360px;\n    position: relative;\n    overflow: hidden;\n    margin-top: 32px;\n  }\n  .logo-hero img { max-height: 220px; width: auto; position: relative; z-index: 1; }\n  .logo-hero::before {\n    content: \"\"; position: absolute; inset: 0;\n    background: radial-gradient(circle at 30% 50%, rgba(111,143,206,0.18), transparent 60%);\n  }\n  .logo-hero .marker {\n    position: absolute;\n    font-family: var(--f-en-body);\n    font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase;\n    color: var(--sky); font-weight: 600;\n    top: 20px; right: 24px;\n  }\n\n  .logo-anatomy {\n    display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px;\n    margin-top: 32px;\n  }\n  .anatomy-stage {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 56px 48px;\n    display: grid; place-items: center;\n    position: relative;\n    min-height: 380px;\n  }\n  .anatomy-stage img { max-height: 240px; width: auto; }\n  .anatomy-stage .callout {\n    position: absolute;\n    font-family: var(--f-en-body);\n    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .anatomy-stage .callout::before {\n    content: \"\"; width: 24px; height: 1px; background: var(--indigo);\n  }\n  .anatomy-stage .callout.c1 { top: 32px; right: 32px; }\n  .anatomy-stage .callout.c2 { top: 50%; left: 32px; transform: translateY(-50%); }\n  .anatomy-stage .callout.c3 { bottom: 32px; right: 32px; }\n  .anatomy-stage .callout.c1::after,\n  .anatomy-stage .callout.c2::after,\n  .anatomy-stage .callout.c3::after { display: none; }\n\n  .anatomy-stage .callout.c2::before { transform: rotate(0deg); }\n  .anatomy-notes { display: flex; flex-direction: column; gap: 12px; }\n  .anatomy-note {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    padding: 18px 22px;\n  }\n  .anatomy-note .num {\n    font-family: var(--f-en-body); font-size: 11px;\n    color: var(--indigo); letter-spacing: 0.16em;\n    font-weight: 700;\n  }\n  .anatomy-note h4 {\n    font-family: var(--f-display); font-size: 17px;\n    margin: 6px 0 6px; color: var(--navy-1);\n  }\n  .anatomy-note p { font-size: 13.5px; color: var(--ink-2); margin: 0; line-height: 1.65; }\n\n  /* Clear-space and minimum-size grids */\n  .logo-rules {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px;\n  }\n  .rule-card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 32px;\n  }\n  .rule-card h4 {\n    font-family: var(--f-display); font-size: 18px;\n    margin: 0 0 6px; color: var(--navy-1);\n  }\n  .rule-card .rule-sub {\n    font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.14em;\n    text-transform: uppercase; color: var(--indigo); margin-bottom: 24px;\n  }\n  .clearspace-stage {\n    background: var(--cloud);\n    border: 1px dashed var(--hairline);\n    border-radius: var(--r-md);\n    padding: 56px;\n    display: grid; place-items: center;\n    position: relative;\n    min-height: 220px;\n  }\n  .clearspace-stage img { max-height: 100px; width: auto; }\n  .clearspace-stage .gap-marker {\n    position: absolute;\n    font-family: var(--f-mono); font-size: 11px;\n    color: var(--indigo); font-weight: 600;\n    background: var(--paper); padding: 2px 8px; border-radius: 4px;\n    border: 1px solid var(--hairline);\n  }\n  .min-size-row {\n    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px;\n  }\n  .min-size-row .ms {\n    background: var(--cloud);\n    border-radius: var(--r-md);\n    padding: 16px;\n    text-align: center;\n    border: 1px solid var(--hairline-2);\n  }\n  .min-size-row .ms img { max-height: 56px; width: auto; }\n  .min-size-row .ms.tiny img { max-height: 22px; }\n  .min-size-row .ms.huge img { max-height: 100px; }\n  .min-size-row .ms .lbl {\n    font-family: var(--f-mono); font-size: 11px;\n    color: var(--ink-3); margin-top: 12px;\n    display: block;\n  }\n\n  /* Logo variants on different backgrounds */\n  .logo-variants {\n    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 32px;\n  }\n  .logo-variant {\n    border-radius: var(--r-md);\n    padding: 28px 18px;\n    display: grid; place-items: center;\n    text-align: center;\n    min-height: 160px;\n    position: relative;\n  }\n  .logo-variant img { max-height: 64px; width: auto; }\n  .logo-variant.on-white { background: #fff; border: 1px solid var(--hairline); }\n  .logo-variant.on-cloud { background: var(--cloud); border: 1px solid var(--hairline-2); }\n  .logo-variant.on-navy { background: var(--navy-1); }\n  .logo-variant.on-indigo { background: var(--indigo); }\n  .logo-variant .v-label {\n    position: absolute; bottom: 10px; left: 10px;\n    font-family: var(--f-en-body); font-size: 9.5px;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--ink-3); font-weight: 600;\n  }\n  .logo-variant.on-navy .v-label, .logo-variant.on-indigo .v-label { color: rgba(255,255,255,0.55); }\n  .logo-variant.mono img { filter: brightness(0) invert(1); }\n  .logo-variant.mono-dark img { filter: brightness(0); }\n\n  /* Do/Don't logo */\n  .logo-rules-grid {\n    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 24px;\n  }\n  .logo-rule {\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    padding: 16px;\n    background: var(--paper);\n    position: relative;\n    min-height: 160px;\n    display: flex; flex-direction: column;\n  }\n  .logo-rule .lr-stage {\n    flex: 1;\n    background: var(--cloud);\n    border-radius: 6px;\n    display: grid; place-items: center;\n    margin-bottom: 12px;\n    padding: 14px;\n  }\n  .logo-rule .lr-stage img { max-height: 48px; width: auto; }\n  .logo-rule .lr-stage.bad { filter: saturate(0.3) brightness(1.2); }\n  .logo-rule .lr-stage.bad img { transform: skewX(-12deg); }\n  .logo-rule .lr-stage.bad-2 img { filter: hue-rotate(120deg); }\n  .logo-rule .lr-stage.bad-3 img { transform: rotate(-8deg); }\n  .logo-rule .lr-stage.bad-4 { background: rgba(0,128,0,0.35); }\n  .logo-rule .lr-label {\n    font-family: var(--f-en-body); font-size: 11px;\n    color: var(--ink-3); letter-spacing: 0.06em;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .logo-rule .lr-label .x {\n    width: 18px; height: 18px; border-radius: 50%;\n    display: grid; place-items: center; font-weight: 700; font-size: 11px;\n    background: rgba(220,40,40,0.12); color: #c44;\n  }\n  .logo-rule .lr-label.ok .x { background: rgba(31,138,91,0.12); color: var(--emerald); }\n\n  /* ---------- Color palette ---------- */\n  .palette-hero {\n    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 8px;\n    margin-top: 32px;\n    height: 280px;\n    border-radius: var(--r-xl);\n    overflow: hidden;\n  }\n  .palette-hero .ph {\n    padding: 24px; display: flex; flex-direction: column; justify-content: space-between;\n    font-family: var(--f-en-body); position: relative;\n  }\n  .palette-hero .ph .nm { font-family: var(--f-display); font-size: 20px; font-weight: 700; letter-spacing: -0.01em; }\n  .palette-hero .ph .ltn { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.7; }\n  .palette-hero .ph .hex { font-family: var(--f-mono); font-size: 13px; opacity: 0.8; margin-top: 4px; }\n  .palette-hero .ph .pct {\n    font-family: var(--f-display); font-size: 56px; font-weight: 800;\n    line-height: 1; letter-spacing: -0.02em;\n  }\n\n  .palette-row {\n    display: grid; grid-template-columns: repeat(9, 1fr); gap: 4px;\n    margin-top: 8px;\n    height: 110px;\n  }\n  .palette-row .ramp {\n    display: flex; flex-direction: column; justify-content: end;\n    padding: 10px 12px;\n    font-family: var(--f-mono); font-size: 10.5px;\n    border-radius: 6px;\n  }\n  .palette-row .ramp .step { opacity: 0.6; font-size: 9.5px; letter-spacing: 0.06em; }\n  .palette-row .ramp .hex-tiny { font-weight: 600; margin-top: 2px; }\n\n  .palette-section {\n    display: grid; grid-template-columns: 220px 1fr; gap: 24px;\n    margin-top: 32px;\n    padding: 20px 0;\n    border-top: 1px solid var(--hairline);\n  }\n  .palette-section .ps-title h3 {\n    font-family: var(--f-display); font-size: 22px; font-weight: 700;\n    margin: 0; color: var(--navy-1);\n  }\n  .palette-section .ps-title p { font-size: 13.5px; color: var(--ink-3); margin: 6px 0 0; }\n\n  .swatch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }\n  .swatch-card {\n    border-radius: var(--r-md);\n    overflow: hidden;\n    border: 1px solid var(--hairline);\n    background: var(--paper);\n  }\n  .swatch-card .chip { height: 80px; }\n  .swatch-card .meta { padding: 12px 14px; }\n  .swatch-card .nm { font-family: var(--f-display); font-weight: 600; font-size: 14.5px; color: var(--navy-1); }\n  .swatch-card .ltn { font-family: var(--f-en-body); font-size: 10.5px; color: var(--ink-3); letter-spacing: 0.08em; margin-top: 2px; }\n  .swatch-card .hex { font-family: var(--f-mono); font-size: 11.5px; color: var(--ink-2); margin-top: 6px; }\n\n  /* Color pairings */\n  .pairings { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px; }\n  .pairing {\n    border-radius: var(--r-md);\n    overflow: hidden;\n    border: 1px solid var(--hairline);\n    background: var(--paper);\n  }\n  .pairing .demo {\n    padding: 28px 24px;\n    font-family: var(--f-display);\n    font-size: 22px; font-weight: 700;\n    letter-spacing: -0.01em;\n    min-height: 110px;\n    display: flex; align-items: center;\n  }\n  .pairing .info { padding: 14px 18px; font-size: 12px; color: var(--ink-3); font-family: var(--f-mono); }\n  .pairing .info strong { color: var(--ink-2); font-weight: 600; }\n\n  /* ---------- Typography ---------- */\n  .type-display {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 48px 40px;\n    margin-top: 32px;\n    position: relative;\n  }\n  .type-display .tags {\n    display: flex; gap: 8px;\n    margin-bottom: 18px;\n    font-family: var(--f-en-body); font-size: 11px;\n    letter-spacing: 0.12em; text-transform: uppercase; color: var(--indigo); font-weight: 600;\n  }\n  .type-display .tags span {\n    padding: 4px 10px; background: var(--cloud); border-radius: 999px;\n  }\n  .type-display .specimen {\n    font-size: clamp(64px, 9vw, 132px);\n    line-height: 0.95;\n    letter-spacing: -0.03em;\n    margin: 0;\n    color: var(--navy-1);\n  }\n  .type-display .meta-row {\n    display: grid; grid-template-columns: repeat(4, 1fr);\n    gap: 24px;\n    margin-top: 32px;\n    padding-top: 24px;\n    border-top: 1px solid var(--hairline);\n    font-family: var(--f-en-body); font-size: 12px;\n  }\n  .type-display .meta-row .k { color: var(--ink-3); letter-spacing: 0.10em; text-transform: uppercase; font-size: 10.5px; }\n  .type-display .meta-row .v { color: var(--navy-1); font-weight: 600; margin-top: 4px; }\n\n  .type-scale {\n    margin-top: 32px;\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    overflow: hidden;\n  }\n  .type-scale .row {\n    display: grid;\n    grid-template-columns: 140px 100px 90px 1fr;\n    gap: 16px;\n    padding: 18px 24px;\n    align-items: baseline;\n    border-bottom: 1px solid var(--hairline-2);\n  }\n  .type-scale .row:last-child { border-bottom: 0; }\n  .type-scale .row.head {\n    background: var(--cloud);\n    font-family: var(--f-en-body); font-size: 10.5px;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--ink-3); font-weight: 600;\n  }\n  .type-scale .row .nm { font-family: var(--f-en-body); font-size: 13px; color: var(--navy-1); font-weight: 600; }\n  .type-scale .row .px { font-family: var(--f-mono); font-size: 12px; color: var(--ink-3); }\n  .type-scale .row .wt { font-family: var(--f-mono); font-size: 12px; color: var(--ink-3); }\n  .type-scale .row .demo { color: var(--navy-1); }\n\n  /* ---------- Iconography ---------- */\n  .icon-grid {\n    display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px;\n    margin-top: 32px;\n  }\n  .icon-cell {\n    aspect-ratio: 1;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    display: grid; place-items: center;\n    position: relative;\n    padding: 22px;\n  }\n  .icon-cell svg { width: 100%; height: 100%; max-width: 56px; max-height: 56px; }\n  .icon-cell .name {\n    position: absolute; bottom: 8px; left: 0; right: 0;\n    text-align: center;\n    font-family: var(--f-en-body);\n    font-size: 9.5px;\n    color: var(--ink-3);\n    letter-spacing: 0.06em;\n  }\n  .icon-rules {\n    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;\n    margin-top: 24px;\n  }\n  .icon-rule {\n    background: var(--paper); border: 1px solid var(--hairline);\n    border-radius: var(--r-md); padding: 18px 22px;\n  }\n  .icon-rule .label {\n    font-family: var(--f-en-body); font-size: 10.5px;\n    letter-spacing: 0.16em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n  }\n  .icon-rule h4 { font-family: var(--f-display); font-size: 16px; margin: 6px 0 4px; color: var(--navy-1); }\n  .icon-rule p { font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.6; }\n\n  /* Icon construction sample */\n  .icon-construction {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    padding: 32px;\n    display: grid; grid-template-columns: 1fr 1fr; gap: 32px;\n    align-items: center;\n    margin-top: 24px;\n  }\n  .construction-svg {\n    aspect-ratio: 1; width: 100%;\n    background:\n      repeating-linear-gradient(0deg, var(--hairline-2), var(--hairline-2) 1px, transparent 1px, transparent 8.33%),\n      repeating-linear-gradient(90deg, var(--hairline-2), var(--hairline-2) 1px, transparent 1px, transparent 8.33%);\n    border-radius: var(--r-sm);\n    position: relative;\n    border: 1px solid var(--hairline);\n  }\n\n  /* ---------- Patterns ---------- */\n  .pattern-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; }\n  .pattern-tile {\n    aspect-ratio: 4/3;\n    border-radius: var(--r-md);\n    overflow: hidden;\n    position: relative;\n    border: 1px solid var(--hairline);\n  }\n  .pattern-tile .ptl {\n    position: absolute; bottom: 12px; right: 14px;\n    font-family: var(--f-en-body); font-size: 10.5px;\n    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;\n    padding: 4px 10px; border-radius: 4px;\n    background: var(--paper); color: var(--navy-1);\n    z-index: 2;\n  }\n  .pat-arcs { background: var(--navy-1); }\n  .pat-dots {\n    background:\n      radial-gradient(circle at 1px 1px, var(--mist) 1.5px, transparent 0) 0 0 / 20px 20px,\n      var(--paper);\n  }\n  .pat-mesh {\n    background:\n      radial-gradient(circle at 20% 20%, var(--sky), transparent 50%),\n      radial-gradient(circle at 80% 80%, var(--indigo), transparent 50%),\n      var(--navy-1);\n  }\n  .pat-grid {\n    background:\n      linear-gradient(to right, var(--hairline) 1px, transparent 1px) 0 0 / 24px 24px,\n      linear-gradient(to bottom, var(--hairline) 1px, transparent 1px) 0 0 / 24px 24px,\n      var(--cloud);\n  }\n  .pat-diagonal {\n    background: repeating-linear-gradient(45deg, var(--indigo) 0, var(--indigo) 2px, transparent 2px, transparent 14px), var(--navy-1);\n  }\n  .pat-blueprint {\n    background:\n      linear-gradient(to right, rgba(111,143,206,0.3) 1px, transparent 1px) 0 0 / 32px 32px,\n      linear-gradient(to bottom, rgba(111,143,206,0.3) 1px, transparent 1px) 0 0 / 32px 32px,\n      var(--navy-1);\n  }\n\n  /* ---------- UI Components ---------- */\n  .ui-section {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    padding: 28px 32px;\n    margin-top: 16px;\n  }\n  .ui-section h4 {\n    font-family: var(--f-display); font-size: 17px;\n    margin: 0 0 4px; color: var(--navy-1);\n  }\n  .ui-section .ui-sub {\n    font-family: var(--f-en-body); font-size: 11px;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600; margin-bottom: 20px;\n  }\n  .ui-row { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }\n\n  /* Button styles */\n  .btn {\n    display: inline-flex; align-items: center; gap: 8px;\n    padding: 10px 20px;\n    font-family: var(--f-body); font-weight: 600; font-size: 14px;\n    border-radius: 8px; border: 1px solid transparent;\n    cursor: pointer;\n    transition: all 160ms;\n  }\n  .btn-primary { background: var(--navy-1); color: #fff; }\n  .btn-primary:hover { background: var(--indigo); }\n  .btn-secondary { background: var(--paper); color: var(--navy-1); border-color: var(--ink-3); }\n  .btn-secondary:hover { background: var(--cloud); border-color: var(--navy-2); }\n  .btn-ghost { background: transparent; color: var(--navy-1); }\n  .btn-ghost:hover { background: var(--cloud); }\n  .btn-accent { background: var(--coral); color: #fff; }\n  .btn-disabled { background: var(--cloud); color: var(--ink-4); cursor: not-allowed; }\n  .btn-lg { padding: 14px 28px; font-size: 15px; }\n  .btn-sm { padding: 6px 14px; font-size: 12.5px; }\n\n  /* Input styles */\n  .field {\n    display: flex; flex-direction: column; gap: 6px;\n    min-width: 220px;\n  }\n  .field label {\n    font-size: 12px; color: var(--ink-3);\n    font-family: var(--f-body); font-weight: 500;\n  }\n  .field input {\n    padding: 11px 14px;\n    border: 1px solid var(--hairline);\n    border-radius: 8px;\n    font-family: var(--f-body); font-size: 14px;\n    background: var(--paper);\n    color: var(--navy-1);\n    transition: border-color 160ms, box-shadow 160ms;\n  }\n  .field input:focus {\n    outline: none;\n    border-color: var(--indigo);\n    box-shadow: 0 0 0 3px rgba(42,45,126,0.12);\n  }\n  .field.err input { border-color: #c44; }\n  .field .helper { font-size: 11.5px; color: var(--ink-3); }\n  .field.err .helper { color: #c44; }\n\n  /* Card components */\n  .ui-card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }\n  .ui-card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    padding: 22px;\n  }\n  .ui-card .h { font-family: var(--f-display); font-weight: 700; font-size: 16px; color: var(--navy-1); margin-bottom: 6px; }\n  .ui-card .b { font-size: 13px; color: var(--ink-2); line-height: 1.65; }\n  .ui-card.elevated { box-shadow: 0 12px 32px -16px rgba(26,30,92,0.18); }\n  .ui-card.feature { background: var(--navy-1); color: #fff; border-color: var(--navy-1); }\n  .ui-card.feature .h { color: #fff; }\n  .ui-card.feature .b { color: rgba(255,255,255,0.7); }\n\n  /* Badges (legacy - unused, kept for backward compat) */\n  .badge-default { background: var(--cloud); color: var(--ink-2); }\n  .badge-primary { background: rgba(42,45,126,0.10); color: var(--indigo); }\n  .badge-success { background: rgba(31,138,91,0.12); color: var(--emerald); }\n  .badge-warn { background: rgba(224,116,74,0.14); color: var(--coral); }\n  .badge-dot::before { content: \"\"; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }\n\n  /* ---------- Spacing & Grid ---------- */\n  .spacing-scale {\n    display: grid; grid-template-columns: repeat(8, 1fr); gap: 8px; margin-top: 32px;\n  }\n  .sp-cell {\n    background: var(--paper); border: 1px solid var(--hairline);\n    border-radius: var(--r-sm);\n    padding: 16px;\n    display: flex; flex-direction: column; gap: 10px;\n    min-height: 120px;\n  }\n  .sp-cell .swatch-sq {\n    background: var(--indigo); border-radius: 2px;\n  }\n  .sp-cell .name { font-family: var(--f-mono); font-size: 11px; color: var(--ink-3); }\n  .sp-cell .val { font-family: var(--f-display); font-size: 18px; font-weight: 700; color: var(--navy-1); }\n\n  .grid-demo {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    padding: 32px;\n    margin-top: 24px;\n  }\n  .grid-cols {\n    display: grid; grid-template-columns: repeat(12, 1fr); gap: 8px;\n  }\n  .grid-cols .col-bar {\n    height: 80px; border-radius: 4px;\n    background: linear-gradient(180deg, var(--mist), var(--cloud));\n    border: 1px dashed var(--blue);\n    display: grid; place-items: center;\n    font-family: var(--f-mono); font-size: 10px; color: var(--indigo); font-weight: 600;\n  }\n\n  /* ---------- Motion ---------- */\n  .motion-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; }\n  .motion-card {\n    background: var(--paper); border: 1px solid var(--hairline);\n    border-radius: var(--r-md); padding: 24px;\n    position: relative;\n    overflow: hidden;\n  }\n  .motion-card .nm { font-family: var(--f-display); font-size: 17px; font-weight: 700; color: var(--navy-1); margin-bottom: 4px; }\n  .motion-card .code { font-family: var(--f-mono); font-size: 11.5px; color: var(--ink-3); margin-bottom: 16px; }\n  .motion-card .curve { height: 80px; margin-bottom: 12px; }\n  .motion-card p { font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.6; }\n  .motion-ball {\n    width: 12px; height: 12px; border-radius: 50%;\n    background: var(--indigo);\n    margin-top: 6px;\n    animation: ball-move 2.4s infinite;\n  }\n  .motion-card.standard .motion-ball { animation-timing-function: cubic-bezier(0.4, 0.0, 0.2, 1); }\n  .motion-card.decel .motion-ball { animation-timing-function: cubic-bezier(0, 0, 0.2, 1); }\n  .motion-card.accel .motion-ball { animation-timing-function: cubic-bezier(0.4, 0.0, 1, 1); }\n  @keyframes ball-move {\n    0% { transform: translateX(0); }\n    50% { transform: translateX(220px); }\n    100% { transform: translateX(0); }\n  }\n\n  /* ---------- Applications ---------- */\n  .app-grid {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px;\n  }\n  .app-stage {\n    background: rgba(255,255,255,0.04);\n    border: 1px solid rgba(255,255,255,0.10);\n    border-radius: var(--r-xl);\n    padding: 36px;\n    position: relative;\n    overflow: hidden;\n    min-height: 320px;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .app-stage .app-label {\n    position: absolute; top: 18px; right: 22px;\n    font-family: var(--f-en-body); font-size: 10.5px;\n    letter-spacing: 0.16em; text-transform: uppercase;\n    color: var(--sky); font-weight: 600;\n  }\n\n  /* Business card mock */\n  .bcard {\n    width: 320px; aspect-ratio: 1.75/1;\n    background: var(--navy-1);\n    border-radius: 8px;\n    padding: 22px;\n    position: relative;\n    overflow: hidden;\n    box-shadow: 0 24px 48px -16px rgba(0,0,0,0.5);\n  }\n  .bcard::before {\n    content: \"\"; position: absolute; top: -40%; right: -20%;\n    width: 70%; aspect-ratio: 1;\n    background: radial-gradient(circle, rgba(111,143,206,0.25), transparent 60%);\n  }\n  .bcard .bc-logo { display: flex; align-items: center; gap: 10px; position: relative; z-index: 1; }\n  .bcard .bc-logo img { width: 38px; height: 38px; }\n  .bcard .bc-logo .nm { font-family: var(--f-display); color: #fff; font-weight: 700; font-size: 16px; }\n  .bcard .bc-logo .ltn { font-family: var(--f-en-body); font-size: 9.5px; color: var(--sky); letter-spacing: 0.16em; text-transform: uppercase; margin-top: 2px; }\n  .bcard .bc-meta {\n    position: absolute; bottom: 22px; right: 22px; left: 22px;\n    color: rgba(255,255,255,0.85);\n    font-size: 12px; line-height: 1.6;\n    z-index: 1;\n  }\n  .bcard .bc-meta .who { font-family: var(--f-display); font-weight: 700; font-size: 16px; color: #fff; margin-bottom: 2px; }\n  .bcard .bc-meta .role { color: var(--sky); font-size: 11px; letter-spacing: 0.08em; margin-bottom: 12px; }\n  .bcard .bc-meta .ct { font-family: var(--f-mono); font-size: 11px; color: rgba(255,255,255,0.65); }\n\n  /* Mobile app mock */\n  .phone-mock {\n    width: 220px; aspect-ratio: 9/19;\n    background: var(--navy-1);\n    border-radius: 28px;\n    padding: 14px 12px;\n    position: relative;\n    border: 4px solid #18193A;\n    overflow: hidden;\n    box-shadow: 0 24px 48px -16px rgba(0,0,0,0.5);\n  }\n  .phone-mock .notch {\n    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);\n    width: 60px; height: 18px; background: #0a0a20; border-radius: 999px;\n  }\n  .phone-mock .screen {\n    background: var(--paper);\n    height: 100%; border-radius: 18px;\n    overflow: hidden;\n    padding: 36px 14px 14px;\n    color: var(--navy-1);\n    font-family: var(--f-body);\n  }\n  .phone-mock .screen h5 { font-family: var(--f-display); font-size: 14px; margin: 0 0 4px; font-weight: 700; }\n  .phone-mock .screen .balance {\n    background: var(--navy-1); color: #fff;\n    padding: 14px; border-radius: 12px;\n    margin-bottom: 12px;\n  }\n  .phone-mock .screen .balance .lbl { font-size: 9.5px; color: var(--sky); letter-spacing: 0.1em; }\n  .phone-mock .screen .balance .v { font-family: var(--f-display); font-size: 22px; font-weight: 800; margin-top: 4px; }\n  .phone-mock .screen .row-item {\n    display: flex; justify-content: space-between; align-items: center;\n    padding: 8px 0;\n    border-bottom: 1px solid var(--hairline-2);\n    font-size: 11px;\n  }\n  .phone-mock .screen .row-item:last-child { border-bottom: 0; }\n  .phone-mock .screen .row-item .t { color: var(--ink-2); }\n  .phone-mock .screen .row-item .a { font-family: var(--f-mono); color: var(--emerald); font-weight: 600; }\n  .phone-mock .screen .row-item.out .a { color: var(--coral); }\n\n  /* Web mock */\n  .web-mock {\n    width: 100%; max-width: 540px;\n    background: var(--paper);\n    border-radius: 8px;\n    overflow: hidden;\n    box-shadow: 0 24px 48px -16px rgba(0,0,0,0.4);\n  }\n  .web-mock .browser-bar {\n    background: #E8EAEF;\n    padding: 8px 12px;\n    display: flex; gap: 6px; align-items: center;\n  }\n  .web-mock .browser-bar .dot { width: 9px; height: 9px; border-radius: 50%; background: #C8CCD4; }\n  .web-mock .browser-bar .url {\n    flex: 1; margin: 0 10px;\n    background: #fff; border-radius: 4px;\n    padding: 3px 10px; font-family: var(--f-mono); font-size: 10px; color: var(--ink-3);\n    text-align: center;\n  }\n  .web-mock .page-body {\n    background: var(--navy-1); color: #fff;\n    padding: 32px 28px 40px;\n    position: relative;\n    overflow: hidden;\n  }\n  .web-mock .page-body::after {\n    content: \"\"; position: absolute; top: 0; right: 0; bottom: 0; width: 40%;\n    background: radial-gradient(circle at 70% 50%, rgba(111,143,206,0.2), transparent 70%);\n  }\n  .web-mock .pb-nav {\n    display: flex; justify-content: space-between; align-items: center;\n    margin-bottom: 36px; position: relative; z-index: 1;\n  }\n  .web-mock .pb-nav img { width: 28px; height: 28px; }\n  .web-mock .pb-nav .nav-links { display: flex; gap: 14px; font-size: 11px; color: rgba(255,255,255,0.65); }\n  .web-mock .pb-nav .nav-cta { background: var(--sky); color: var(--navy-1); padding: 4px 10px; border-radius: 4px; font-size: 10px; font-weight: 600; }\n  .web-mock h2 {\n    font-family: var(--f-display); font-size: 28px; font-weight: 800;\n    margin: 0; letter-spacing: -0.02em; line-height: 1.1;\n    position: relative; z-index: 1;\n  }\n  .web-mock h2 .em { color: var(--sky); }\n  .web-mock .sub { font-size: 12px; color: rgba(255,255,255,0.65); margin-top: 10px; max-width: 280px; position: relative; z-index: 1; }\n  .web-mock .cta-row { display: flex; gap: 8px; margin-top: 20px; position: relative; z-index: 1; }\n  .web-mock .cta-row .btn-mini { background: var(--sky); color: var(--navy-1); padding: 8px 16px; border-radius: 6px; font-size: 11px; font-weight: 700; }\n  .web-mock .cta-row .btn-mini.ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.3); }\n\n  /* Social post mock */\n  .social-mock {\n    width: 300px; aspect-ratio: 1;\n    background: var(--navy-1);\n    border-radius: 8px;\n    padding: 32px;\n    position: relative;\n    overflow: hidden;\n    box-shadow: 0 24px 48px -16px rgba(0,0,0,0.4);\n    display: flex; flex-direction: column; justify-content: space-between;\n    color: #fff;\n  }\n  .social-mock::before {\n    content: \"\"; position: absolute; bottom: -30%; left: -20%;\n    width: 80%; aspect-ratio: 1;\n    background: radial-gradient(circle, rgba(111,143,206,0.30), transparent 60%);\n  }\n  .social-mock .sm-arcs {\n    position: absolute; top: -10%; right: -10%; width: 50%; opacity: 0.4;\n  }\n  .social-mock .sm-top {\n    font-family: var(--f-en-body); font-size: 10.5px; letter-spacing: 0.18em;\n    text-transform: uppercase; color: var(--sky); font-weight: 600;\n    position: relative; z-index: 1;\n  }\n  .social-mock h3 {\n    font-family: var(--f-display); font-weight: 800;\n    font-size: 28px; letter-spacing: -0.02em; line-height: 1.2;\n    margin: 0;\n    position: relative; z-index: 1;\n  }\n  .social-mock .sm-foot {\n    display: flex; align-items: center; gap: 8px;\n    font-size: 11px; color: rgba(255,255,255,0.65);\n    position: relative; z-index: 1;\n  }\n  .social-mock .sm-foot img { width: 24px; height: 24px; }\n\n  /* Email signature */\n  .email-mock {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: 6px;\n    padding: 22px 26px;\n    width: 380px;\n    box-shadow: 0 8px 24px -8px rgba(26,30,92,0.15);\n    color: var(--ink-2);\n    font-family: var(--f-body);\n  }\n  .email-mock .name { font-family: var(--f-display); font-weight: 700; font-size: 16px; color: var(--navy-1); }\n  .email-mock .role { font-size: 11.5px; color: var(--indigo); margin-top: 2px; }\n  .email-mock hr { border: 0; border-top: 1px solid var(--hairline); margin: 12px 0; }\n  .email-mock .em-row { display: flex; gap: 14px; }\n  .email-mock .em-row img { width: 42px; height: 42px; }\n  .email-mock .em-info { font-size: 11px; color: var(--ink-3); line-height: 1.65; }\n  .email-mock .em-info .v { color: var(--ink-2); font-family: var(--f-mono); }\n\n  /* Inline KPI / chips */\n  .kpi-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }\n  .kpi {\n    padding: 18px 22px;\n    background: var(--cloud);\n    border: 1px solid var(--hairline-2);\n    border-radius: var(--r-md);\n    min-width: 160px;\n  }\n  .kpi .n {\n    font-family: var(--f-display);\n    font-size: 32px; font-weight: 800;\n    color: var(--navy-1); line-height: 1;\n    letter-spacing: -0.02em;\n    font-feature-settings: \"tnum\" 1;\n  }\n  .kpi .l { font-size: 12.5px; color: var(--ink-3); margin-top: 6px; line-height: 1.5; }\n\n  /* ============================================================\n     VOLUME 2 — VISUAL IDENTITY components\n     ============================================================ */\n\n  /* Logo system */\n  .logo-stage {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 56px;\n    display: grid;\n    grid-template-columns: 1.2fr 1fr;\n    gap: 48px;\n    align-items: center;\n    margin-top: 24px;\n  }\n  .logo-stage.dark { background: var(--navy-1); border-color: var(--navy-1); }\n  .logo-stage .display {\n    background: var(--paper-2);\n    border-radius: var(--r-lg);\n    aspect-ratio: 1;\n    display: grid; place-items: center;\n    position: relative;\n    border: 1px dashed var(--hairline);\n  }\n  .logo-stage.dark .display { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.12); }\n  .logo-stage .display img { width: 55%; height: auto; }\n  .logo-stage .info h3 {\n    font-family: var(--f-display);\n    font-size: 24px; font-weight: 700;\n    color: var(--navy-1); margin: 0 0 8px;\n    letter-spacing: -0.015em;\n  }\n  .logo-stage.dark .info h3 { color: #fff; }\n  .logo-stage .info p { color: var(--ink-2); font-size: 14.5px; line-height: 1.75; margin: 0 0 12px; }\n  .logo-stage.dark .info p { color: rgba(255,255,255,0.72); }\n  .logo-stage .info .spec {\n    margin-top: 18px; padding-top: 18px;\n    border-top: 1px solid var(--hairline);\n    font-family: var(--f-mono);\n    font-size: 12px;\n    color: var(--ink-3);\n    line-height: 1.85;\n  }\n  .logo-stage.dark .info .spec { color: rgba(255,255,255,0.55); border-color: rgba(255,255,255,0.14); }\n\n  /* Clearspace diagram */\n  .clearspace {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 40px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 40px;\n    margin-top: 16px;\n  }\n  .clearspace .stage {\n    position: relative;\n    background: var(--paper-2);\n    border-radius: var(--r-md);\n    aspect-ratio: 4/3;\n    display: grid; place-items: center;\n    overflow: visible;\n    padding: 20px;\n  }\n  .clearspace .grid-marks {\n    position: absolute; inset: 0;\n    background-image:\n      linear-gradient(to right, rgba(42,45,126,0.08) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(42,45,126,0.08) 1px, transparent 1px);\n    background-size: 24px 24px;\n  }\n  .clearspace .logo-box {\n    position: relative;\n    padding: 48px;\n    display: grid; place-items: center;\n  }\n  .clearspace .logo-box img { width: 80px; height: auto; position: relative; z-index: 1; }\n  .clearspace .logo-box::before {\n    content: \"\";\n    position: absolute; inset: 0;\n    border: 2px dashed var(--indigo);\n    border-radius: 8px;\n  }\n  .clearspace .logo-box::after {\n    content: \"X\";\n    position: absolute;\n    top: 8px; right: 8px;\n    font-family: var(--f-en-display); font-style: italic;\n    font-size: 12px; color: var(--indigo); font-weight: 600;\n  }\n  /* duplicate logo-box img rule removed in cleanup */\n  .clearspace .logo-box-img-legacy { display: none; }\n  .clearspace .x-marks { position: absolute; }\n  .clearspace .x-mark {\n    position: absolute;\n    font-family: var(--f-en-display); font-style: italic;\n    color: var(--indigo); font-size: 12px; font-weight: 600;\n  }\n  .clearspace .x-top { top: 24px; left: 50%; transform: translateX(-50%); }\n  .clearspace .x-bot { bottom: 24px; left: 50%; transform: translateX(-50%); }\n  .clearspace .x-left { left: 24px; top: 50%; transform: translateY(-50%); }\n  .clearspace .x-right { right: 24px; top: 50%; transform: translateY(-50%); }\n  .clearspace .spec-list dt {\n    font-family: var(--f-en-body); font-size: 11px;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n    margin-top: 18px;\n  }\n  .clearspace .spec-list dt:first-child { margin-top: 0; }\n  .clearspace .spec-list dd {\n    margin: 6px 0 0;\n    color: var(--ink-2);\n    font-size: 14px; line-height: 1.7;\n  }\n  .clearspace .spec-list dd code {\n    font-family: var(--f-mono);\n    font-size: 12.5px;\n    background: var(--cloud);\n    padding: 2px 6px; border-radius: 4px;\n    color: var(--indigo);\n  }\n\n  /* Sizing stairs */\n  .sizes {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px;\n    margin-top: 32px;\n  }\n  .size-card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    padding: 22px;\n    text-align: center;\n  }\n  .size-card .preview {\n    background: var(--paper-2);\n    border-radius: 6px;\n    height: 140px;\n    display: grid; place-items: center;\n    margin-bottom: 14px;\n  }\n  .size-card .preview img { max-width: 80%; max-height: 75%; width: auto; height: auto; object-fit: contain; }\n  .size-card .name { font-family: var(--f-display); font-weight: 700; font-size: 15px; color: var(--navy-1); margin-bottom: 2px; }\n  .size-card .dim { font-family: var(--f-mono); font-size: 11px; color: var(--ink-3); }\n\n  /* Dos / Donts on logo */\n  .logo-rules { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 24px; }\n  .rule-card {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    overflow: hidden;\n    position: relative;\n  }\n  .rule-card .ex {\n    height: 160px;\n    display: grid; place-items: center;\n    position: relative;\n    overflow: hidden;\n  }\n  .rule-card .ex img { max-width: 60%; max-height: 70%; }\n  .rule-card .caption {\n    padding: 14px 16px;\n    border-top: 1px solid var(--hairline);\n    font-size: 13px;\n    color: var(--ink-2);\n    display: flex; align-items: center; gap: 8px;\n    line-height: 1.5;\n  }\n  .rule-card .caption .mark {\n    width: 20px; height: 20px;\n    border-radius: 50%;\n    flex-shrink: 0;\n    display: grid; place-items: center;\n    font-size: 13px; font-weight: 700;\n  }\n  .rule-card.no .caption .mark { background: #C4373F; color: #fff; }\n  .rule-card.no .ex::after {\n    content: \"\";\n    position: absolute;\n    inset: 24px;\n    border: 1.5px solid #C4373F;\n    border-radius: 50%;\n    transform: rotate(0deg);\n  }\n  .rule-card.no .ex::before {\n    content: \"\";\n    position: absolute;\n    width: 200%; height: 1.5px;\n    background: #C4373F;\n    transform: rotate(-45deg);\n    z-index: 1;\n  }\n\n  /* Big color swatches */\n  .palette-hero {\n    display: grid;\n    grid-template-columns: 2fr 1fr 1fr 1fr;\n    gap: 8px;\n    margin-top: 24px;\n    min-height: 280px;\n  }\n  .swatch-big {\n    border-radius: var(--r-lg);\n    padding: 28px;\n    display: flex; flex-direction: column; justify-content: flex-end;\n    position: relative; overflow: hidden;\n    color: #fff;\n  }\n  .swatch-big.light { color: var(--navy-1); }\n  .swatch-big .role {\n    font-family: var(--f-en-body); font-size: 10.5px;\n    letter-spacing: 0.18em; text-transform: uppercase;\n    opacity: 0.7; font-weight: 600;\n  }\n  .swatch-big .name {\n    font-family: var(--f-display); font-size: 24px; font-weight: 700;\n    letter-spacing: -0.015em; margin-top: 6px;\n  }\n  .swatch-big .hex {\n    font-family: var(--f-mono); font-size: 12.5px;\n    margin-top: 12px; opacity: 0.8;\n  }\n  .swatch-big.feature .name { font-size: 36px; }\n\n  /* Neutral row */\n  .neutrals { display: grid; grid-template-columns: repeat(8, 1fr); gap: 4px; margin-top: 24px; }\n  .neutral {\n    aspect-ratio: 1.1;\n    border-radius: var(--r-sm);\n    padding: 12px;\n    display: flex; flex-direction: column; justify-content: space-between;\n    font-size: 11px;\n  }\n  .neutral .nm {\n    font-family: var(--f-en-body); font-size: 10px;\n    letter-spacing: 0.1em; text-transform: uppercase;\n    font-weight: 600; opacity: 0.7;\n  }\n  .neutral .hx { font-family: var(--f-mono); font-size: 10.5px; opacity: 0.85; }\n\n  /* Color usage bar */\n  .usage-bar {\n    margin-top: 28px;\n    border-radius: var(--r-md);\n    overflow: hidden;\n    display: flex;\n    height: 60px;\n    border: 1px solid var(--hairline);\n  }\n  .usage-bar .seg {\n    color: #fff;\n    display: flex; align-items: center; justify-content: center;\n    font-family: var(--f-en-body); font-size: 12px; font-weight: 600;\n    letter-spacing: 0.05em;\n  }\n  .usage-bar .seg.light { color: var(--navy-1); }\n\n  /* Type specimen */\n  .specimen {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 48px;\n    margin-top: 24px;\n    position: relative;\n  }\n  .specimen.dark { background: var(--navy-1); border-color: var(--navy-1); color: #fff; }\n  .specimen .meta {\n    display: flex; justify-content: space-between; align-items: baseline;\n    padding-bottom: 24px;\n    border-bottom: 1px solid var(--hairline);\n    margin-bottom: 32px;\n  }\n  .specimen.dark .meta { border-color: rgba(255,255,255,0.12); }\n  .specimen .meta .face-name {\n    font-family: var(--f-display);\n    font-size: 36px; font-weight: 700;\n    color: var(--navy-1); letter-spacing: -0.02em;\n  }\n  .specimen.dark .meta .face-name { color: #fff; }\n  .specimen .meta .face-tag {\n    font-family: var(--f-en-body);\n    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n  }\n  .specimen.dark .meta .face-tag { color: var(--sky); }\n  .specimen .big-char {\n    font-size: clamp(120px, 14vw, 220px);\n    font-weight: 700; line-height: 0.85;\n    letter-spacing: -0.04em;\n    color: var(--navy-1);\n    text-align: center;\n    padding: 12px 0;\n  }\n  .specimen.dark .big-char { color: #fff; }\n  .specimen .weights {\n    display: grid; grid-template-columns: 1fr; gap: 0;\n    margin-top: 32px;\n  }\n  .specimen .wt-row {\n    padding: 18px 0;\n    border-top: 1px solid var(--hairline-2);\n    display: grid;\n    grid-template-columns: 110px 1fr 110px;\n    gap: 24px;\n    align-items: baseline;\n  }\n  .specimen.dark .wt-row { border-color: rgba(255,255,255,0.08); }\n  .specimen .wt-row .label-w {\n    font-family: var(--f-en-body); font-size: 11px;\n    color: var(--ink-3); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;\n  }\n  .specimen.dark .wt-row .label-w { color: rgba(255,255,255,0.45); }\n  .specimen .wt-row .sample {\n    font-size: 26px;\n    color: var(--navy-1);\n    line-height: 1.3;\n  }\n  .specimen.dark .wt-row .sample { color: #fff; }\n  .specimen .wt-row .num {\n    font-family: var(--f-mono); font-size: 12px;\n    color: var(--ink-3);\n    text-align: left;\n  }\n  .specimen.dark .wt-row .num { color: rgba(255,255,255,0.4); }\n\n  /* Type scale ladder */\n  .scale-ladder {\n    margin-top: 24px;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 40px;\n  }\n  .scale-step {\n    padding: 18px 0;\n    border-top: 1px solid var(--hairline-2);\n    display: grid;\n    grid-template-columns: 80px 1fr 220px;\n    gap: 24px;\n    align-items: baseline;\n  }\n  .scale-step:first-of-type { border-top: 0; }\n  .scale-step .tag {\n    font-family: var(--f-en-body); font-size: 11px;\n    letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600;\n    color: var(--indigo);\n  }\n  .scale-step .demo {\n    color: var(--navy-1);\n    line-height: 1.15;\n    letter-spacing: -0.02em;\n    font-weight: 700;\n  }\n  .scale-step .spec {\n    font-family: var(--f-mono); font-size: 12px;\n    color: var(--ink-3);\n    line-height: 1.7;\n  }\n\n  /* Motif system */\n  .motif {\n    margin-top: 24px;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 48px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 48px;\n    align-items: center;\n  }\n  .motif.dark { background: var(--navy-1); border-color: var(--navy-1); color: #fff; }\n  .motif .canvas {\n    aspect-ratio: 1;\n    background: var(--paper-2);\n    border-radius: var(--r-lg);\n    position: relative;\n    overflow: hidden;\n  }\n  .motif.dark .canvas { background: rgba(255,255,255,0.04); }\n  .motif .info h3 {\n    font-family: var(--f-display);\n    font-size: 28px; font-weight: 700;\n    color: var(--navy-1); margin: 0 0 12px;\n    letter-spacing: -0.02em;\n  }\n  .motif.dark .info h3 { color: #fff; }\n  .motif .info p { color: var(--ink-2); line-height: 1.85; margin: 0 0 12px; }\n  .motif.dark .info p { color: rgba(255,255,255,0.75); }\n\n  /* Motif examples */\n  .motif-uses { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 24px; }\n  .motif-use {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-md);\n    overflow: hidden;\n    aspect-ratio: 4/3;\n    position: relative;\n  }\n  .motif-use .label {\n    position: absolute; bottom: 14px; right: 14px;\n    font-family: var(--f-en-body); font-size: 10.5px;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--ink-3); font-weight: 600;\n    background: rgba(255,255,255,0.9);\n    padding: 4px 8px; border-radius: 4px;\n    backdrop-filter: blur(4px);\n  }\n\n  /* Icon system */\n  .icons-grid {\n    display: grid;\n    grid-template-columns: repeat(8, 1fr);\n    gap: 1px;\n    background: var(--hairline);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-lg);\n    overflow: hidden;\n    margin-top: 24px;\n  }\n  .icon-cell {\n    background: var(--paper);\n    aspect-ratio: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    padding: 14px;\n  }\n  .icon-cell svg { width: 32px; height: 32px; color: var(--navy-1); }\n  .icon-cell .nm {\n    font-size: 10.5px;\n    color: var(--ink-3);\n    text-align: center;\n    line-height: 1.3;\n  }\n\n  /* UI components */\n  .ui-row {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 36px;\n    margin-top: 24px;\n  }\n  .ui-row + .ui-row { margin-top: 16px; }\n  .ui-row .row-head {\n    display: flex; justify-content: space-between; align-items: baseline;\n    padding-bottom: 18px; margin-bottom: 24px;\n    border-bottom: 1px solid var(--hairline-2);\n  }\n  .ui-row .row-head h3 {\n    font-family: var(--f-display); font-size: 20px; font-weight: 700;\n    color: var(--navy-1); margin: 0; letter-spacing: -0.015em;\n  }\n  .ui-row .row-head .meta {\n    font-family: var(--f-en-body); font-size: 11px;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n  }\n  .btn-group { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }\n  .btn {\n    font-family: var(--f-body); font-weight: 500;\n    border-radius: 8px;\n    padding: 10px 20px;\n    border: 1px solid transparent;\n    cursor: pointer;\n    font-size: 14px;\n    line-height: 1.4;\n    transition: all 160ms ease;\n  }\n  .btn.primary { background: var(--navy-1); color: #fff; }\n  .btn.primary:hover { background: var(--indigo); }\n  .btn.secondary { background: var(--paper); color: var(--navy-1); border-color: var(--ink-2); }\n  .btn.tertiary { background: transparent; color: var(--indigo); }\n  .btn.tertiary:hover { background: var(--cloud); }\n  .btn.large { padding: 14px 28px; font-size: 15px; }\n  .btn.small { padding: 6px 14px; font-size: 13px; }\n  .btn.disabled { background: var(--cloud); color: var(--ink-4); cursor: not-allowed; }\n\n  /* Badges */\n  .badges-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }\n  .badge {\n    display: inline-block;\n    padding: 0 10px;\n    height: 22px;\n    line-height: 22px;\n    border-radius: 4px;\n    font-size: 12px;\n    font-weight: 600;\n    font-family: var(--f-body);\n    letter-spacing: 0.04em;\n    white-space: nowrap;\n    box-sizing: border-box;\n    vertical-align: middle;\n  }\n  .badge .dot {\n    display: inline-block;\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n    background: currentColor;\n    vertical-align: middle;\n    margin-left: 6px;\n    margin-bottom: 2px;\n    position: relative;\n    top: -1px;\n  }\n  .badge.success { background: rgba(31,138,91,0.12); color: var(--emerald); }\n  .badge.warning { background: rgba(224,116,74,0.12); color: var(--coral); }\n  .badge.info { background: rgba(42,45,126,0.10); color: var(--indigo); }\n  .badge.neutral { background: var(--cloud); color: var(--ink-2); }\n  .badge.dark { background: var(--navy-1); color: #fff; }\n\n  /* Form sample */\n  .form-sample { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; max-width: 640px; }\n  .form-row { display: flex; flex-direction: column; gap: 6px; }\n  .form-row label {\n    font-size: 12.5px;\n    color: var(--ink-2); font-weight: 500;\n  }\n  .form-row input, .form-row select {\n    font-family: var(--f-body);\n    padding: 10px 14px;\n    border: 1px solid var(--hairline);\n    border-radius: 8px;\n    font-size: 14px;\n    background: var(--paper);\n    color: var(--ink);\n  }\n  .form-row input:focus, .form-row select:focus {\n    outline: none; border-color: var(--indigo);\n    box-shadow: 0 0 0 3px rgba(42,45,126,0.10);\n  }\n\n  /* App / mobile mockup */\n  .mockup-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 24px;\n    margin-top: 24px;\n  }\n  .phone {\n    background: var(--navy-1);\n    border-radius: 28px;\n    padding: 12px;\n    aspect-ratio: 9/19;\n    position: relative;\n    box-shadow: 0 30px 60px -20px rgba(10,14,46,0.4);\n  }\n  .phone .screen {\n    background: var(--paper);\n    border-radius: 20px;\n    width: 100%; height: 100%;\n    overflow: hidden;\n    position: relative;\n    display: flex; flex-direction: column;\n  }\n  .phone .status {\n    display: flex; justify-content: space-between;\n    padding: 12px 18px 4px;\n    font-family: var(--f-mono); font-size: 10px;\n    color: var(--ink);\n  }\n  .phone .topbar {\n    padding: 14px 18px 12px;\n    display: flex; justify-content: space-between; align-items: center;\n  }\n  .phone .logo-tiny { display: flex; align-items: center; gap: 6px; }\n  .phone .logo-tiny img { width: 24px; height: 24px; }\n  .phone .logo-tiny .nm { font-family: var(--f-display); font-weight: 700; font-size: 13px; color: var(--navy-1); }\n\n  /* Stationery */\n  .stationery {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 24px;\n    margin-top: 24px;\n  }\n  .card-bc {\n    aspect-ratio: 1.65;\n    border-radius: 8px;\n    box-shadow: 0 20px 40px -12px rgba(10,14,46,0.25);\n    position: relative;\n    overflow: hidden;\n  }\n  .card-bc.front {\n    background: var(--navy-1);\n    color: #fff;\n    padding: 0;\n    display: grid;\n    grid-template-rows: 1fr auto;\n  }\n  .card-bc.front::before {\n    content: \"\";\n    position: absolute;\n    top: -30%; left: -20%;\n    width: 80%; aspect-ratio: 1;\n    background: radial-gradient(circle, rgba(111,143,206,0.25), transparent 70%);\n    pointer-events: none;\n  }\n  .card-bc.front .front-top {\n    padding: 22px 28px;\n    display: flex; align-items: center; gap: 10px;\n    z-index: 1;\n  }\n  .card-bc.front .front-top img { width: 26px; height: 26px; }\n  .card-bc.front .front-top .nm {\n    font-family: var(--f-display); font-weight: 700;\n    font-size: 16px; letter-spacing: -0.01em;\n  }\n  .card-bc.front .front-bottom {\n    padding: 22px 28px;\n    border-top: 1px solid rgba(255,255,255,0.10);\n    background: rgba(0,0,0,0.15);\n    z-index: 1;\n    position: relative;\n  }\n  .card-bc.front .name {\n    font-family: var(--f-display); font-weight: 700; font-size: 19px;\n    letter-spacing: -0.015em; color: #fff;\n  }\n  .card-bc.front .role {\n    font-size: 12px; color: var(--sky); margin-top: 3px;\n    font-family: var(--f-en-body); font-weight: 500;\n    letter-spacing: 0.02em;\n  }\n  .card-bc.front .arcs-bg {\n    position: absolute;\n    bottom: -10%; right: -15%;\n    width: 70%; opacity: 0.18;\n    pointer-events: none;\n  }\n  .card-bc.back {\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    padding: 0;\n    display: grid;\n    grid-template-columns: 1fr 90px;\n  }\n  .card-bc.back .back-main {\n    padding: 24px 28px;\n    display: flex; flex-direction: column; justify-content: space-between;\n    border-left: 1px solid var(--hairline-2);\n  }\n  .card-bc.back .back-side {\n    background: var(--cloud);\n    display: grid; place-items: center;\n    position: relative; overflow: hidden;\n  }\n  .card-bc.back .back-side::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background:\n      radial-gradient(circle at 100% 0%, rgba(42,45,126,0.10), transparent 70%);\n  }\n  .card-bc.back .back-side img {\n    width: 60%; height: auto; position: relative; z-index: 1;\n  }\n  .card-bc.back .bc-logo .nm {\n    font-family: var(--f-display); font-weight: 700; font-size: 16px;\n    color: var(--navy-1); letter-spacing: -0.01em;\n  }\n  .card-bc.back .bc-tagline {\n    font-family: var(--f-en-body); font-size: 9.5px;\n    letter-spacing: 0.16em; text-transform: uppercase;\n    color: var(--indigo); font-weight: 600;\n    margin-top: 6px;\n  }\n  .card-bc.back .contact {\n    font-family: var(--f-mono); font-size: 10.5px;\n    line-height: 2; color: var(--ink-2);\n  }\n  .card-bc.back .contact .row {\n    display: flex; align-items: center; gap: 8px;\n  }\n  .card-bc.back .contact .row svg {\n    width: 11px; height: 11px;\n    color: var(--indigo); flex-shrink: 0;\n  }\n  .card-bc.back::after { display: none; }\n\n  /* Social post mockup */\n  .social-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px; }\n  .post {\n    aspect-ratio: 1;\n    border-radius: var(--r-lg);\n    padding: 32px;\n    display: flex; flex-direction: column; justify-content: space-between;\n    position: relative;\n    overflow: hidden;\n    border: 1px solid var(--hairline);\n  }\n  .post .meta-strip {\n    display: flex; justify-content: space-between; align-items: center;\n    font-family: var(--f-en-body); font-size: 10px;\n    letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600;\n  }\n  .post .meta-strip .brand {\n    display: flex; align-items: center; gap: 6px;\n  }\n  .post .meta-strip .brand img { width: 18px; height: 18px; }\n  .post .post-text {\n    font-family: var(--f-display);\n    font-weight: 700;\n    font-size: 24px;\n    line-height: 1.35;\n    letter-spacing: -0.02em;\n  }\n  .post.dark { background: var(--navy-1); color: #fff; border-color: var(--navy-1); }\n  .post.dark .meta-strip { color: var(--sky); }\n  .post.dark .post-text { color: #fff; }\n  .post.indigo { background: var(--indigo); color: #fff; border-color: var(--indigo); }\n  .post.indigo .meta-strip { color: rgba(255,255,255,0.7); }\n  .post.cream { background: var(--paper); color: var(--navy-1); }\n  .post.cream .meta-strip { color: var(--indigo); }\n\n  /* Layout grid demo */\n  .grid-demo {\n    margin-top: 24px;\n    background: var(--paper);\n    border: 1px solid var(--hairline);\n    border-radius: var(--r-xl);\n    padding: 40px;\n    position: relative;\n  }\n  .grid-demo .demo-stage {\n    height: 240px;\n    background: var(--paper-2);\n    border-radius: var(--r-md);\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    gap: 8px;\n    padding: 12px;\n  }\n  .grid-demo .col {\n    background: rgba(42,45,126,0.10);\n    border-radius: 4px;\n  }\n\n  /* Section divider */\n  .vol-divider {\n    min-height: 100vh;\n    background: var(--navy-1);\n    color: #fff;\n    border: 0;\n    display: grid; place-items: center;\n    padding: 0;\n    text-align: center;\n    position: relative; overflow: hidden;\n  }\n  .vol-divider::before {\n    content: \"\";\n    position: absolute;\n    top: -20%; right: -10%;\n    width: 70%; aspect-ratio: 1;\n    background: radial-gradient(circle, rgba(111,143,206,0.20), transparent 60%);\n  }\n  .vol-divider .vol-content { position: relative; z-index: 1; }\n  .vol-divider .vol-num {\n    font-family: var(--f-en-display); font-style: italic;\n    font-size: 24px; color: var(--sky);\n    letter-spacing: 0.04em; opacity: 0.8;\n  }\n  .vol-divider h2 {\n    font-family: var(--f-display);\n    font-size: clamp(72px, 10vw, 160px);\n    font-weight: 800;\n    letter-spacing: -0.04em;\n    line-height: 0.9;\n    margin: 16px 0 24px;\n    color: #fff;\n  }\n  .vol-divider .vol-sub {\n    font-family: var(--f-en-display); font-style: italic;\n    font-size: clamp(24px, 2.5vw, 32px);\n    color: rgba(255,255,255,0.5);\n  }\n  .vol-divider .vol-line {\n    width: 120px; height: 2px; background: var(--sky);\n    margin: 32px auto;\n  }\n  .vol-divider .vol-desc {\n    max-width: 580px; margin: 0 auto;\n    color: rgba(255,255,255,0.7);\n    font-size: 17px; line-height: 1.8;\n  }\n\n  /* ============================================================\n     GLOBAL MOTION SYSTEM — applied to all pages\n     ============================================================ */\n  \n  @media (prefers-reduced-motion: no-preference) {\n    /* Reveal-on-scroll base */\n    .reveal {\n      opacity: 0;\n      transform: translateY(28px);\n      transition: opacity 700ms cubic-bezier(0.22,1,0.36,1),\n                  transform 700ms cubic-bezier(0.22,1,0.36,1);\n      will-change: opacity, transform;\n    }\n    .reveal.in {\n      opacity: 1;\n      transform: none;\n    }\n\n    /* Staggered grid children */\n    .stagger > * { opacity: 0; transform: translateY(20px); transition: opacity 600ms cubic-bezier(0.22,1,0.36,1), transform 600ms cubic-bezier(0.22,1,0.36,1); }\n    .stagger.in > * { opacity: 1; transform: none; }\n    .stagger.in > *:nth-child(1) { transition-delay: 0ms; }\n    .stagger.in > *:nth-child(2) { transition-delay: 80ms; }\n    .stagger.in > *:nth-child(3) { transition-delay: 160ms; }\n    .stagger.in > *:nth-child(4) { transition-delay: 240ms; }\n    .stagger.in > *:nth-child(5) { transition-delay: 320ms; }\n    .stagger.in > *:nth-child(6) { transition-delay: 400ms; }\n    .stagger.in > *:nth-child(7) { transition-delay: 480ms; }\n    .stagger.in > *:nth-child(8) { transition-delay: 560ms; }\n\n    /* Card hover lift */\n    .card, .product-card, .aud-card, .pillar, .word-card, .swatch-big,\n    .neutral, .post, .size-card, .rule-card, .icon-cell, .motif-use {\n      transition: transform 280ms cubic-bezier(0.22,1,0.36,1),\n                  box-shadow 280ms cubic-bezier(0.22,1,0.36,1),\n                  border-color 280ms ease;\n    }\n    .card:hover, .pillar:hover, .word-card:hover, .size-card:hover {\n      transform: translateY(-3px);\n      box-shadow: 0 18px 36px -20px rgba(10,14,46,0.18);\n      border-color: var(--ink-4);\n    }\n    .product-card:hover, .aud-card:hover {\n      transform: translateY(-3px);\n      box-shadow: 0 24px 48px -24px rgba(10,14,46,0.22);\n    }\n    .post:hover { transform: translateY(-2px); }\n    .motif-use:hover, .icon-cell:hover { transform: scale(1.03); }\n\n    /* Statement underline draw-in */\n    .statement {\n      position: relative;\n      overflow: visible;\n    }\n    .statement.in::before {\n      animation: drawV 900ms cubic-bezier(0.22,1,0.36,1) forwards;\n      transform-origin: top;\n    }\n    @keyframes drawV {\n      from { transform: scaleY(0); }\n      to   { transform: scaleY(1); }\n    }\n\n    /* H1 title slide-up with letter spacing easing */\n    h1.title-fa.reveal { transform: translateY(40px); }\n    h1.title-fa.reveal.in { transform: none; }\n\n    /* Cover-specific animations */\n    .cover-title {\n      opacity: 0;\n      transform: translateY(60px);\n      animation: coverIn 1200ms 200ms cubic-bezier(0.22,1,0.36,1) forwards;\n    }\n    .cover-title .pi {\n      display: inline-block;\n      opacity: 0;\n      animation: coverIn 1200ms 600ms cubic-bezier(0.22,1,0.36,1) forwards;\n    }\n    .cover-sub {\n      opacity: 0;\n      animation: fadeIn 800ms 900ms ease forwards;\n    }\n    .cover-eyebrow {\n      opacity: 0;\n      animation: fadeIn 600ms 100ms ease forwards;\n    }\n    .cover-meta {\n      opacity: 0;\n      animation: fadeUp 800ms 1100ms cubic-bezier(0.22,1,0.36,1) forwards;\n    }\n    .cover-foot, .cover-top {\n      opacity: 0;\n      animation: fadeIn 600ms 1300ms ease forwards;\n    }\n\n    @keyframes coverIn { to { opacity: 1; transform: none; } }\n    @keyframes fadeIn  { to { opacity: 1; } }\n    @keyframes fadeUp  { to { opacity: 1; transform: none; } }\n\n    /* Cover arcs — gradually drawn in, slow and visible */\n    .cover .arcs path {\n      stroke-dasharray: 1400;\n      stroke-dashoffset: 1400;\n      animation: drawArc 3400ms cubic-bezier(0.16, 1, 0.3, 1) forwards;\n    }\n    .cover .arcs path:nth-child(1) { animation-delay: 200ms; }\n    .cover .arcs path:nth-child(2) { animation-delay: 350ms; }\n    .cover .arcs path:nth-child(3) { animation-delay: 500ms; }\n    .cover .arcs path:nth-child(4) { animation-delay: 650ms; }\n    .cover .arcs path:nth-child(5) { animation-delay: 800ms; }\n    .cover .arcs path:nth-child(6) { animation-delay: 950ms; }\n    .cover .arcs path:nth-child(7) { animation-delay: 1100ms; }\n    .cover .arcs .accent-dot {\n      opacity: 0;\n      animation: dotIn 700ms 3200ms cubic-bezier(0.22,1,0.36,1) forwards;\n      transform-origin: center;\n    }\n    .cover .arcs-2 path {\n      stroke-dasharray: 1000;\n      stroke-dashoffset: 1000;\n      animation: drawArc 3000ms cubic-bezier(0.16, 1, 0.3, 1) forwards;\n    }\n    .cover .arcs-2 path:nth-child(1) { animation-delay: 1600ms; }\n    .cover .arcs-2 path:nth-child(2) { animation-delay: 1800ms; }\n    .cover .arcs-2 path:nth-child(3) { animation-delay: 2000ms; }\n\n    @keyframes drawArc { to { stroke-dashoffset: 0; } }\n    @keyframes dotIn   { from { opacity: 0; transform: scale(0.3); } to { opacity: 1; transform: scale(1); } }\n\n    /* Competitive map — pulse on us marker */\n    .compass-axis .player.us {\n      animation: usFloat 4s ease-in-out infinite;\n    }\n    @keyframes usFloat {\n      0%, 100% { transform: translate(50%, -50%); }\n      50% { transform: translate(50%, -52%); }\n    }\n    .compass-axis .player.us::before {\n      animation: pulseRing 3s ease-out infinite;\n    }\n    @keyframes pulseRing {\n      0% { transform: rotate(0deg) scale(1); opacity: 0.7; }\n      80%, 100% { transform: rotate(360deg) scale(1.4); opacity: 0; }\n    }\n\n    /* KPI count-up: handled in JS */\n    .kpi .n.counting { color: var(--indigo); }\n\n    /* Progress bar — smoother */\n    .progress-bar .fill { transition: width 200ms cubic-bezier(0.16,1,0.3,1); }\n\n    /* Side nav link slide on hover */\n    nav.toc a {\n      transition: background 200ms cubic-bezier(0.22,1,0.36,1),\n                  color 200ms,\n                  padding-right 240ms cubic-bezier(0.22,1,0.36,1);\n    }\n    nav.toc a:hover { padding-right: 16px; }\n\n    /* Button microinteractions */\n    .btn { transition: background 200ms, transform 180ms cubic-bezier(0.22,1,0.36,1), box-shadow 200ms; }\n    .btn.primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px -10px rgba(10,14,46,0.5); }\n    .btn:active { transform: translateY(0); }\n\n    /* Badge pulse for success */\n    .badge.success .dot {\n      animation: dotPulse 2s ease-in-out infinite;\n    }\n    @keyframes dotPulse {\n      0%, 100% { box-shadow: 0 0 0 0 currentColor; opacity: 1; }\n      50% { box-shadow: 0 0 0 4px transparent; opacity: 0.6; }\n    }\n\n    /* Product card timing tag — subtle blink */\n    .product-card .timing { transition: transform 220ms; }\n    .product-card:hover .timing { transform: scale(1.06); }\n\n    /* Brand-mark logo subtle floating in nav */\n    .brand-mark img { transition: transform 600ms cubic-bezier(0.22,1,0.36,1); }\n    aside.nav:hover .brand-mark img { transform: rotate(-3deg) scale(1.04); }\n\n    /* Tagline word cards on scroll */\n    .tagline-grid .word-card.in:hover {\n      transform: translateY(-6px);\n      box-shadow: 0 30px 60px -28px rgba(10,14,46,0.4);\n    }\n\n    /* Section page subtle fade-in on first paint */\n    section.page {\n      opacity: 0;\n      animation: pageIn 600ms cubic-bezier(0.22,1,0.36,1) forwards;\n    }\n    section.page.cover { animation-delay: 0ms; }\n    @keyframes pageIn { to { opacity: 1; } }\n  }\n\n  /* Reduced motion override */\n  @media (prefers-reduced-motion: reduce) {\n    .reveal, .stagger > *, h1.title-fa, .cover-title, .cover-title .pi,\n    .cover-sub, .cover-eyebrow, .cover-meta, .cover-foot, .cover-top,\n    section.page {\n      opacity: 1 !important;\n      transform: none !important;\n      animation: none !important;\n    }\n    .cover .arcs path, .cover .arcs-2 path {\n      stroke-dashoffset: 0 !important;\n      animation: none !important;\n    }\n  }\n\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n\n\n\n<div class=\"progress-bar\"><div class=\"fill\" id=\"progressFill\"><\u002Fdiv><\u002Fdiv>\n\n<div class=\"shell\">\n\n<!-- =================== SIDEBAR =================== -->\n<aside class=\"nav\" data-screen-label=\"Side Navigation\">\n  <div class=\"brand-mark\">\n    <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" alt=\"Boorspay\">\n    <div class=\"text\">\n      <div class=\"t1\">بورس پی<\u002Fdiv>\n      <div class=\"t2\">Boorspay · Brand Book<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <div class=\"nav-section\">۱ · راهبرد<\u002Fdiv>\n  <nav class=\"toc\" id=\"toc\">\n    <a href=\"#cover\" data-target=\"cover\"><span class=\"num\">۰۰<\u002Fspan><span>جلد<\u002Fspan><\u002Fa>\n    <a href=\"#essence\" data-target=\"essence\"><span class=\"num\">۰۱<\u002Fspan><span>جوهره برند<\u002Fspan><\u002Fa>\n    <a href=\"#mission\" data-target=\"mission\">