get=\"logo\"><span class=\"num\">۱۷<\u002Fspan><span>سیستم لوگو<\u002Fspan><\u002Fa>\n    <a href=\"#clearspace\" data-target=\"clearspace\"><span class=\"num\">۱۸<\u002Fspan><span>فضای امن و ابعاد<\u002Fspan><\u002Fa>\n    <a href=\"#logo-rules\" data-target=\"logo-rules\"><span class=\"num\">۱۹<\u002Fspan><span>لوگو: بایدها و نبایدها<\u002Fspan><\u002Fa>\n    <a href=\"#palette\" data-target=\"palette\"><span class=\"num\">۲۰<\u002Fspan><span>پالت رنگ<\u002Fspan><\u002Fa>\n    <a href=\"#color-use\" data-target=\"color-use\"><span class=\"num\">۲۱<\u002Fspan><span>کاربرد رنگ<\u002Fspan><\u002Fa>\n    <a href=\"#type-fa\" data-target=\"type-fa\"><span class=\"num\">۲۲<\u002Fspan><span>تایپ‌فیس فارسی<\u002Fspan><\u002Fa>\n    <a href=\"#type-en\" data-target=\"type-en\"><span class=\"num\">۲۳<\u002Fspan><span>تایپ‌فیس لاتین<\u002Fspan><\u002Fa>\n    <a href=\"#type-scale\" data-target=\"type-scale\"><span class=\"num\">۲۴<\u002Fspan><span>مقیاس تایپ<\u002Fspan><\u002Fa>\n    <a href=\"#motif\" data-target=\"motif\"><span class=\"num\">۲۵<\u002Fspan><span>نقش‌مایه‌ی Arc<\u002Fspan><\u002Fa>\n    <a href=\"#graphics\" data-target=\"graphics\"><span class=\"num\">۲۶<\u002Fspan><span>نقطه و خط<\u002Fspan><\u002Fa>\n    <a href=\"#motion\" data-target=\"motion\"><span class=\"num\">۲۷<\u002Fspan><span>موشن و حرکت<\u002Fspan><\u002Fa>\n    <a href=\"#icons\" data-target=\"icons\"><span class=\"num\">۲۸<\u002Fspan><span>آیکونوگرافی<\u002Fspan><\u002Fa>\n    <a href=\"#components\" data-target=\"components\"><span class=\"num\">۲۹<\u002Fspan><span>کامپوننت‌های UI<\u002Fspan><\u002Fa>\n    <a href=\"#layout\" data-target=\"layout\"><span class=\"num\">۳۰<\u002Fspan><span>گرید و لی‌آوت<\u002Fspan><\u002Fa>\n    <a href=\"#mockup\" data-target=\"mockup\"><span class=\"num\">۳۱<\u002Fspan><span>کاربرد در محصول<\u002Fspan><\u002Fa>\n    <a href=\"#stationery\" data-target=\"stationery\"><span class=\"num\">۳۲<\u002Fspan><span>اقلام چاپی<\u002Fspan><\u002Fa>\n    <a href=\"#social\" data-target=\"social\"><span class=\"num\">۳۳<\u002Fspan><span>شبکه‌های اجتماعی<\u002Fspan><\u002Fa>\n\n  <div class=\"nav-section\">۳ · هویت بصری<\u002Fdiv>\n  <nav class=\"toc\">\n    <a href=\"#design-intro\" data-target=\"design-intro\"><span class=\"num\">۱۶<\u002Fspan><span>درآمد بصری<\u002Fspan><\u002Fa>\n    <a href=\"#logo\" data-target=\"logo\"><span class=\"num\">۱۷<\u002Fspan><span>سیستم لوگو<\u002Fspan><\u002Fa>\n    <a href=\"#color\" data-target=\"color\"><span class=\"num\">۱۸<\u002Fspan><span>پالت رنگی<\u002Fspan><\u002Fa>\n    <a href=\"#typography\" data-target=\"typography\"><span class=\"num\">۱۹<\u002Fspan><span>تایپوگرافی<\u002Fspan><\u002Fa>\n    <a href=\"#icons\" data-target=\"icons\"><span class=\"num\">۲۰<\u002Fspan><span>آیکونوگرافی<\u002Fspan><\u002Fa>\n    <a href=\"#patterns\" data-target=\"patterns\"><span class=\"num\">۲۱<\u002Fspan><span>الگوها<\u002Fspan><\u002Fa>\n    <a href=\"#components\" data-target=\"components\"><span class=\"num\">۲۲<\u002Fspan><span>اجزای UI<\u002Fspan><\u002Fa>\n    <a href=\"#grid\" data-target=\"grid\"><span class=\"num\">۲۳<\u002Fspan><span>فاصله و گرید<\u002Fspan><\u002Fa>\n    <a href=\"#motion\" data-target=\"motion\"><span class=\"num\">۲۴<\u002Fspan><span>حرکت<\u002Fspan><\u002Fa>\n    <a href=\"#applications\" data-target=\"applications\"><span class=\"num\">۲۵<\u002Fspan><span>کاربردها<\u002Fspan><\u002Fa>\n  <\u002Fnav>\n\n  <div class=\"nav-foot\">\n    <div class=\"row\"><span>نسخه<\u002Fspan><span class=\"v\">۲.۰<\u002Fspan><\u002Fdiv>\n    <div class=\"row\"><span>زیربرند<\u002Fspan><span class=\"v\">رایان هم‌افزا<\u002Fspan><\u002Fdiv>\n    <div class=\"row\"><span>تاریخ<\u002Fspan><span class=\"v\">اردیبهشت ۱۴۰۵<\u002Fspan><\u002Fdiv>\n    <div class=\"row\"><span>وضعیت<\u002Fspan><span class=\"v\">داخلی · محرمانه<\u002Fspan><\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fnav><\u002Faside>\n\n<!-- =================== CONTENT =================== -->\n<main class=\"content\">\n\n<!-- COVER -->\n<section class=\"page cover\" id=\"cover\" data-screen-label=\"00 Cover\">\n  <div class=\"arcs\">\n    <svg viewBox=\"0 0 800 800\" preserveAspectRatio=\"xMinYMin meet\">\n      <!-- Arcs originating from top-left corner (0,0) -->\n      <path d=\"M 750 0 A 750 750 0 0 1 0 750\" stroke-width=\"1\" opacity=\"0.18\"><\u002Fpath>\n      <path d=\"M 660 0 A 660 660 0 0 1 0 660\" stroke-width=\"1\" opacity=\"0.28\"><\u002Fpath>\n      <path d=\"M 570 0 A 570 570 0 0 1 0 570\" stroke-width=\"1.1\" opacity=\"0.42\"><\u002Fpath>\n      <path d=\"M 480 0 A 480 480 0 0 1 0 480\" stroke-width=\"1.2\" opacity=\"0.58\"><\u002Fpath>\n      <path d=\"M 390 0 A 390 390 0 0 1 0 390\" stroke-width=\"1.3\" opacity=\"0.72\"><\u002Fpath>\n      <path d=\"M 300 0 A 300 300 0 0 1 0 300\" stroke-width=\"1.4\" opacity=\"0.85\"><\u002Fpath>\n      <path d=\"M 210 0 A 210 210 0 0 1 0 210\" stroke-width=\"1.5\" opacity=\"1\"><\u002Fpath>\n      <!-- Accent dots along the inner arc -->\n      <circle class=\"accent-dot\" cx=\"148\" cy=\"148\" r=\"4\"><\u002Fcircle>\n    <\u002Fsvg>\n  <\u002Fdiv>\n  <div class=\"arcs-2\">\n    <svg viewBox=\"0 0 400 400\" preserveAspectRatio=\"xMaxYMax meet\">\n      <!-- Mirror set, smaller, from bottom-right -->\n      <path d=\"M 0 400 A 400 400 0 0 1 400 0\" stroke=\"#6F8FCE\" fill=\"none\" stroke-width=\"1\" opacity=\"0.4\"><\u002Fpath>\n      <path d=\"M 0 320 A 320 320 0 0 1 320 0\" stroke=\"#6F8FCE\" fill=\"none\" stroke-width=\"1\" opacity=\"0.55\"><\u002Fpath>\n      <path d=\"M 0 240 A 240 240 0 0 1 240 0\" stroke=\"#6F8FCE\" fill=\"none\" stroke-width=\"1\" opacity=\"0.7\"><\u002Fpath>\n    <\u002Fsvg>\n  <\u002Fdiv>\n\n  <div class=\"cover-top\">\n    <div>راهنمای هویت برند · Brand Book<\u002Fdiv>\n    <div class=\"badge\">نسخه ۲.۰ — بازنگری شده<\u002Fdiv>\n  <\u002Fdiv>\n\n  <div class=\"cover-mid\">\n    <div class=\"cover-eyebrow\">A Rayan Hamafza venture · 1404<\u002Fdiv>\n    <div class=\"cover-title\">بورس <span class=\"pi\">پی<\u002Fspan><\u002Fdiv>\n    <div class=\"cover-sub\">The payment rails of Iran's capital market<\u002Fdiv>\n\n    <dl class=\"cover-meta\">\n      <div>\n        <dt>زیربرند<\u002Fdt>\n        <dd>رایان هم‌افزا<\u002Fdd>\n      <\u002Fdiv>\n      <div>\n        <dt>صنعت<\u002Fdt>\n        <dd>زیرساخت پرداخت · بازار سرمایه<\u002Fdd>\n      <\u002Fdiv>\n      <div>\n        <dt>محصولات<\u002Fdt>\n        <dd>چابک · تیام · همتا · کارت هدیه بورسی<\u002Fdd>\n      <\u002Fdiv>\n      <div>\n        <dt>این جلد<\u002Fdt>\n        <dd>راهبرد و هویت کلامی<\u002Fdd>\n      <\u002Fdiv>\n    <\u002Fdl>\n  <\u002Fdiv>\n\n  <div class=\"cover-foot\">\n    <div>© ۱۴۰۵ رایان هم‌افزا · محرمانه<\u002Fdiv>\n    <div class=\"scroll-hint\">\n      <span>ادامه<\u002Fspan>\n      <span class=\"arrow\"><\u002Fspan>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ESSENCE -->\n<section class=\"page\" id=\"essence\" data-screen-label=\"01 Brand Essence\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۱<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۱ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">جوهره برند<\u002Fh1>\n    <div class=\"title-en\">Brand Essence<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 56px;\">\n      جوهره برند، آن یک جمله است که اگر همه‌چیز را از دست بدهیم، باز هم بورس پی را تعریف می‌کند. هسته‌ای که هر تصمیم، هر محصول و هر کلمه باید از آن بجوشد.\n    <\u002Fp>\n\n    <div class=\"statement\">\n      بورس پی، <span class=\"accent\">ریل‌های پرداختِ تخصصیِ<\u002Fspan> بازار سرمایه ایران است؛\n      <br>پرداختی که هم آنی است، هم نهادی، هم زیر نظرِ سازمان بورس.\n    <\u002Fdiv>\n\n    <div class=\"kpi-row\">\n      <div class=\"kpi\"><div class=\"n\">۲۱<\u002Fdiv><div class=\"l\">بانک متصل از طریق بانکداری باز<\u002Fdiv><\u002Fdiv>\n      <div class=\"kpi\"><div class=\"n\">۵۰+<\u002Fdiv><div class=\"l\">صندوق سرمایه‌گذاری مشتری<\u002Fdiv><\u002Fdiv>\n      <div class=\"kpi\"><div class=\"n\">۱۰<\u002Fdiv><div class=\"l\">کارگزاری مشتری<\u002Fdiv><\u002Fdiv>\n      <div class=\"kpi\"><div class=\"n\">T+۰<\u002Fdiv><div class=\"l\">استاندارد زمانِ تسویه<\u002Fdiv><\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۰۱ · ۰۱<\u002Fspan>\n      <h2>سه ستونِ جوهره<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">Specialist<\u002Fdiv>\n        <h3>تخصصی<\u002Fh3>\n        <p>ما برای هر کسبی پرداخت نمی‌کنیم. تنها برای نهادهای بازار سرمایه — صندوق‌ها، کارگزاری‌ها، تأمین سرمایه‌ها. این تمرکز، عمق ما را می‌سازد.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">Instant<\u002Fdiv>\n        <h3>آنی<\u002Fh3>\n        <p>زمانِ تسویه برای ما متغیر نیست. T+۰ نقطه‌ی صفرِ کیفیتِ خدمت ماست. هر آنچه کمتر باشد، خدمت ناقص است.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">Sanctioned<\u002Fdiv>\n        <h3>مجاز<\u002Fh3>\n        <p>سازمان بورس به ما تأییدیه داده تا کانال رسمی پرداخت‌های صندوق‌ها باشیم. این مجوز، یک مزیت رقابتی نیست؛ یک شرط لازم است.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- MISSION -->\n<section class=\"page tint\" id=\"mission\" data-screen-label=\"02 Mission\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۲<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۲ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">ماموریت<\u002Fh1>\n    <div class=\"title-en\">Mission<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 56px;\">\n      آنچه هر روز از خواب برمی‌خیزیم تا انجامش دهیم. وعده‌ای به امروزِ مخاطب.\n    <\u002Fp>\n\n    <div class=\"statement\">\n      ما پرداخت‌های دستی، چندروزه و کاغذیِ نهادهای بازار سرمایه را به پرداخت‌های <span class=\"accent\">آنی، خودکار و دیجیتال<\u002Fspan> تبدیل می‌کنیم —\n      <br>تا صندوق‌ها، کارگزاران و بانک‌ها بتوانند با اعتماد، با ما تسویه کنند.\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۰۲ · ۰۱<\u002Fspan>\n      <h2>سه تعهد روزانه<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">به صندوق‌ها<\u002Fdiv>\n        <h3>تقسیم سود، در یک کلیک.<\u002Fh3>\n        <p>چیزی که زمانی نیاز به مدیر، چک، مهر و تنها چند روز انتظار داشت، به یک عملیات سیستمی تبدیل می‌کنیم. تیام، امضادارهای قانونی را در پلتفرم می‌نشاند و پرداخت را اتوماتیک می‌کند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">به کارگزاری‌ها<\u002Fdiv>\n        <h3>عملیات، بدون عملیاتی.<\u002Fh3>\n        <p>کارهایی که هر روز کارمندِ تسویه باید دستی انجام دهد، با همتا خودکار می‌شود. تراکنش‌های پایا، ساتنا و داخلی، در یک کنسولِ یکپارچه روی ریل‌های چابک می‌نشینند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">به اکوسیستم<\u002Fdiv>\n        <h3>زیرساختی شفاف.<\u002Fh3>\n        <p>هر تراکنش، یک گرهِ روشن است — قابلِ ردیابی، قابلِ مصالحه‌گری، با امضای دیجیتالِ مرجع. ما ریلی می‌سازیم که سازمان بورس و بانک‌ها به آن باور دارند.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- VISION -->\n<section class=\"page\" id=\"vision\" data-screen-label=\"03 Vision\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۳<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۳ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">چشم‌انداز<\u002Fh1>\n    <div class=\"title-en\">Vision<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 56px;\">\n      تصویرِ روشن از فردایی که می‌سازیم. جایی که می‌خواهیم در پنج سال آینده ایستاده باشیم.\n    <\u002Fp>\n\n    <div class=\"statement\">\n      تا ۱۴۱۰، هر تراکنشِ پرداختِ نهادی در اکوسیستم بازار سرمایه ایران، <span class=\"accent\">از کانال بورس پی<\u002Fspan> عبور کند —\n      <br>و «تسویه‌ی چند روزه» تنها یادگاری از گذشته باشد.\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 64px;\">\n      <span class=\"glyph\">۰۳ · ۰۱<\u002Fspan>\n      <h2>افق‌های پنج‌ساله<\u002Fh2>\n    <\u002Fdiv>\n\n    <ul class=\"num-list\">\n      <li>\n        <div class=\"term\">پوشش کاملِ صندوق‌ها<span class=\"latin\">Full fund coverage<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">از ۵۰ صندوقِ امروز، به همه‌ی صندوق‌های فعال بازار سرمایه ایران برسیم — به‌گونه‌ای که هر تقسیم سود سراسری در بازار، روی ریل‌های بورس پی پردازش شود.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">گسترشِ کارگزاری‌ها<span class=\"latin\">Brokerage expansion<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">همتا، استاندارد عملیاتیِ تسویه برای کارگزاری‌های بزرگ کشور شود — جایگزینِ سامانه‌های دستی و پراکنده‌ی موجود.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">پل به بازارهای موازی<span class=\"latin\">Adjacent markets<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">منطقِ پرداختِ بازار سرمایه را به حوزه‌های هم‌جوار گسترش دهیم: تأمین مالی جمعی، بازار رمز‌ارز نهادی، بازارهای مشتقه.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">کالا، نه پروژه<span class=\"latin\">Productized infrastructure<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">چابک به یک API استاندارد در بازار سرمایه تبدیل شود — به‌گونه‌ای که هر کارگزار، فین‌تک و بانک، آن را به‌عنوان یک «دادهٔ آماده» در معماری خود بنشاند.<\u002Fdiv>\n      <\u002Fli>\n    <\u002Ful>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- PRODUCTS — Architecture -->\n<section class=\"page\" id=\"products\" data-screen-label=\"04 Product Architecture\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۴<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۴ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">معماری محصول<\u002Fh1>\n    <div class=\"title-en\">Product Architecture<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      بورس پی یک خانواده از محصولات است که از یک ریلِ مشترک تغذیه می‌کنند. هر محصول، یک سناریوی پرداختِ متفاوت در بازار سرمایه را حل می‌کند.\n    <\u002Fp>\n\n    <div class=\"arch\">\n      <div class=\"arch-grid\">\n        <div class=\"product-card chabok\">\n          <div class=\"ribbon\"><span class=\"dot\"><\u002Fspan>محصول · زیرساخت<\u002Fdiv>\n          <div class=\"name\">چابک<\u002Fdiv>\n          <div class=\"latin\">Chabok · The Switch<\u002Fdiv>\n          <div class=\"desc\">سوییچِ پرداختِ آنی. روی بانکداری باز سوار است و به ۲۱ بانک متصل می‌شود. هر پرداختِ بدونِ نیاز به امضا، از این مسیر می‌رود. چابک و «پرداخت آنی»، مترادف‌اند.<\u002Fdiv>\n          <div class=\"who\"><span><strong>زمان:<\u002Fstrong> آنی<\u002Fspan><span>پایا · ساتنا · داخلی<\u002Fspan><\u002Fdiv>\n          <div class=\"timing\">T+0<\u002Fdiv>\n        <\u002Fdiv>\n\n        <div class=\"product-card tiam\">\n          <div class=\"ribbon\"><span class=\"dot\"><\u002Fspan>محصول · صندوق<\u002Fdiv>\n          <div class=\"name\">تیام<\u002Fdiv>\n          <div class=\"latin\">Tiam · Fund Disbursement<\u002Fdiv>\n          <div class=\"desc\">جانشینِ رایان‌بان. برای تقسیمِ سودِ گروهی صندوق‌ها. امضادارهای قانونی در سامانه می‌نشینند، تأیید می‌کنند، و تیام پرداختِ فله را روی ریل چابک می‌فرستد.<\u002Fdiv>\n          <div class=\"who\"><span><strong>زمان:<\u002Fstrong> ۴-۵ ساعت<\u002Fspan><span>با امضای قانونی<\u002Fspan><\u002Fdiv>\n          <div class=\"timing\">T+0 (~4h)<\u002Fdiv>\n        <\u002Fdiv>\n\n        <div class=\"product-card hamta\">\n          <div class=\"ribbon\"><span class=\"dot\"><\u002Fspan>محصول · کارگزاری<\u002Fdiv>\n          <div class=\"name\">همتا<\u002Fdiv>\n          <div class=\"latin\">Hamta · Brokerage Ops<\u002Fdiv>\n          <div class=\"desc\">اتوماسیونِ عملیاتِ تسویه‌ی کارگزاری‌ها. صف ارسال، تطبیق، گزارش‌گیری و پرداختِ نهایی — همگی از کنسولِ همتا، روی ریلِ چابک اجرا می‌شوند.<\u002Fdiv>\n          <div class=\"who\"><span><strong>مشتری:<\u002Fstrong> کارگزاری<\u002Fspan><span>۱۰ کارگزاری<\u002Fspan><\u002Fdiv>\n          <div class=\"timing\">T+0<\u002Fdiv>\n        <\u002Fdiv>\n\n        <div class=\"product-card gift\">\n          <div class=\"ribbon\"><span class=\"dot\"><\u002Fspan>محصول · کاربر نهایی<\u002Fdiv>\n          <div class=\"name\">کارت هدیه<\u002Fdiv>\n          <div class=\"latin\">Bourse Gift Card<\u002Fdiv>\n          <div class=\"desc\">تنها محصولِ B2C ما؛ هدیه‌ای که یک سهم را به نام عزیزانتان می‌گذارد. درگاهِ ورودِ نسلِ تازه به بازار سرمایه از یک تجربه‌ی گرم.<\u002Fdiv>\n          <div class=\"who\"><span><strong>مخاطب:<\u002Fstrong> فرد<\u002Fspan><span>هدیه‌دهنده / گیرنده<\u002Fspan><\u002Fdiv>\n          <div class=\"timing\">B2C<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"arch-foundation\">\n        <div>\n          <div class=\"label\">زیرساخت مشترک · Shared Rails<\u002Fdiv>\n          <div class=\"text\">\n            هر چهار محصول از یک <strong>هسته‌ی پرداخت<\u002Fstrong> تغذیه می‌کنند: اتصالِ بانکداری بازِ ۲۱ بانک، تأییدیه‌ی سازمان بورس، و سوییچِ اختصاصیِ بورس پی. ما <strong>فقط پرداخت می‌کنیم<\u002Fstrong> — برخلاف پرداخت‌یاری‌ها که هم پرداخت و هم دریافت دارند، تمرکز ما باریک و عمیق است.\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"meta\">\n          <div class=\"stat\"><div class=\"n\">۲۱<\u002Fdiv><div class=\"l\">Banks<\u002Fdiv><\u002Fdiv>\n          <div class=\"stat\"><div class=\"n\">۳<\u002Fdiv><div class=\"l\">Channels<\u002Fdiv><\u002Fdiv>\n          <div class=\"stat\"><div class=\"n\">۱<\u002Fdiv><div class=\"l\">Switch<\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"arch-flow\">\n        <div>\n          <strong>سلسله‌مراتب:<\u002Fstrong> چابک ریلِ پایه است. تیام و همتا روی چابک سوار می‌شوند. کارت هدیه، یک محصولِ مصرفی است که از همان زیرساخت استفاده می‌کند.\n        <\u002Fdiv>\n        <div>\n          <strong>یک تفاوتِ کلیدی:<\u002Fstrong> چابک «آنی» است (T+۰). تیام به‌خاطر فرآیندِ امضای قانونی، چند ساعت زمان می‌برد — اما همچنان همان‌روزه‌ی واقعی است.\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 24px;\">\n      یادداشت: <strong style=\"color: var(--navy-1);\">داک<\u002Fstrong>، <strong style=\"color: var(--navy-1);\">پلاگ‌این<\u002Fstrong> و سایر محصولات قدیمی، در این معماری جایی ندارند. تمرکز برند، روی این چهار محصولِ بنیادی است.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- AUDIENCE -->\n<section class=\"page tint\" id=\"audience\" data-screen-label=\"05 Audience\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۵<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۵ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">مخاطبِ هدف<\u002Fh1>\n    <div class=\"title-en\">Target Audience<\u002Fdiv>\n\n    <p class=\"lede\">\n      مخاطبِ ما عمدتاً نهادی است. سه گروهِ متمایز که هر کدام، رابطه‌ی متفاوتی با ما دارند.\n    <\u002Fp>\n\n    <div class=\"audience-grid\">\n      <!-- Funds -->\n      <div class=\"aud-card\">\n        <div class=\"role\"><span class=\"dot\"><\u002Fspan>اولویتِ یک · Primary B2B<\u002Fdiv>\n        <h3>صندوق‌ها<\u002Fh3>\n        <div class=\"latin\">Investment Funds<\u002Fdiv>\n        <p>مدیرانِ مالی و عملیاتیِ صندوق‌های سرمایه‌گذاری. کسانی که هر ماه تقسیم سودِ گروهی به هزاران سرمایه‌گذار را راه می‌اندازند و در گذشته با چک، مهر و انتظارِ بانک سر و کار داشتند.<\u002Fp>\n        <div>\n          <span class=\"product-tag\">تیام<\u002Fspan>\n          <span class=\"product-tag\">چابک<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"scale\">\n          <span>اندازه: ۵۰+ صندوق<\u002Fspan>\n          <span>محصول اصلی: تیام<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <!-- Brokerages -->\n      <div class=\"aud-card\">\n        <div class=\"role\"><span class=\"dot\"><\u002Fspan>اولویتِ دو · Secondary B2B<\u002Fdiv>\n        <h3>کارگزاری‌ها<\u002Fh3>\n        <div class=\"latin\">Brokerage Firms<\u002Fdiv>\n        <p>تیم‌های عملیات، تسویه و خزانه‌داری در کارگزاری‌های فعالِ بورس. کسانی که هر روز با هزاران تراکنش و نقطه‌ی فشارِ ساعت پایانیِ بازار دست‌وپنجه نرم می‌کنند.<\u002Fp>\n        <div>\n          <span class=\"product-tag\">همتا<\u002Fspan>\n          <span class=\"product-tag\">چابک<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"scale\">\n          <span>اندازه: ۱۰ کارگزاری<\u002Fspan>\n          <span>محصول اصلی: همتا<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <!-- Banks -->\n      <div class=\"aud-card banks\">\n        <div class=\"role\"><span class=\"dot\"><\u002Fspan>شریک · Integration Partner<\u002Fdiv>\n        <h3>بانک‌ها<\u002Fh3>\n        <div class=\"latin\">Banking Partners<\u002Fdiv>\n        <p>بانک‌هایی که از طریق API‌های بانکداریِ باز با ما هم‌سفره شده‌اند. آن‌ها زیرساختِ خام را می‌دهند، ما لایه‌ی هوشمند را روی آن می‌سازیم. ۲۱ بانک، تا امروز.<\u002Fp>\n        <div>\n          <span class=\"product-tag\">چابک<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"scale\">\n          <span>اندازه: ۲۱ بانک<\u002Fspan>\n          <span>اتصال: Open Banking API<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۰۵ · ۰۲<\u002Fspan>\n      <h2>مخاطبِ ثانویه — کاربرِ نهایی<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-2\">\n      <div class=\"card\">\n        <div class=\"label\">B2C · Bourse Gift Card<\u002Fdiv>\n        <h3>هدیه‌دهنده و گیرنده.<\u002Fh3>\n        <p>افرادی که می‌خواهند یک سهم را به نام عزیزانشان هدیه دهند، یا آن‌ها که از این مسیر، اولین تجربه‌ی بازار سرمایه را تجربه می‌کنند. این مخاطب، در آینده ممکن است به صورت مستقیم با چابک تعامل کند. امروز، تنها کانالِ ارتباطِ ما با مردمِ عادی، کارت هدیه است.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">آینده · Future Direct B2C<\u002Fdiv>\n        <h3>کاربرانِ تسویه‌ی شخصی.<\u002Fh3>\n        <p>افرادی که در آینده بتوانند مستقیم با ریلِ پرداختیِ بورس پی، تسویه‌های روزانه‌شان را انجام دهند. این یک افقِ پنج‌ساله است — امروز هنوز محصولِ مستقیمِ B2C در این مسیر نداریم، اما معماری چابک، آن را ممکن می‌سازد.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 24px; max-width: 760px;\">\n      <strong style=\"color: var(--navy-1);\">جمع‌بندی:<\u002Fstrong>\n      اولویتِ ارتباطیِ ما، نهادی است. لحن، استدلال و کانالِ ارتباطیِ پیش‌فرضِ ما، با یک مدیرِ مالیِ نهادِ بازار سرمایه گفت‌وگو می‌کند. کاربرِ نهایی، مخاطبِ شاخه‌ایست؛ مهم، اما در مدارِ دوم.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- POSITION -->\n<section class=\"page dark\" id=\"position\" data-screen-label=\"06 Competitive Position\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۶<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۶ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">جایگاهِ رقابتی<\u002Fh1>\n    <div class=\"title-en\">Competitive Positioning<\u002Fdiv>\n\n    <p class=\"lede\">\n      ما تنها بازیگرِ فضای پرداختِ ایران نیستیم. اما تنها بازیگری هستیم که <em style=\"color: var(--sky); font-style: normal;\">تخصصِ بازار سرمایه<\u002Fem> را به <em style=\"color: var(--sky); font-style: normal;\">سرعتِ T+۰<\u002Fem> جوش می‌دهد.\n    <\u002Fp>\n\n    <div class=\"compass\">\n      <div class=\"compass-axis\" style=\"background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.10);\">\n        <span class=\"ax-label ax-x-l\" style=\"color: rgba(255,255,255,0.5);\">عمومی<\u002Fspan>\n        <span class=\"ax-label ax-x-r\" style=\"color: rgba(255,255,255,0.5);\">تخصصِ بازار سرمایه<\u002Fspan>\n        <span class=\"ax-label ax-y-t\" style=\"color: rgba(255,255,255,0.5);\">پرداختِ آنی<\u002Fspan>\n        <span class=\"ax-label ax-y-b\" style=\"color: rgba(255,255,255,0.5);\">پرداختِ سنتی<\u002Fspan>\n        <div class=\"axis-h\" style=\"background: rgba(255,255,255,0.12);\"><\u002Fdiv>\n        <div class=\"axis-v\" style=\"background: rgba(255,255,255,0.12);\"><\u002Fdiv>\n\n        <!-- Players plotted -->\n        <div class=\"player us\" style=\"top: 24%; right: 78%;\">بورس پی<\u002Fdiv>\n        <div class=\"player\" style=\"top: 30%; right: 25%; background: transparent; border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);\">جیبیت<\u002Fdiv>\n        <div class=\"player\" style=\"top: 38%; right: 18%; background: transparent; border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);\">زرین‌پال<\u002Fdiv>\n        <div class=\"player\" style=\"top: 72%; right: 30%; background: transparent; border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);\">پرداختیاری‌های عمومی<\u002Fdiv>\n        <div class=\"player\" style=\"top: 78%; right: 75%; background: transparent; border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);\">روش‌های دستیِ صندوق‌ها<\u002Fdiv>\n        <div class=\"player\" style=\"top: 60%; right: 70%; background: transparent; border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);\">سامانه‌های in-house کارگزاری<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 56px;\">\n      <span class=\"glyph\">۰۶ · ۰۲<\u002Fspan>\n      <h2>سه تفاوتِ بنیادی<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">۰۱ vs جیبیت<\u002Fdiv>\n        <h3>تخصص، نه گستره.<\u002Fh3>\n        <p>جیبیت یک پرداخت‌یارِ عمومی است؛ از هر کسبی خوشش بیاید، پذیرنده‌اش می‌شود. ما تنها در بازار سرمایه کار می‌کنیم — و این محدودیت، عمقِ ما را می‌سازد.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۲ vs زرین‌پال<\u002Fdiv>\n        <h3>پرداخت، نه دریافت.<\u002Fh3>\n        <p>زرین‌پال پذیرنده است؛ پول از مشتری می‌گیرد و به فروشنده می‌دهد. ما برعکسیم — ما تنها پرداخت‌کننده‌ایم. این تخصص، ریسک و رگولاتوری ما را متفاوت می‌کند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۳ vs سامانه‌های دستی<\u002Fdiv>\n        <h3>سیستم، نه فرآیند.<\u002Fh3>\n        <p>قبلاً، صندوق‌دار باید چک می‌برد، مهر می‌گرفت، می‌رفت بانک. امروز، تیام این مسیر را سیستماتیک می‌کند. این، یک ارتقای ابزاری نیست — یک تغییرِ پارادایم است.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 24px; color: rgba(255,255,255,0.6); max-width: 800px;\">\n      <strong style=\"color: #fff;\">یادآوری:<\u002Fstrong>\n      شرکت‌های پرداخت‌یاری به‌طور قانونی مجازِ هم پرداخت و هم دریافت‌اند. تخصصِ <em style=\"color: var(--sky); font-style: normal;\">فقط پرداخت<\u002Fem> ما، یک انتخابِ استراتژیک است — نه یک محدودیتِ رگولاتوری.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- VALUES -->\n<section class=\"page\" id=\"values\" data-screen-label=\"07 Values\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۷<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۷ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">ارزش‌ها<\u002Fh1>\n    <div class=\"title-en\">Values<\u002Fdiv>\n\n    <p class=\"lede\" style=\"max-width: 800px; margin-bottom: 48px;\">\n      ارزش‌های بورس پی، شاخه‌ای متمایز از ریشه‌ی رایان هم‌افزا است: همان اصولِ حرفه‌ایِ شرکتِ مادر، با چابکیِ افزوده‌ای که از روحِ یک محصولِ نوبنیادِ زیرساختی می‌آید.\n    <\u002Fp>\n\n    <div class=\"grid-2\">\n      <div class=\"card\">\n        <div class=\"label\">۰۱ · Trust by Inheritance<\u002Fdiv>\n        <h3>اعتمادِ به ارث رسیده<\u002Fh3>\n        <p>اعتماد ما، از یک شب ساخته نشده. ما وارثِ سال‌ها سابقه‌ی رایان هم‌افزا در زیرساختِ بازار سرمایه‌ایم — و تأییدیه‌ی سازمان بورس، مهرِ بیرونیِ این میراث است. این، ارزشی است که هر روز پس می‌دهیم، نه چیزی که هر روز بسازیم.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۲ · Speed is the Spec<\u002Fdiv>\n        <h3>سرعت، استانداردِ پایه<\u002Fh3>\n        <p>T+۰ برای ما یک ویژگیِ بازاریابانه نیست؛ ستونِ قراردادی است. اگر یک تراکنش از این آستانه عبور کند، خدمت ناقص است. سرعت، تعریفِ پایه‌ایِ ماست.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۳ · Depth, not Breadth<\u002Fdiv>\n        <h3>عمق، نه گستره<\u002Fh3>\n        <p>ما برای هر کسبی پرداخت‌یار نمی‌شویم. تنها نهادهای بازار سرمایه. این محدودیت، عمقِ تخصص و کیفیتِ خدمتِ ما را تضمین می‌کند. ما به جای ۱۰ صنعت متوسط، یک صنعت را بی‌نقص می‌خواهیم.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۴ · Open Architecture<\u002Fdiv>\n        <h3>معماریِ گشوده<\u002Fh3>\n        <p>ما زیرساختی می‌سازیم که برای دیگران هم کار کند. بانک‌ها، کارگزاری‌ها، فین‌تک‌ها — شریک‌اند، نه مشتریِ صرف. بانکداریِ باز، در فرهنگِ ما پیش از آنکه در رگولاتوریِ کشور وارد شود، اصلِ کار بود.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۵ · Plain Speech<\u002Fdiv>\n        <h3>زبانِ روشن<\u002Fh3>\n        <p>اصطلاحاتِ مالی، حقوقی و فنی را به زبانِ آدمیزاد ترجمه می‌کنیم. شفافیت در کار، با شفافیت در کلمات شروع می‌شود. اگر مدیرِ مالی صندوق نتواند گزارشِ ما را در یک نگاه بفهمد، گزارشِ ما را اصلاح می‌کنیم — نه او را.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۶ · Quiet Accountability<\u002Fdiv>\n        <h3>پاسخ‌گوییِ بی‌سر و صدا<\u002Fh3>\n        <p>وقتی همه‌چیز خوب کار می‌کند، دیده نمی‌شویم — و این، آرمانِ ما از خدمت است. در لحظه‌ی خطا، اولین کسی که در را باز می‌کند، خودِ ماییم. تأخیر و توجیه، در فرهنگِ ما جایی ندارد.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- VALUE PROP -->\n<section class=\"page tint\" id=\"valueprop\" data-screen-label=\"08 Value Proposition\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۸<\u002Fspan><span>راهبرد · Strategy<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۸ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">ارزشِ پیشنهادی<\u002Fh1>\n    <div class=\"title-en\">Value Proposition<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 48px;\">\n      چهار ستونی که ادعای بورس پی را بر دوش می‌کشند. هر کدام، یک قول است که باید در محصول، در تجربه و در ارتباط، قابلِ سنجش باشد.\n    <\u002Fp>\n\n    <div class=\"statement\">\n      «سرعتِ یک تراکنش، اعتمادِ یک نهاد، تخصصِ یک متخصص —\n      <br>همه روی <span class=\"accent\">یک ریلِ زیرساختی واحد<\u002Fspan>.»\n    <\u002Fdiv>\n\n    <div class=\"pillars\">\n      <div class=\"pillar\">\n        <span class=\"num\">۰۱ · Instant<\u002Fspan>\n        <h3>تسویه‌ی آنی<\u002Fh3>\n        <p>چابک، T+۰ را به استانداردِ پایه تبدیل می‌کند. روی هر سه ریلِ پایا، ساتنا و داخلی.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"pillar\">\n        <span class=\"num\">۰۲ · Specialist<\u002Fspan>\n        <h3>تخصصِ نهادی<\u002Fh3>\n        <p>ما تنها برای نهادهای بازار سرمایه می‌سازیم. این، عمقِ راه‌حل و درکِ مسئله‌ی ما را متمایز می‌کند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"pillar\">\n        <span class=\"num\">۰۳ · Sanctioned<\u002Fspan>\n        <h3>مجوزِ مرجع<\u002Fh3>\n        <p>تأییدیه‌ی سازمان بورس برای پرداختِ صندوق‌ها از کانال ما. این، یک امضای رگولاتوری است که رقبا ندارند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"pillar\">\n        <span class=\"num\">۰۴ · Unified<\u002Fspan>\n        <h3>زیرساختِ یکپارچه<\u002Fh3>\n        <p>چابک، تیام و همتا، روی یک هسته‌ی مشترک می‌نشینند. یک قرارداد، یک API، یک تجربه‌ی نگهداری.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۰۸ · ۰۲<\u002Fspan>\n      <h2>قابِ ارزشِ پیشنهادی برای هر محصول<\u002Fh2>\n    <\u002Fdiv>\n\n    <p class=\"body\" style=\"margin-bottom: 24px;\">یک جمله‌ی مرجع برای هر محصول، که هر زیرشاخه از کمپین تا فروش، از آن مشتق می‌شود:<\u002Fp>\n\n    <div style=\"background: var(--navy-1); color: #fff; padding: 32px 40px; border-radius: var(--r-xl); margin-bottom: 14px;\">\n      <div style=\"font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sky); margin-bottom: 12px; font-weight: 600;\">For Funds · Tiam<\u002Fdiv>\n      <div style=\"font-family: var(--f-display); font-size: 21px; line-height: 1.65; font-weight: 500;\">\n        برای صندوق‌هایی که تقسیم سودِ گروهی برایشان <span style=\"color: var(--sky);\">نقطه‌ی فشارِ ماهانه<\u002Fspan> است، تیام <span style=\"color: var(--sky);\">یک پلتفرمِ امضا و پرداخت<\u002Fspan> است که فرآیندِ کاغذیِ چندروزه را به یک عملیاتِ سیستمیِ همان‌روزه تبدیل می‌کند — برخلاف بانک‌های سنتی که هر تقسیمِ سود را به یک پروژه‌ی عملیاتی تبدیل می‌کنند.\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div style=\"background: var(--navy-1); color: #fff; padding: 32px 40px; border-radius: var(--r-xl); margin-bottom: 14px;\">\n      <div style=\"font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sky); margin-bottom: 12px; font-weight: 600;\">For Brokerages · Hamta<\u002Fdiv>\n      <div style=\"font-family: var(--f-display); font-size: 21px; line-height: 1.65; font-weight: 500;\">\n        برای کارگزاری‌هایی که عملیاتِ تسویه‌ی روزانه‌شان <span style=\"color: var(--sky);\">پر از نقطه‌ی دستی<\u002Fspan> است، همتا <span style=\"color: var(--sky);\">یک کنسولِ اتوماسیون<\u002Fspan> است که صف، تطبیق و پرداخت را خودکار می‌کند — برخلاف سامانه‌های in-house که با هر ارتقا، یک پروژه‌ی توسعه‌ی داخلی می‌خواهند.\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div style=\"background: var(--paper); padding: 32px 40px; border-radius: var(--r-xl); border: 1px solid var(--hairline); margin-bottom: 14px;\">\n      <div style=\"font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--indigo); margin-bottom: 12px; font-weight: 600;\">For Capital Market Institutions · Chabok<\u002Fdiv>\n      <div style=\"font-family: var(--f-display); font-size: 21px; line-height: 1.65; font-weight: 500; color: var(--navy-1);\">\n        برای هر نهادِ بازار سرمایه که نیاز به <span style=\"color: var(--indigo);\">پرداختِ آنی به ده‌ها هزار حسابِ بانکی<\u002Fspan> دارد، چابک <span style=\"color: var(--indigo);\">یک سوییچِ تخصصی<\u002Fspan> است که روی بانکداریِ باز ۲۱ بانک سوار شده — برخلاف اتصالِ مستقیم به APIهای پراکنده‌ی بانک‌ها که هر تغییرِ سرور، یک بحرانِ عملیاتی می‌سازد.\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div style=\"background: var(--paper); padding: 32px 40px; border-radius: var(--r-xl); border: 1px solid rgba(224,116,74,0.20);\">\n      <div style=\"font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--coral); margin-bottom: 12px; font-weight: 600;\">For Gift-Givers · Bourse Gift Card<\u002Fdiv>\n      <div style=\"font-family: var(--f-display); font-size: 21px; line-height: 1.65; font-weight: 500; color: var(--navy-1);\">\n        برای کسانی که می‌خواهند <span style=\"color: var(--coral);\">هدیه‌ی معنادار<\u002Fspan> بدهند، کارت هدیه بورسیِ بورس پی <span style=\"color: var(--coral);\">یک سهم<\u002Fspan> را به نام عزیزانشان می‌گذارد — برخلاف کارت‌های هدیه‌ی فروشگاهی که با گذرِ زمان فقط مصرف می‌شوند، نه رشد می‌کنند.\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- PERSONA -->\n<section class=\"page\" id=\"persona\" data-screen-label=\"09 Personality\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۰۹<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۰۹ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">شخصیتِ برند<\u002Fh1>\n    <div class=\"title-en\">Brand Personality<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 48px;\">\n      اگر بورس پی یک نفر بود، چه کسی بود؟ پاسخ این سؤال، رفتارِ ما را در هر نقطه‌ی تماس تعیین می‌کند.\n    <\u002Fp>\n\n    <div class=\"statement\">\n      یک <span class=\"accent\">معمارِ زیرساخت‌های مالیِ نسلِ جدید<\u002Fspan> —\n      <br>کسی که زبانِ پروتکل‌ها را می‌داند، اما با شما به فارسیِ ساده حرف می‌زند. دقیق و آرام، با اعتمادبه‌نفسی که از تجربه آمده، نه از تبلیغ.\n    <\u002Fdiv>\n\n    <div class=\"grid-4\" style=\"margin-top: 56px; gap: 14px;\">\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">سنِ ذهنی<\u002Fdiv>\n        <h3 style=\"font-size: 18px; margin-bottom: 0;\">۳۴ ساله<\u002Fh3>\n        <p style=\"margin-top: 6px; font-size: 13px;\">پختگیِ یک حرفه‌ای، با چابکیِ یک نوجوان.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">پوشش<\u002Fdiv>\n        <h3 style=\"font-size: 18px; margin-bottom: 0;\">رسمیِ راحت<\u002Fh3>\n        <p style=\"margin-top: 6px; font-size: 13px;\">پیراهنِ تیره، بدونِ کراوات. آماده‌ی جلسه‌ی هیئت مدیره و قهوه‌خانه‌ی توسعه‌دهنده.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">رفتار<\u002Fdiv>\n        <h3 style=\"font-size: 18px; margin-bottom: 0;\">آرام و دقیق<\u002Fh3>\n        <p style=\"margin-top: 6px; font-size: 13px;\">هیچ‌گاه شتاب‌زده نیست، اما همیشه به‌موقع است.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">رابطه<\u002Fdiv>\n        <h3 style=\"font-size: 18px; margin-bottom: 0;\">شریک، نه فروشنده<\u002Fh3>\n        <p style=\"margin-top: 6px; font-size: 13px;\">منفعتِ بلندمدتِ شما را پیش از فروشِ امروزش می‌گذارد.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 56px;\">\n      <span class=\"glyph\">۰۹ · ۰۲<\u002Fspan>\n      <h2>چهار صفتِ بنیادی<\u002Fh2>\n    <\u002Fdiv>\n\n    <ul class=\"num-list\">\n      <li>\n        <div class=\"term\">صداقت<span class=\"latin\">Honesty — inherited from Rayan<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">فروتن، صمیمی، ارزش‌مدار. می‌گوییم چه کاری از ما برمی‌آید و چه نه. ریسک را پنهان نمی‌کنیم. وقتی نمی‌دانیم، می‌گوییم نمی‌دانیم.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">صلاحیت<span class=\"latin\">Competence — inherited from Rayan<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">متخصص، هوشمند، فن‌محور، به‌روز. عمقِ دانشِ ما در گفت‌وگو حس می‌شود — حتی وقتی ساده حرف می‌زنیم. تأییدیه‌ی سازمان بورس، گواهِ بیرونیِ این صلاحیت است.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">چابکی<span class=\"latin\">Agility — Boorspay's own<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">ویژگیِ ممتازِ ما، که از رایان نیامده. سریع‌تر تصمیم می‌گیریم، سریع‌تر می‌سازیم، سریع‌تر اصلاح می‌کنیم. این، ما را از یک شرکتِ نرم‌افزاریِ سنتی متمایز می‌کند.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">باراندازی<span class=\"latin\">Stewardship — Boorspay's own<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">ما بارِ مسئولیتِ زیرساخت را برمی‌داریم. مشتریِ ما با خیالِ راحت، تسویه‌ی صدها میلیارد تومانی را روی شانه‌های ما می‌گذارد. این، یک تعهدِ سنگین است که هر روز نشان می‌دهیم می‌توانیم حمل کنیم.<\u002Fdiv>\n      <\u002Fli>\n    <\u002Ful>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ARCHETYPE -->\n<section class=\"page tint\" id=\"archetype\" data-screen-label=\"10 Archetypes\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۰<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۰ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">آرکتایپ‌ها<\u002Fh1>\n    <div class=\"title-en\">Jungian Archetypes<\u002Fdiv>\n\n    <p class=\"lede\" style=\"max-width: 800px; margin-bottom: 48px;\">\n      آرکتایپ‌های یونگ، الگوهای کهنی هستند که در ناخودآگاهِ جمعیِ بشر زیست می‌کنند. برندهای ماندگار، روی یک آرکتایپِ غالب می‌ایستند و با یک یا دو آرکتایپِ ثانویه آن را تلطیف می‌کنند. ترکیبِ بورس پی به این شکل است:\n    <\u002Fp>\n\n    <!-- Primary -->\n    <div class=\"archetype primary\">\n      <div class=\"symbol\">\n        <svg viewBox=\"0 0 100 100\" width=\"55%\" height=\"55%\" fill=\"none\" stroke=\"#6F8FCE\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <!-- Magician transformation: arrows from box to circle -->\n          <rect x=\"14\" y=\"42\" width=\"22\" height=\"22\" stroke-opacity=\"0.5\"><\u002Frect>\n          <circle cx=\"76\" cy=\"53\" r=\"12\"><\u002Fcircle>\n          <path d=\"M40 53 L60 53\" stroke=\"#fff\" stroke-width=\"1.8\"><\u002Fpath>\n          <path d=\"M55 47 L62 53 L55 59\" stroke=\"#fff\" stroke-width=\"1.8\"><\u002Fpath>\n          <circle cx=\"76\" cy=\"53\" r=\"3\" fill=\"#6F8FCE\" stroke=\"none\"><\u002Fcircle>\n          <path d=\"M20 28 L24 32 M28 22 L26 27 M14 35 L18 33\" stroke-opacity=\"0.4\"><\u002Fpath>\n        <\u002Fsvg>\n      <\u002Fdiv>\n      <div class=\"body\">\n        <div class=\"pct\">آرکتایپِ غالب · Primary · ۶۰٪<\u002Fdiv>\n        <h3>جادوگر<\u002Fh3>\n        <div class=\"latin\">The Magician<\u002Fdiv>\n        <p>\n          جادوگر، چیزی که غیرممکن می‌نمود را ممکن می‌کند. نه با حقه، که با درکِ عمیقِ سازوکارها. ماموریتِ او «تحول» است: تبدیلِ واقعیتی سفت و سخت به واقعیتی روان، در دسترس و سیال.\n        <\u002Fp>\n        <p>\n          بورس پی همین کار را می‌کند: <strong>چک، مهر و چندروزِ بانک را به یک کلیک تبدیل می‌کند<\u002Fstrong>. سامانه‌ی دستی به اتوماسیون. کاغذ به امضای دیجیتال. این، جوهرِ جادوگری در فین‌تک است.\n        <\u002Fp>\n        <div class=\"traits\">\n          <span>تحول‌بخش<\u002Fspan><span>ممکن‌کننده<\u002Fspan><span>دانای پروتکل<\u002Fspan><span>رازِ پیچیده، نتیجه‌ی ساده<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- Secondary -->\n    <div class=\"archetype\" style=\"margin-top: 16px;\">\n      <div class=\"symbol\">\n        <svg viewBox=\"0 0 100 100\" width=\"55%\" height=\"55%\" fill=\"none\" stroke=\"#2A2D7E\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <!-- Sage / book + eye -->\n          <path d=\"M50 28 C 30 28, 22 40, 22 48 C 22 56, 30 70, 50 70 C 70 70, 78 56, 78 48 C 78 40, 70 28, 50 28 Z\"><\u002Fpath>\n          <circle cx=\"50\" cy=\"48\" r=\"10\"><\u002Fcircle>\n          <circle cx=\"50\" cy=\"48\" r=\"3\" fill=\"#2A2D7E\" stroke=\"none\"><\u002Fcircle>\n        <\u002Fsvg>\n      <\u002Fdiv>\n      <div class=\"body\">\n        <div class=\"pct\">آرکتایپِ ثانویه · Secondary · ۲۵٪<\u002Fdiv>\n        <h3>فرزانه<\u002Fh3>\n        <div class=\"latin\">The Sage<\u002Fdiv>\n        <p>\n          فرزانه، در پی حقیقت است. می‌خواند، می‌سنجد، آموزش می‌دهد. تخصص و دقت، نشانه‌های اوست. این آرکتایپ، میراثِ مستقیمِ ما از رایان هم‌افزا و تأییدیه‌ی سازمان بورس است — همان عمقی که هر مدیرِ مالیِ صندوق در گفت‌وگو با ما حس می‌کند.\n        <\u002Fp>\n        <div class=\"traits\">\n          <span>متخصص<\u002Fspan><span>دقیق<\u002Fspan><span>آموزگار<\u002Fspan><span>قابل استناد<\u002Fspan><span>عمیق<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- Tertiary -->\n    <div class=\"archetype\" style=\"margin-top: 16px;\">\n      <div class=\"symbol\">\n        <svg viewBox=\"0 0 100 100\" width=\"55%\" height=\"55%\" fill=\"none\" stroke=\"#1B1F66\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <!-- Ruler / crown-pillar -->\n          <path d=\"M28 70 L72 70\"><\u002Fpath>\n          <path d=\"M28 70 L28 38 L40 50 L50 32 L60 50 L72 38 L72 70\"><\u002Fpath>\n          <circle cx=\"40\" cy=\"50\" r=\"2\" fill=\"#1B1F66\" stroke=\"none\"><\u002Fcircle>\n          <circle cx=\"50\" cy=\"32\" r=\"2\" fill=\"#1B1F66\" stroke=\"none\"><\u002Fcircle>\n          <circle cx=\"60\" cy=\"50\" r=\"2\" fill=\"#1B1F66\" stroke=\"none\"><\u002Fcircle>\n        <\u002Fsvg>\n      <\u002Fdiv>\n      <div class=\"body\">\n        <div class=\"pct\">آرکتایپِ نوازشی · Accent · ۱۵٪<\u002Fdiv>\n        <h3>حاکم<\u002Fh3>\n        <div class=\"latin\">The Ruler<\u002Fdiv>\n        <p>\n          حاکم، نظم می‌سازد، قانون می‌گذارد، کنترلِ مسئولانه را به جان می‌خرد. این آرکتایپ، در مواجهه با مسئولیتِ سنگینِ ما — جا‌به‌جا کردنِ صدها میلیارد تومان در روز — ضروری است. مشتریِ نهادیِ ما به ما باور دارد، چون می‌داند ما <strong>نظم‌دار، باسابقه و مسئولانه<\u002Fstrong>‌ایم.\n        <\u002Fp>\n        <div class=\"traits\">\n          <span>منظم<\u002Fspan><span>مسئولانه<\u002Fspan><span>قاعده‌مند<\u002Fspan><span>زیرساختی<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 32px; max-width: 800px;\">\n      <strong style=\"color: var(--navy-1);\">قاعده‌ی به‌کارگیری:<\u002Fstrong>\n      در ارتباطِ نهادی (صندوق و کارگزاری و بانک)، نسبت‌ها به سمتِ <em style=\"color: var(--indigo); font-style: normal;\">جادوگر + فرزانه + حاکم<\u002Fem> می‌چرخد. در ارتباطِ B2C کارت هدیه، <em style=\"color: var(--indigo); font-style: normal;\">جادوگر<\u002Fem> همچنان غالب می‌ماند، اما <em style=\"color: var(--indigo); font-style: normal;\">حاکم<\u002Fem> پشتِ پرده می‌ایستد و گرما اضافه می‌شود.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- VOICE -->\n<section class=\"page\" id=\"voice\" data-screen-label=\"11 Voice\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۱<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۱ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">لحنِ برند<\u002Fh1>\n    <div class=\"title-en\">Tone of Voice<\u002Fdiv>\n\n    <p class=\"lede\" style=\"max-width: 820px; margin-bottom: 48px;\">\n      لحنِ ما، جان‌مایه‌ای است که از رایان هم‌افزا به ارث می‌بریم: <em style=\"font-style: normal; color: var(--indigo);\">صمیمی، ساده، شفاف، فروتن، انسانی، مثبت‌اندیش، مسئولانه<\u002Fem>. به این مجموعه، یک ویژگیِ مختصِ بورس پی اضافه می‌کنیم: <em style=\"font-style: normal; color: var(--indigo);\">با اعتماد به نفسِ نهادی<\u002Fem>. ما متخصص‌ایم. لازم نیست بلند بگوییم — اما لازم است که از زیرِ اعتمادبه‌نفس حرف بزنیم.\n    <\u002Fp>\n\n    <div class=\"voice-cols\">\n      <div class=\"col do\">\n        <h4><span class=\"mark\">+<\u002Fspan>لحنِ ما این است<\u002Fh4>\n        <ul>\n          <li><strong>گرم و صمیمی<\u002Fstrong> — مثلِ یک همکارِ آشنا، نه یک منشیِ تشریفاتی.<\u002Fli>\n          <li><strong>ساده و روشن<\u002Fstrong> — هر جمله یک معنا، بدونِ پز اصطلاحی.<\u002Fli>\n          <li><strong>شفاف و راستگو<\u002Fstrong> — ریسک، تأخیر و محدودیت را پنهان نمی‌کنیم.<\u002Fli>\n          <li><strong>دقیق و مستند<\u002Fstrong> — اعداد، تاریخ‌ها و ارجاعات را درست می‌آوریم.<\u002Fli>\n          <li><strong>با اعتماد به نفس<\u002Fstrong> — می‌دانیم چه می‌کنیم؛ از زیرِ این دانایی حرف می‌زنیم.<\u002Fli>\n          <li><strong>مثبت‌اندیش بدونِ ساده‌انگاری<\u002Fstrong> — به آینده باور داریم، با چشمِ باز.<\u002Fli>\n          <li><strong>مسئولانه<\u002Fstrong> — وقتی اشتباه می‌کنیم، اول از همه خودمان می‌گوییم.<\u002Fli>\n          <li><strong>قابلِ ارجاع<\u002Fstrong> — حرف‌ها را با مدرکِ قابلِ بررسی می‌گوییم.<\u002Fli>\n        <\u002Ful>\n      <\u002Fdiv>\n      <div class=\"col dont\">\n        <h4><span class=\"mark\">−<\u002Fspan>لحنِ ما این نیست<\u002Fh4>\n        <ul>\n          <li>سردِ ماشینی و تشریفاتی<\u002Fli>\n          <li>پیچیده با اصطلاحاتِ نامفهوم<\u002Fli>\n          <li>متظاهرانه یا مدعی<\u002Fli>\n          <li>طعنه‌آمیز یا کنایی<\u002Fli>\n          <li>پر از وعده‌های اغراق‌آمیز<\u002Fli>\n          <li>مغرور یا فرادست<\u002Fli>\n          <li>منفی‌نگر یا ترساننده<\u002Fli>\n          <li>اَمیخته با اصطلاحاتِ زرد و بازاریابی شعاری<\u002Fli>\n        <\u002Ful>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 56px;\">\n      <span class=\"glyph\">۱۱ · ۰۲<\u002Fspan>\n      <h2>چند قاعده‌ی نوشتاری<\u002Fh2>\n    <\u002Fdiv>\n\n    <ul class=\"num-list\">\n      <li>\n        <div class=\"term\">جمله‌های کوتاه<span class=\"latin\">Short sentences<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">میانگین زیرِ ۱۸ کلمه. هر جمله، یک ایده. اگر مجبور به نقطه‌ویرگول شدید، احتمالاً جمله را باید شکست.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">دومِ شخص، نه سومِ شخص<span class=\"latin\">Second person<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">«شما می‌توانید…» نه «کاربران می‌توانند…». ارتباط، مستقیم است — حتی در ارتباطِ نهادی.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">عددِ فارسی<span class=\"latin\">Persian numerals<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">۱، ۲، ۳ — نه 1, 2, 3. مگر در زمینه‌ی برنامه‌نویسی، مستنداتِ فنی، یا APIها.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">بدونِ ایموجی در محصول<span class=\"latin\">No emoji in product UI<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">در کانال‌های اجتماعی، با اعتدال؛ در محصول، هیچ. وضعیت، با رنگ و آیکن مشخص می‌شود — نه با ایموجی.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">از منفی به مثبت بازنویسی<span class=\"latin\">Reframe to positive<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">«اشتباه نکنید» را به «به این نکته دقت کنید» تبدیل می‌کنیم. زبان، راه را نشان می‌دهد، نه اخطار را.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">عذرخواهیِ مستقیم<span class=\"latin\">Plain apologies<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">«متأسفیم. این از سمتِ ما بود. در حالِ رفعش هستیم.» — بدونِ توجیه، بدونِ پاسِ مسئولیت.<\u002Fdiv>\n      <\u002Fli>\n      <li>\n        <div class=\"term\">نامِ محصولات را با غرور به کار ببرید<span class=\"latin\">Honor product names<\u002Fspan><\u002Fdiv>\n        <div class=\"desc\">«چابک»، «تیام»، «همتا» — اسامیِ زنده هستند، نه برچسبِ خشک. در نوشتار، آن‌ها را با احترام و وضوح بنویسید. مثلاً: «از طریق <em style=\"font-style: normal; color: var(--indigo);\">چابک<\u002Fem>، تسویه در همین لحظه انجام می‌شود.»<\u002Fdiv>\n      <\u002Fli>\n    <\u002Ful>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- TONE DIAL -->\n<section class=\"page tint\" id=\"tone-dial\" data-screen-label=\"12 Tone Dial\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۲<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۲ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">تنظیمِ لحن<\u002Fh1>\n    <div class=\"title-en\">Tone Dial<\u002Fdiv>\n\n    <p class=\"lede\" style=\"max-width: 800px; margin-bottom: 32px;\">\n      لحنِ ما یک نقطه‌ی ثابت نیست؛ روی یک طیف می‌چرخد. بسته به اینکه با که حرف می‌زنیم — نهادِ مالی یا کاربرِ نهایی — و در چه کانالی، تنظیماتِ زیر را داریم.\n    <\u002Fp>\n\n    <div class=\"tone-dial\">\n      <h4>طیف لحن بسته به مخاطب<\u002Fh4>\n      <p class=\"sub\">نقطه‌ی پر رنگ، تنظیمِ پیش‌فرض برای هر مخاطب است. در عمل، می‌توانیم در ±۲۰٪ این نقطه نوسان کنیم.<\u002Fp>\n\n      <div class=\"scale-row\">\n        <div class=\"end\">رسمی<div class=\"tag\">Formal<\u002Fdiv><\u002Fdiv>\n        <div class=\"scale-track\">\n          <div class=\"b2b-dot\" style=\"right: 22%;\"><\u002Fdiv>\n          <div class=\"b2c-dot\" style=\"right: 60%;\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"end r\">صمیمی<div class=\"tag\">Casual<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"scale-row\">\n        <div class=\"end\">جدی<div class=\"tag\">Serious<\u002Fdiv><\u002Fdiv>\n        <div class=\"scale-track\">\n          <div class=\"b2b-dot\" style=\"right: 18%;\"><\u002Fdiv>\n          <div class=\"b2c-dot\" style=\"right: 65%;\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"end r\">سبک<div class=\"tag\">Playful<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"scale-row\">\n        <div class=\"end\">فنی<div class=\"tag\">Technical<\u002Fdiv><\u002Fdiv>\n        <div class=\"scale-track\">\n          <div class=\"b2b-dot\" style=\"right: 25%;\"><\u002Fdiv>\n          <div class=\"b2c-dot\" style=\"right: 75%;\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"end r\">روزمره<div class=\"tag\">Everyday<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"scale-row\">\n        <div class=\"end\">مفصل<div class=\"tag\">Detailed<\u002Fdiv><\u002Fdiv>\n        <div class=\"scale-track\">\n          <div class=\"b2b-dot\" style=\"right: 28%;\"><\u002Fdiv>\n          <div class=\"b2c-dot\" style=\"right: 70%;\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"end r\">مختصر<div class=\"tag\">Concise<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"scale-row\">\n        <div class=\"end\">محتاط<div class=\"tag\">Cautious<\u002Fdiv><\u002Fdiv>\n        <div class=\"scale-track\">\n          <div class=\"b2b-dot\" style=\"right: 38%;\"><\u002Fdiv>\n          <div class=\"b2c-dot\" style=\"right: 62%;\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"end r\">جسور<div class=\"tag\">Bold<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"tone-legend\">\n        <div class=\"item\"><span class=\"swatch\" style=\"background: var(--navy-1);\"><\u002Fspan>B2B · صندوق و کارگزاری و بانک<\u002Fdiv>\n        <div class=\"item\"><span class=\"swatch\" style=\"background: var(--coral);\"><\u002Fspan>B2C · کاربرِ کارت هدیه<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۱۲ · ۰۲<\u002Fspan>\n      <h2>تنظیماتِ کانال<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">وب‌سایت<\u002Fdiv>\n        <h3>اعتمادساز، تشریحی.<\u002Fh3>\n        <p>میانگینِ لحن: نزدیک به مرکزِ طیف. صفحه‌ی محصولاتِ نهادی (چابک، تیام، همتا) رسمی‌تر؛ صفحه‌ی کارت هدیه، گرم‌تر. صفحاتِ حقوقی و قراردادی، کاملاً رسمی هستند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">لینکدین · ارتباط نهادی<\u002Fdiv>\n        <h3>متخصص، آرام، با عمق.<\u002Fh3>\n        <p>به سمتِ آرکتایپِ فرزانه و حاکم می‌چرخیم. اعداد، کِیس‌استادی، مصاحبه با مدیرانِ صندوق‌ها. بدونِ ایموجی. جمله‌های کامل‌تر و پاراگراف‌های ساخت‌مند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">اینستاگرام · توییتر<\u002Fdiv>\n        <h3>گرم، چابک، آموزشی.<\u002Fh3>\n        <p>اینجا — به‌ویژه برای کارت هدیه — حق داریم گاهی لبخند بزنیم. اصطلاحاتِ روزمره. ایموجی به اعتدال، هرگز به اجبار. کپشن‌ها زیرِ ۸۰ کلمه.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- SAMPLES -->\n<section class=\"page\" id=\"samples\" data-screen-label=\"13 Voice Samples\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۳<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۳ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">نمونه‌های لحن<\u002Fh1>\n    <div class=\"title-en\">Voice in Practice<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 48px;\">\n      لحن، در مثال زنده می‌شود. این نمونه‌ها، یک قاعده‌ی عملی به دست می‌دهند که بقیه‌ی نوشته‌ها را بسازید.\n    <\u002Fp>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۱۳ · ۰۱<\u002Fspan>\n      <h2>صندوق · تیام<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"samples\">\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2b\">B2B<\u002Fspan><span>لینکدین · پست محصول<\u002Fspan><\u002Fdiv>\n        <blockquote>«تقسیم سودِ مردادِ یک صندوق با ۱۲ هزار سرمایه‌گذار، با تیام در ۳ ساعت و ۴۲ دقیقه انجام شد. این، رکوردِ دستی‌اش بود؛ این، استانداردِ تیام است.»<\u002Fblockquote>\n      <\u002Fdiv>\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2b\">B2B<\u002Fspan><span>ایمیلِ معرفی<\u002Fspan><\u002Fdiv>\n        <blockquote>«تقسیم سودِ ماهانه، بزرگ‌ترین پروژه‌ی عملیاتیِ صندوق شماست — هر بار. تیام، آن را به یک کارِ روزانه تبدیل می‌کند: امضاداران در سامانه تأیید می‌کنند، پرداختِ فله، در همان روز کار اجرا می‌شود. اگر مفید بود، یک جلسه‌ی ۳۰ دقیقه‌ای پیشنهاد می‌دهیم.»<\u002Fblockquote>\n      <\u002Fdiv>\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2b\">B2B<\u002Fspan><span>پیامِ موفقیت در سامانه<\u002Fspan><\u002Fdiv>\n        <blockquote>«تقسیم سود شماره ۲۸۴۵ ارسال شد. ۱۲٬۴۰۲ تراکنش در صف؛ پایانِ عملیات تا ساعت ۱۵:۲۰ تخمین زده می‌شود. گزارشِ زنده در داشبورد در دسترس است.»<\u002Fblockquote>\n      <\u002Fdiv>\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2b\">B2B<\u002Fspan><span>پاسخ به یک نگرانی<\u002Fspan><\u002Fdiv>\n        <blockquote>«پرسش به‌جایی است. اعتبارِ امضاهای دیجیتالِ تیام مورد تأییدِ سازمان بورس است و بر اساس همان استانداردی است که خودِ شما در حسابرسی پذیرفته‌اید. سندِ تأییدیه را همین حالا برایتان می‌فرستیم.»<\u002Fblockquote>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 48px;\">\n      <span class=\"glyph\">۱۳ · ۰۲<\u002Fspan>\n      <h2>کارگزاری · همتا<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"samples\">\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2b\">B2B<\u002Fspan><span>لینکدین · کِیس استادی<\u002Fspan><\u002Fdiv>\n        <blockquote>«یک کارگزاریِ بزرگ، سه کارمندِ تسویه را برای صفِ پایانیِ بازار اختصاص داده بود. با همتا، آن سه نفر امروز روی پروژه‌های ارزش‌افزوده کار می‌کنند. این، تعریفِ ما از اتوماسیون است.»<\u002Fblockquote>\n      <\u002Fdiv>\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2b\">B2B<\u002Fspan><span>مستنداتِ فنی<\u002Fspan><\u002Fdiv>\n        <blockquote>«درخواست‌های تسویه از طریق endpoint استاندارد ارسال می‌شود. پاسخ، در کمتر از ۲۰۰ میلی‌ثانیه برمی‌گردد. در صورتِ بروزِ خطا، سامانه به‌صورت idempotent، بازارسال را پذیرا است.»<\u002Fblockquote>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 48px;\">\n      <span class=\"glyph\">۱۳ · ۰۳<\u002Fspan>\n      <h2>کاربرِ نهایی · کارت هدیه<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"samples\">\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2c\">B2C<\u002Fspan><span>اینستاگرام · پست<\u002Fspan><\u002Fdiv>\n        <blockquote>«هدیه‌ای که با گذرِ زمان، یاد بهترش می‌شود. کارت هدیه‌ی بورسی، یک سهم را به نام عزیزانتان می‌گذارد — و کمک می‌کند ورودی‌شان به بازار سرمایه از یک تجربه‌ی گرم شروع شود.»<\u002Fblockquote>\n      <\u002Fdiv>\n      <div class=\"sample\">\n        <div class=\"ctx\"><span class=\"pill b2c\">B2C<\u002Fspan><span>پوش نوتیفیکیشن<\u002Fspan><\u002Fdiv>\n        <blockquote>«کارت هدیه‌ی شما فعال شد. سهمِ روی آن، از همین لحظه در بازار با شما همراه است.»<\u002Fblockquote>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- PYRAMID -->\n<section class=\"page tint\" id=\"pyramid\" data-screen-label=\"14 Brand Pyramid\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۴<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۴ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">هرمِ برند<\u002Fh1>\n    <div class=\"title-en\">Brand Pyramid<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      یک تصویرِ فشرده از همه‌چیز: از پایه‌ی محصولی تا قله‌ی جوهره. اگر تنها یک صفحه از این سند را همراه داشته باشید، این صفحه است.\n    <\u002Fp>\n\n    <div class=\"pyramid\">\n      <div class=\"level\">\n        <div class=\"k\"><span class=\"latin\">Functional Benefits<\u002Fspan><span class=\"fa\">منافع کارکردی<\u002Fspan><\u002Fdiv>\n        <div class=\"v\">تسویه‌ی آنی (T+۰) · اتوماسیونِ پرداختِ فله · امضای دیجیتال · اتصالِ ۲۱ بانک<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"level\">\n        <div class=\"k\"><span class=\"latin\">Emotional Benefits<\u002Fspan><span class=\"fa\">منافع احساسی<\u002Fspan><\u002Fdiv>\n        <div class=\"v\">آرامشِ خاطرِ مدیرِ مالی، اعتمادِ نهادی، حسِ همراهیِ یک شریکِ متخصص<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"level\">\n        <div class=\"k\"><span class=\"latin\">Personality<\u002Fspan><span class=\"fa\">شخصیت<\u002Fspan><\u002Fdiv>\n        <div class=\"v\">صداقت، صلاحیت، چابکی، باراندازی<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"level\">\n        <div class=\"k\"><span class=\"latin\">Values<\u002Fspan><span class=\"fa\">ارزش‌ها<\u002Fspan><\u002Fdiv>\n        <div class=\"v\">اعتمادِ موروثی، سرعتِ به مثابه‌ی خدمت، عمق‌نه‌گستره، معماری گشوده<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"level\">\n        <div class=\"k\"><span class=\"latin\">Positioning<\u002Fspan><span class=\"fa\">جایگاه‌یابی<\u002Fspan><\u002Fdiv>\n        <div class=\"v\">ریل‌های پرداختِ تخصصیِ بازار سرمایه — برای نهاد و فرد<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"level essence\">\n        <div class=\"k\"><span class=\"latin\">Essence<\u002Fspan><span class=\"fa\">جوهره<\u002Fspan><\u002Fdiv>\n        <div class=\"v\">پرداخت، آنی و تخصصی.<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- TAGLINE -->\n<section class=\"page dark\" id=\"tagline\" data-screen-label=\"15 Tagline\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۵<\u002Fspan><span>هویتِ کلامی · Voice<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۵ / ۱۵<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">شعارِ برند<\u002Fh1>\n    <div class=\"title-en\">Brand Tagline<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 16px;\">\n      شعارِ رایان هم‌افزا «ساختار امن، سرعت عمل، سهولت در کاربری» است. شعارِ بورس پی در همان روح، سه واژه‌ی ما را تعریف می‌کند:\n    <\u002Fp>\n\n    <div class=\"tagline-grid\">\n      <div class=\"word-card dark\" style=\"background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.10);\">\n        <div class=\"num\">۰۱<\u002Fdiv>\n        <div class=\"big\">آنی<\u002Fdiv>\n        <div class=\"latin\">Instant<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"word-card dark\" style=\"background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.10);\">\n        <div class=\"num\">۰۲<\u002Fdiv>\n        <div class=\"big\">امن<\u002Fdiv>\n        <div class=\"latin\">Secure<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"word-card dark\" style=\"background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.10);\">\n        <div class=\"num\">۰۳<\u002Fdiv>\n        <div class=\"big\">تخصصی<\u002Fdiv>\n        <div class=\"latin\">Specialist<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"final-quote\" style=\"margin-top: 24px; color: #fff;\">\n      <span class=\"em\" style=\"color: var(--sky);\">آنی، امن، تخصصی.<\u002Fspan>\n      <br>\n      بورس پی، ریل‌های پرداختِ بازار سرمایه.\n    <\u002Fp>\n\n    <div style=\"margin-top: 64px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.14); font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.5); display: flex; justify-content: space-between;\">\n      <div>End of Volume 1 · Strategy + Voice<\u002Fdiv>\n      <div>Volume 2 · Visual Identity — ادامه<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ============================================================\n     VOLUME 2 · VISUAL IDENTITY\n     ============================================================ -->\n\n<!-- VOL 2 DIVIDER -->\n<section class=\"page vol-divider\" id=\"vol2\" data-screen-label=\"16 Volume 2 — Visual Identity\">\n  <div class=\"vol-content\">\n    <div class=\"vol-num\">Volume Two — جلد دوم<\u002Fdiv>\n    <h2>هویتِ بصری<\u002Fh2>\n    <div class=\"vol-sub\">Visual Identity System<\u002Fdiv>\n    <div class=\"vol-line\"><\u002Fdiv>\n    <p class=\"vol-desc\">\n      اگر جلدِ اول، روحِ بورس پی را نوشت، جلدِ دوم چهره‌اش را می‌سازد. هر نشانه، هر رنگ، هر کلمه‌ای که با تایپ‌فیسِ ما نوشته می‌شود — همه سهمی در ذهنیتِ مخاطب دارند. این جلد، قواعدِ بازی است.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- LOGO SYSTEM -->\n<section class=\"page\" id=\"logo\" data-screen-label=\"17 Logo\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۷<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۷ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">سیستمِ لوگو<\u002Fh1>\n    <div class=\"title-en\">Logo System<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 48px;\">\n      نشانه‌ی برند، شناسنامه‌ی ماست. ساده، خوانا، با یک هندسه‌ی خاطره‌ساز: قوس‌هایی که از نقطه‌ی ورود به بازارِ سرمایه، به سمتِ نقدشوندگی پیشروی می‌کنند.\n    <\u002Fp>\n\n    <div class=\"logo-stage\">\n      <div class=\"display\">\n        <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" alt=\"Boorspay primary logo\">\n      <\u002Fdiv>\n      <div class=\"info\">\n        <h3>نشانه‌ی اصلی — نسخه‌ی روشن<\u002Fh3>\n        <p>نشانه‌ی پایه، روی پس‌زمینه‌های روشن. این نسخه، انتخابِ پیش‌فرض است. در همه‌ی اقلامِ چاپی، صفحه‌ی فرود، اسناد رسمی و فاکتورها استفاده می‌شود.<\u002Fp>\n        <div class=\"spec\">\n          نام: Boorspay Primary<br>\n          فرمت: PNG، SVG، PDF<br>\n          رنگ: Navy #0A0E2E + Sky #6F8FCE<br>\n          حداقل اندازه: ۲۴px ارتفاع\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"logo-stage dark\" style=\"margin-top: 16px;\">\n      <div class=\"display\">\n        <img src=\"e6688663-a5e4-451b-9c47-47d16f602127\" alt=\"Boorspay logo on dark\" style=\"\">\n      <\u002Fdiv>\n      <div class=\"info\">\n        <h3>نشانه‌ی اصلی — نسخه‌ی تیره<\u002Fh3>\n        <p>نشانه‌ی پایه، روی پس‌زمینه‌ی نیلیِ برند یا هر تنِ تیره‌ی دیگر. وقتی پس‌زمینه بیش از ۴۰٪ تیره است، این نسخه استفاده می‌شود.<\u002Fp>\n        <div class=\"spec\">\n          نام: Boorspay Inverse<br>\n          استفاده: کاور لینکدین، اسلایدِ تیتر، اوپن‌گراف، اپلیکیشن\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۱۷ · ۰۲<\u002Fspan>\n      <h2>کالبدِ نشانه<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">آرک‌ها · The Arcs<\u002Fdiv>\n        <h3>قوس‌های پلکانی<\u002Fh3>\n        <p>سه قوسِ هم‌مرکز که نشانه‌ی پیشروی، رشد و اتصال هستند. هر قوس می‌تواند نمایانگرِ یکی از سه مخاطبِ ما باشد: صندوق، کارگزاری، بانک.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">نوشتاره · Wordmark<\u002Fdiv>\n        <h3>«بورس پی»<\u002Fh3>\n        <p>به‌صورت دو واژه‌ی مجزا — نه با نیم‌فاصله. «بورس» میراثِ صنعت ماست؛ «پی» قولِ ما در زمینه‌ی پرداخت. فاصله‌ی بینِ این دو، عمدی است.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">رابطه · Composition<\u002Fdiv>\n        <h3>نشانه + نوشتار<\u002Fh3>\n        <p>نشانه‌ی گرافیکی و نوشتاره با یک نسبتِ ثابت کنارِ هم می‌نشینند. این نسبت در همه‌ی اندازه‌ها حفظ می‌شود — هیچ‌گاه یکی را بدونِ دیگری بزرگ یا کوچک نمی‌کنیم.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- CLEARSPACE -->\n<section class=\"page tint\" id=\"clearspace\" data-screen-label=\"18 Clearspace\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۸<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۸ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">فضای امن و اندازه‌ها<\u002Fh1>\n    <div class=\"title-en\">Clearspace &amp; Sizing<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 48px;\">\n      نشانه، اتاقِ نفس می‌خواهد. فضای امن، حداقلِ فاصله‌ای است که هیچ عنصرِ دیگری نباید واردِ آن شود.\n    <\u002Fp>\n\n    <div class=\"clearspace\">\n      <div class=\"stage\">\n        <div class=\"grid-marks\"><\u002Fdiv>\n        <div class=\"logo-box\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" alt=\"Logo with clearspace\">\n        <\u002Fdiv>\n        <div class=\"x-mark x-top\">x<\u002Fdiv>\n        <div class=\"x-mark x-bot\">x<\u002Fdiv>\n        <div class=\"x-mark x-left\">x<\u002Fdiv>\n        <div class=\"x-mark x-right\">x<\u002Fdiv>\n      <\u002Fdiv>\n      <div>\n        <dl class=\"spec-list\">\n          <dt>واحد اندازه‌گیری<\u002Fdt>\n          <dd><code>x<\u002Fcode> برابر است با ارتفاعِ نشانه‌ی گرافیکیِ آرک‌ها (بدونِ نوشتاره).<\u002Fdd>\n\n          <dt>فضای امنِ پیش‌فرض<\u002Fdt>\n          <dd>حداقل <code>۱x<\u002Fcode> در هر چهار طرفِ نشانه. این فضا، هرگز نباید با عنصر دیگر (متن، تصویر، خط) اشغال شود.<\u002Fdd>\n\n          <dt>فضای امنِ ممتاز<\u002Fdt>\n          <dd>در اقلامِ نمایشیِ کلیدی (کاور، تابلو، صفحه‌ی اولِ اسناد رسمی)، فضای امن را به <code>۲x<\u002Fcode> افزایش دهید.<\u002Fdd>\n\n          <dt>گوشه‌ها<\u002Fdt>\n          <dd>نشانه هرگز نباید به گوشه‌ی پیج «چسبیده» باشد. فاصله از لبه‌ها، حداقل <code>۱.۵x<\u002Fcode> است.<\u002Fdd>\n        <\u002Fdl>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۱۸ · ۰۲<\u002Fspan>\n      <h2>اندازه‌های استاندارد<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"sizes\">\n      <div class=\"size-card\">\n        <div class=\"preview\"><img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\"><\u002Fdiv>\n        <div class=\"name\">Display<\u002Fdiv>\n        <div class=\"dim\">≥ 160px · کاور و بنرها<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"size-card\">\n        <div class=\"preview\"><img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"height: 70%; width: auto;\"><\u002Fdiv>\n        <div class=\"name\">Standard<\u002Fdiv>\n        <div class=\"dim\">64–160px · هدر، فوتر<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"size-card\">\n        <div class=\"preview\"><img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"height: 50%; width: auto;\"><\u002Fdiv>\n        <div class=\"name\">Compact<\u002Fdiv>\n        <div class=\"dim\">32–64px · کارت ویزیت، امضا<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"size-card\">\n        <div class=\"preview\"><img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"height: 36%; width: auto;\"><\u002Fdiv>\n        <div class=\"name\">Minimum<\u002Fdiv>\n        <div class=\"dim\">24px · کمتر مجاز نیست<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 24px; max-width: 760px;\">\n      <strong style=\"color: var(--navy-1);\">قاعده‌ی طلایی:<\u002Fstrong>\n      اگر نشانه را در کوچک‌ترین اندازه‌ای که قرار است در آن دیده شود، نمی‌توانید بخوانید — اندازه را افزایش دهید یا از نسخه‌ی تک‌آرکیِ نشانه (بدونِ نوشتاره) استفاده کنید.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- LOGO RULES -->\n<section class=\"page\" id=\"logo-rules\" data-screen-label=\"19 Logo Rules\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۱۹<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۱۹ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">بایدها و نبایدها<\u002Fh1>\n    <div class=\"title-en\">Logo Dos &amp; Don'ts<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      نشانه، یک تصمیمِ طراحیِ تمام‌شده است. تغییر، چرخش، رنگ‌آمیزیِ خودسرانه یا جاسازی در پس‌زمینه‌ی شلوغ، اعتبارِ آن را خراب می‌کند.\n    <\u002Fp>\n\n    <div class=\"logo-rules\">\n      <div class=\"rule-card no\">\n        <div class=\"ex\" style=\"background: #FFD1D1;\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\">\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>روی پس‌زمینه‌ی رنگیِ غیرِبرند<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"rule-card no\">\n        <div class=\"ex\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"transform: rotate(-15deg);\">\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>چرخش، کجی یا اعوجاج<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"rule-card no\">\n        <div class=\"ex\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"transform: scaleX(1.6);\">\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>کشش یا تغییرِ نسبت<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"rule-card no\">\n        <div class=\"ex\" style=\"background: linear-gradient(135deg, #FF6B9D, #FFD93D);\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\">\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>گرادیان یا پس‌زمینه‌ی شلوغ<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"rule-card no\">\n        <div class=\"ex\" style=\"background: #FFF;\">\n          <div style=\"display: flex; align-items: center; gap: 12px;\">\n            <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"width: 50px;\">\n            <div style=\"font-family: var(--f-display); font-weight: 700; font-size: 18px; color: var(--navy-1);\">بورس پی<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>افزودنِ نوشتارِ مضاعف<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"rule-card no\">\n        <div class=\"ex\" style=\"background: #0A0E2E;\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\">\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>نسخه‌ی روشن روی پس‌زمینه‌ی تیره<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"rule-card no\">\n        <div class=\"ex\" style=\"background: linear-gradient(45deg, #FFF 50%, #C8D6EC 50%);\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\">\n        <\u002Fdiv>\n        <div class=\"caption\"><span class=\"mark\">×<\u002Fspan>پس‌زمینه‌ی دوتنه یا تصویری<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 56px;\">\n      <span class=\"glyph\">۱۹ · ۰۲<\u002Fspan>\n      <h2>پس‌زمینه‌های مجاز<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-4\" style=\"margin-top: 24px;\">\n      <div style=\"background: var(--paper); border: 1px solid var(--hairline); aspect-ratio: 1; border-radius: 12px; display: grid; place-items: center;\">\n        <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"width: 60%;\">\n      <\u002Fdiv>\n      <div style=\"background: var(--paper-2); aspect-ratio: 1; border-radius: 12px; display: grid; place-items: center;\">\n        <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"width: 60%;\">\n      <\u002Fdiv>\n      <div style=\"background: var(--cloud); aspect-ratio: 1; border-radius: 12px; display: grid; place-items: center;\">\n        <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"width: 60%;\">\n      <\u002Fdiv>\n      <div style=\"background: var(--navy-1); aspect-ratio: 1; border-radius: 12px; display: grid; place-items: center;\">\n        <img src=\"e6688663-a5e4-451b-9c47-47d16f602127\" style=\"width: 60%; \">\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- PALETTE -->\n<section class=\"page tint\" id=\"palette\" data-screen-label=\"20 Color Palette\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۰<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۰ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">پالتِ رنگ<\u002Fh1>\n    <div class=\"title-en\">Color Palette<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      پالتِ ما، از لوگو زاده شده: عمقِ نیلیِ بازار سرمایه، با درخششِ آسمانیِ پرداختِ آنی. کم، انتخابی، تمرکزآفرین.\n    <\u002Fp>\n\n    <div class=\"palette-hero\">\n      <div class=\"swatch-big feature\" style=\"background: var(--navy-1);\">\n        <div>\n          <div class=\"role\">Primary · رنگ اصلی<\u002Fdiv>\n          <div class=\"name\">نیلیِ ژرف<\u002Fdiv>\n          <div class=\"hex\">#0A0E2E · Navy 1<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"swatch-big\" style=\"background: var(--navy-2);\">\n        <div class=\"role\">Secondary<\u002Fdiv>\n        <div class=\"name\">نیلی<\u002Fdiv>\n        <div class=\"hex\">#1B1F66<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"swatch-big\" style=\"background: var(--indigo);\">\n        <div class=\"role\">Accent<\u002Fdiv>\n        <div class=\"name\">ایندیگو<\u002Fdiv>\n        <div class=\"hex\">#2A2D7E<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"swatch-big light\" style=\"background: var(--sky);\">\n        <div class=\"role\">Highlight<\u002Fdiv>\n        <div class=\"name\">آسمانی<\u002Fdiv>\n        <div class=\"hex\">#6F8FCE<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۰ · ۰۲<\u002Fspan>\n      <h2>پالتِ پشتیبان<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"palette-hero\" style=\"grid-template-columns: 1fr 1fr 1fr; min-height: 200px;\">\n      <div class=\"swatch-big light\" style=\"background: var(--mist);\">\n        <div class=\"role\">Support<\u002Fdiv>\n        <div class=\"name\">مه<\u002Fdiv>\n        <div class=\"hex\">#C8D6EC<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"swatch-big light\" style=\"background: var(--cloud);\">\n        <div class=\"role\">Surface<\u002Fdiv>\n        <div class=\"name\">ابر<\u002Fdiv>\n        <div class=\"hex\">#F2F5FB<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"swatch-big light\" style=\"background: var(--paper); border: 1px solid var(--hairline);\">\n        <div class=\"role\">Canvas<\u002Fdiv>\n        <div class=\"name\">سفید<\u002Fdiv>\n        <div class=\"hex\">#FFFFFF<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۰ · ۰۳<\u002Fspan>\n      <h2>پالتِ تأکیدی — مصرفِ بسیار محدود<\u002Fh2>\n    <\u002Fdiv>\n\n    <p class=\"body\" style=\"margin-bottom: 16px;\">این دو رنگ، تنها برای موقعیت‌های خاص استفاده می‌شوند. کرال، در محصولِ B2C کارت هدیه؛ سبز، برای پیامِ موفقیت در محصولِ نهادی.<\u002Fp>\n\n    <div class=\"palette-hero\" style=\"grid-template-columns: 1fr 1fr; min-height: 180px;\">\n      <div class=\"swatch-big\" style=\"background: var(--coral);\">\n        <div class=\"role\">B2C Accent · کرال<\u002Fdiv>\n        <div class=\"name\">کرالِ گرم<\u002Fdiv>\n        <div class=\"hex\">#E0744A · فقط کارت هدیه<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"swatch-big\" style=\"background: var(--emerald);\">\n        <div class=\"role\">Success · سبز<\u002Fdiv>\n        <div class=\"name\">زمرد<\u002Fdiv>\n        <div class=\"hex\">#1F8A5B · پیامِ موفقیت<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۰ · ۰۴<\u002Fspan>\n      <h2>طیفِ خاکستری<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"neutrals\">\n      <div class=\"neutral\" style=\"background: var(--ink); color: #fff;\">\n        <div class=\"nm\">Ink<\u002Fdiv>\n        <div class=\"hx\">#0A0E2E<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--ink-2); color: #fff;\">\n        <div class=\"nm\">Ink-2<\u002Fdiv>\n        <div class=\"hx\">#2B3157<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--ink-3); color: #fff;\">\n        <div class=\"nm\">Ink-3<\u002Fdiv>\n        <div class=\"hx\">#6C7290<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--ink-4); color: var(--navy-1);\">\n        <div class=\"nm\">Ink-4<\u002Fdiv>\n        <div class=\"hx\">#A6ACC4<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--mist); color: var(--navy-1);\">\n        <div class=\"nm\">Mist<\u002Fdiv>\n        <div class=\"hx\">#C8D6EC<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--cloud); color: var(--navy-1);\">\n        <div class=\"nm\">Cloud<\u002Fdiv>\n        <div class=\"hx\">#F2F5FB<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--paper-2); color: var(--navy-1); border: 1px solid var(--hairline);\">\n        <div class=\"nm\">Paper-2<\u002Fdiv>\n        <div class=\"hx\">#FAFBFE<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"neutral\" style=\"background: var(--paper); color: var(--navy-1); border: 1px solid var(--hairline);\">\n        <div class=\"nm\">Paper<\u002Fdiv>\n        <div class=\"hx\">#FFFFFF<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- COLOR USAGE -->\n<section class=\"page\" id=\"color-use\" data-screen-label=\"21 Color Usage\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۱<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۱ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">کاربردِ رنگ<\u002Fh1>\n    <div class=\"title-en\">Color Application<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      پالت کم، با نسبتِ مشخص. عدمِ رعایتِ این نسبت، اصلی‌ترین دلیلِ بی‌نظمیِ بصری در پروژه‌های برند است.\n    <\u002Fp>\n\n    <div class=\"section-head\" style=\"margin-top: 16px;\">\n      <span class=\"glyph\">۲۱ · ۰۱<\u002Fspan>\n      <h2>قاعده‌ی ۶۰ / ۳۰ / ۱۰<\u002Fh2>\n    <\u002Fdiv>\n\n    <p class=\"body\" style=\"margin-bottom: 0;\">در هر طراحی، نسبتِ تقریبیِ زیر را حفظ کنید. این، تضمین می‌کند که هویتِ ما حتی در یک نگاهِ یک‌ثانیه‌ای، خوانا و شناختنی باشد.<\u002Fp>\n\n    <div class=\"usage-bar\">\n      <div class=\"seg light\" style=\"background: var(--paper); flex: 60; border-left: 1px solid var(--hairline);\">۶۰٪ — سفید / ابر<\u002Fdiv>\n      <div class=\"seg\" style=\"background: var(--navy-1); flex: 30;\">۳۰٪ — نیلیِ ژرف<\u002Fdiv>\n      <div class=\"seg\" style=\"background: var(--indigo); flex: 8;\">۸٪ — ایندیگو<\u002Fdiv>\n      <div class=\"seg\" style=\"background: var(--sky); color: var(--navy-1); flex: 2;\">۲٪<\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۱ · ۰۲<\u002Fspan>\n      <h2>قواعدِ ترکیب<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-2\">\n      <div class=\"card\">\n        <div class=\"label\">سطحِ پایه<\u002Fdiv>\n        <h3>سفید بر نیلی، نیلی بر سفید.<\u002Fh3>\n        <p>هر طراحی، یا نیلی‌محور است (پس‌زمینه‌ی نیلی، نوشته‌ی سفید) یا روشن‌محور (پس‌زمینه‌ی سفید، نوشته‌ی نیلی). ترکیبِ این دو در یک صفحه، با خطِ مرزِ روشن.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">تأکید<\u002Fdiv>\n        <h3>ایندیگو، سپس آسمانی.<\u002Fh3>\n        <p>برای تأکیدِ جزئی، ایندیگو. برای درخششِ بصری (لینک، اعداد، آیکن)، آسمانی. هرگز این دو را در یک عنصر باهم استفاده نکنید.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">B2C — استثنا<\u002Fdiv>\n        <h3>کرال، فقط در کارت هدیه.<\u002Fh3>\n        <p>کرالِ گرم، تنها در طراحی‌های کارت هدیه و کانال‌های B2C نشان می‌شود. وارد کردنِ کرال به طراحیِ نهادی، حسِ اعتمادِ آن را خراب می‌کند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">سبزِ زمرد — وضعیت<\u002Fdiv>\n        <h3>سبز، فقط برای موفقیت.<\u002Fh3>\n        <p>سبزِ زمردِ ما، یک رنگِ functional است، نه برندی. تنها برای پیام‌های موفقیت در رابطِ کاربری استفاده می‌شود. هرگز در بازاریابی به کار نمی‌رود.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۱ · ۰۳<\u002Fspan>\n      <h2>گرادیان امضایی<\u002Fh2>\n    <\u002Fdiv>\n\n    <p class=\"body\" style=\"margin-bottom: 16px;\">یک گرادیان رسمی، فقط برای موقعیتِ ممتاز — کاور لینکدین، اسلایدِ تیتر، و موقعیت‌های ویدئویی.<\u002Fp>\n\n    <div style=\"margin-top: 16px; height: 140px; border-radius: 16px; background: linear-gradient(135deg, var(--navy-1) 0%, var(--indigo) 50%, var(--sky) 100%); display: flex; align-items: end; padding: 24px; color: #fff; font-family: var(--f-mono); font-size: 12px;\">\n      linear-gradient(135deg, #0A0E2E 0%, #2A2D7E 50%, #6F8FCE 100%)\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- TYPE FA -->\n<section class=\"page tint\" id=\"type-fa\" data-screen-label=\"22 Persian Type\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۲<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۲ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">تایپ‌فیسِ فارسی<\u002Fh1>\n    <div class=\"title-en\">Persian Typeface<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      صدای نوشتاریِ ما، در حروف زندگی می‌کند. تایپ‌فیسِ ما، خوانا، مدرن و حرفه‌ای است — متناسب با شخصیتِ نهادیِ ما.\n    <\u002Fp>\n\n    <div class=\"specimen\">\n      <div class=\"meta\">\n        <div class=\"face-name\">وزیرمتن<\u002Fdiv>\n        <div class=\"face-tag\">Vazirmatn · Primary Persian<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"big-char\">آ ب پ<\u002Fdiv>\n\n      <div class=\"weights\">\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Light · 300<\u002Fdiv>\n          <div class=\"sample\" style=\"font-weight: 300;\">پرداختِ آنی برای صندوق‌های سرمایه‌گذاری<\u002Fdiv>\n          <div class=\"num\">۳۰۰<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Regular · 400<\u002Fdiv>\n          <div class=\"sample\" style=\"font-weight: 400;\">پرداختِ آنی برای صندوق‌های سرمایه‌گذاری<\u002Fdiv>\n          <div class=\"num\">۴۰۰<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Medium · 500<\u002Fdiv>\n          <div class=\"sample\" style=\"font-weight: 500;\">پرداختِ آنی برای صندوق‌های سرمایه‌گذاری<\u002Fdiv>\n          <div class=\"num\">۵۰۰<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">SemiBold · 600<\u002Fdiv>\n          <div class=\"sample\" style=\"font-weight: 600;\">پرداختِ آنی برای صندوق‌های سرمایه‌گذاری<\u002Fdiv>\n          <div class=\"num\">۶۰۰<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Bold · 700<\u002Fdiv>\n          <div class=\"sample\" style=\"font-weight: 700;\">پرداختِ آنی برای صندوق‌های سرمایه‌گذاری<\u002Fdiv>\n          <div class=\"num\">۷۰۰<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Black · 800<\u002Fdiv>\n          <div class=\"sample\" style=\"font-weight: 800;\">پرداختِ آنی برای صندوق‌های سرمایه‌گذاری<\u002Fdiv>\n          <div class=\"num\">۸۰۰<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\" style=\"margin-top: 24px;\">\n      <div class=\"card\">\n        <div class=\"label\">نقش<\u002Fdiv>\n        <h3>تیتر و متن<\u002Fh3>\n        <p>وزیرمتن، هم برای تیترهای درشت و هم برای متنِ بدنه استفاده می‌شود. تنوعِ وزن، کافی برای ساختِ سلسله‌مراتب بصری است.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">دلیلِ انتخاب<\u002Fdiv>\n        <h3>متن‌باز و حرفه‌ای<\u002Fh3>\n        <p>وزیرمتن، یک فونتِ متن‌باز با کیفیتِ نشر است. روی همه‌ی سیستم‌عامل‌ها قابلِ استفاده، و در وب با Google Fonts فوراً قابلِ بارگذاری.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">فاصله‌گذاری<\u002Fdiv>\n        <h3>letter-spacing: -0.01em<\u002Fh3>\n        <p>برای تیترهای بزرگ، فاصله‌ی حروف را اندکی کم می‌کنیم تا فشردگیِ مدرن حفظ شود. برای متنِ بدنه، مقدارِ پیش‌فرض را تغییر نمی‌دهیم.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- TYPE EN -->\n<section class=\"page dark\" id=\"type-en\" data-screen-label=\"23 Latin Type\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۳<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۳ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">تایپ‌فیسِ لاتین<\u002Fh1>\n    <div class=\"title-en\">Latin Typeface<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      برای متنِ لاتین، یک ترکیبِ دو فونتی استفاده می‌کنیم: یک serif سرمت برای ژستِ تشریفاتی، و یک sans-serif مدرن برای متنِ کاربردی.\n    <\u002Fp>\n\n    <div class=\"specimen dark\">\n      <div class=\"meta\">\n        <div class=\"face-name\" style=\"font-family: var(--f-en-display); font-style: italic;\">DM Serif Display<\u002Fdiv>\n        <div class=\"face-tag\">Display · For statements &amp; accents<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"big-char\" style=\"font-family: var(--f-en-display); font-style: italic;\">Aa Bb<\u002Fdiv>\n\n      <div class=\"weights\">\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Regular Italic<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-display); font-style: italic; font-weight: 400;\">The Payment Rails of Capital Markets<\u002Fdiv>\n          <div class=\"num\">400 italic<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Regular<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-display); font-weight: 400;\">The Payment Rails of Capital Markets<\u002Fdiv>\n          <div class=\"num\">400<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"specimen\" style=\"margin-top: 16px;\">\n      <div class=\"meta\">\n        <div class=\"face-name\" style=\"font-family: var(--f-en-body);\">DM Sans<\u002Fdiv>\n        <div class=\"face-tag\">Body · For UI &amp; technical text<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"big-char\" style=\"font-family: var(--f-en-body); font-weight: 700;\">Aa Bb<\u002Fdiv>\n\n      <div class=\"weights\">\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Light · 300<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-body); font-weight: 300;\">Instant settlement for capital market institutions<\u002Fdiv>\n          <div class=\"num\">300<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Regular · 400<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-body); font-weight: 400;\">Instant settlement for capital market institutions<\u002Fdiv>\n          <div class=\"num\">400<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Medium · 500<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-body); font-weight: 500;\">Instant settlement for capital market institutions<\u002Fdiv>\n          <div class=\"num\">500<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">SemiBold · 600<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-body); font-weight: 600;\">Instant settlement for capital market institutions<\u002Fdiv>\n          <div class=\"num\">600<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"wt-row\">\n          <div class=\"label-w\">Bold · 700<\u002Fdiv>\n          <div class=\"sample\" style=\"font-family: var(--f-en-body); font-weight: 700;\">Instant settlement for capital market institutions<\u002Fdiv>\n          <div class=\"num\">700<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- TYPE SCALE -->\n<section class=\"page\" id=\"type-scale\" data-screen-label=\"24 Type Scale\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۴<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۴ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">مقیاسِ تایپ<\u002Fh1>\n    <div class=\"title-en\">Type Scale<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      سلسله‌مراتبِ تایپ، در یک مقیاسِ هارمونیک ساخته شده است. نسبتِ تقریباً ۱.۲۵× بین سطوحِ مجاور.\n    <\u002Fp>\n\n    <div class=\"scale-ladder\">\n      <div class=\"scale-step\">\n        <div class=\"tag\">Display<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 84px;\">سرتیتر<\u002Fdiv>\n        <div class=\"spec\">84px / 92px · 800 · -0.03em<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">H1<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 56px;\">سرتیتر صفحه<\u002Fdiv>\n        <div class=\"spec\">56px / 64px · 700 · -0.025em<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">H2<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 36px;\">سرتیتر بخش<\u002Fdiv>\n        <div class=\"spec\">36px / 44px · 700 · -0.02em<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">H3<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 26px;\">سرتیتر کارت<\u002Fdiv>\n        <div class=\"spec\">26px / 34px · 600 · -0.015em<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">Lede<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 21px; font-weight: 400; line-height: 1.6;\">بندِ شروع<\u002Fdiv>\n        <div class=\"spec\">21px / 34px · 400 · 0<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">Body<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 16px; font-weight: 400; line-height: 1.75;\">متنِ بدنه‌ی روزمره<\u002Fdiv>\n        <div class=\"spec\">16px / 28px · 400 · 0<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">Small<\u002Fdiv>\n        <div class=\"demo\" style=\"font-size: 13px; font-weight: 400; color: var(--ink-3);\">متنِ کوچک — کپشن و یادداشت<\u002Fdiv>\n        <div class=\"spec\">13px / 20px · 400 · 0<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"scale-step\">\n        <div class=\"tag\">Eyebrow<\u002Fdiv>\n        <div class=\"demo\" style=\"font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--indigo); font-weight: 600;\">EYEBROW · OVERLINE<\u002Fdiv>\n        <div class=\"spec\">11px · 600 · 0.18em<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۴ · ۰۲<\u002Fspan>\n      <h2>قواعدِ مهم<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">۰۱<\u002Fdiv>\n        <h3>فقط ۳ سطح در یک صفحه<\u002Fh3>\n        <p>هرگز در یک صفحه بیش از سه سایزِ مختلف از تایپ استفاده نکنید. این، نظمِ بصری را تضمین می‌کند.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۲<\u002Fdiv>\n        <h3>text-wrap: balance<\u002Fh3>\n        <p>برای تیترهای دو خط و بالاتر، از <code style=\"font-family: var(--f-mono); font-size: 12px;\">text-wrap: balance<\u002Fcode> استفاده کنید تا توزیعِ خوبی داشته باشد.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۳<\u002Fdiv>\n        <h3>اعداد، tabular-nums<\u002Fh3>\n        <p>در جداول و گزارش‌های مالی، حتماً <code style=\"font-family: var(--f-mono); font-size: 12px;\">tnum<\u002Fcode> را فعال کنید تا اعداد عمودی هم‌تراز شوند.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- MOTIF -->\n<section class=\"page tint\" id=\"motif\" data-screen-label=\"25 Arc Motif\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۵<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۵ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">نقش‌مایه‌ی Arc<\u002Fh1>\n    <div class=\"title-en\">The Arc Motif<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      قوس‌های پلکانیِ لوگو، نقش‌مایه‌ی برندِ ما هستند. آن‌ها می‌توانند بزرگ شوند، بشکنند، تکرار شوند و در هر طراحی‌ای جانِ تازه بگیرند — اما همیشه به سرچشمه‌ی خود وفادار می‌مانند.\n    <\u002Fp>\n\n    <div class=\"motif\">\n      <div class=\"canvas\">\n        <svg viewBox=\"0 0 400 400\" style=\"width: 100%; height: 100%;\" fill=\"none\" stroke=\"#2A2D7E\" stroke-width=\"1.5\">\n          <path d=\"M40 360 A 320 320 0 0 1 360 40\"><\u002Fpath>\n          <path d=\"M40 300 A 260 260 0 0 1 300 40\"><\u002Fpath>\n          <path d=\"M40 240 A 200 200 0 0 1 240 40\"><\u002Fpath>\n          <path d=\"M40 180 A 140 140 0 0 1 180 40\"><\u002Fpath>\n          <path d=\"M40 120 A 80 80 0 0 1 120 40\"><\u002Fpath>\n          <circle cx=\"40\" cy=\"40\" r=\"3\" fill=\"#2A2D7E\" stroke=\"none\"><\u002Fcircle>\n        <\u002Fsvg>\n      <\u002Fdiv>\n      <div class=\"info\">\n        <h3>قاعده‌ی پایه<\u002Fh3>\n        <p>قوس‌ها همیشه از یک نقطه‌ی مرجع (معمولاً گوشه‌ی پایین-راست در RTL) شروع می‌شوند و به سمتِ بیرون گسترش می‌یابند. این، حسِ «پیشرویِ مستمر» را منتقل می‌کند.<\u002Fp>\n        <p>تعدادِ قوس‌ها، انعطاف‌پذیر است: ۳ تا ۷ قوس. فاصله‌ی بینِ آن‌ها، ثابت یا پلکانی.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۵ · ۰۲<\u002Fspan>\n      <h2>کاربردهای نقش‌مایه<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"motif-uses\">\n      <div class=\"motif-use\" style=\"background: var(--navy-1);\">\n        <svg viewBox=\"0 0 400 300\" style=\"width: 100%; height: 100%;\" fill=\"none\" stroke=\"#6F8FCE\" stroke-width=\"1.2\" opacity=\"0.4\">\n          <path d=\"M0 250 A 280 280 0 0 1 280 -30\"><\u002Fpath>\n          <path d=\"M0 200 A 230 230 0 0 1 230 -30\"><\u002Fpath>\n          <path d=\"M0 150 A 180 180 0 0 1 180 -30\"><\u002Fpath>\n          <path d=\"M0 100 A 130 130 0 0 1 130 -30\"><\u002Fpath>\n        <\u002Fsvg>\n        <span class=\"label\" style=\"background: rgba(10,14,46,0.7); color: var(--sky); backdrop-filter: blur(8px);\">پس‌زمینه‌ی کاور<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"motif-use\" style=\"background: var(--paper); display: grid; place-items: center;\">\n        <svg viewBox=\"0 0 200 200\" style=\"width: 70%; height: 70%;\" fill=\"none\" stroke=\"#2A2D7E\" stroke-width=\"2\">\n          <path d=\"M20 180 A 160 160 0 0 1 180 20\"><\u002Fpath>\n          <path d=\"M20 130 A 110 110 0 0 1 130 20\"><\u002Fpath>\n          <path d=\"M20 80 A 60 60 0 0 1 80 20\"><\u002Fpath>\n        <\u002Fsvg>\n        <span class=\"label\">آیکنِ بخش<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"motif-use\" style=\"background: linear-gradient(135deg, var(--indigo), var(--sky)); position: relative; overflow: hidden;\">\n        <svg viewBox=\"0 0 400 300\" style=\"position: absolute; bottom: 0; left: 0; width: 100%; height: 100%;\" fill=\"none\" stroke=\"#fff\" stroke-width=\"1\" opacity=\"0.35\">\n          <path d=\"M0 300 A 360 360 0 0 1 360 -60\"><\u002Fpath>\n          <path d=\"M0 240 A 300 300 0 0 1 300 -60\"><\u002Fpath>\n          <path d=\"M0 180 A 240 240 0 0 1 240 -60\"><\u002Fpath>\n        <\u002Fsvg>\n        <span class=\"label\" style=\"background: rgba(255,255,255,0.9);\">گرادیان امضایی<\u002Fspan>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 24px; max-width: 800px;\">\n      <strong style=\"color: var(--navy-1);\">قاعده‌های مهم:<\u002Fstrong>\n      نقش‌مایه‌ی Arc هرگز در پیش‌زمینه (روی متن) نمی‌نشیند. همیشه پشتِ متن، با شفافیتِ بین ۲۵٪ تا ۴۵٪ استفاده می‌شود. در طراحی‌های B2B از رنگِ آسمانی روی نیلی؛ در طراحی‌های B2C می‌توان از کرال بهره برد.\n    <\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- DOT & LINE SYSTEM -->\n<section class=\"page\" id=\"graphics\" data-screen-label=\"26 Dot &amp; Line System\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۶<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۶ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">نقطه و خط<\u002Fh1>\n    <div class=\"title-en\">Dot &amp; Line · The Core Element<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      تمامِ گرافیکِ کمکیِ ما، از یک ایده ساخته می‌شود: <em style=\"font-style: normal; color: var(--indigo);\">یک نقطه‌ی پُر، روی یک خطِ منحنی، در حالِ حرکت<\u002Fem>. این، استعاره‌ی مستقیمِ کارِ ماست — جابه‌جاییِ یک پرداخت، روی ریلِ ما.\n    <\u002Fp>\n\n    <!-- Hero animation — dot truly travels along the curve via animateMotion -->\n    <div style=\"background: var(--paper); border: 1px solid var(--hairline); border-radius: var(--r-xl); padding: 56px; position: relative; overflow: hidden; margin-bottom: 32px;\">\n      <svg viewBox=\"0 0 800 200\" style=\"width: 100%; height: 200px;\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <defs>\n          <path id=\"hero-curve\" d=\"M 60 140 Q 240 30, 410 100 T 740 80\"><\u002Fpath>\n        <\u002Fdefs>\n        <!-- Background dashed reference path -->\n        <use href=\"#hero-curve\" stroke=\"#2A2D7E\" stroke-width=\"1.3\" stroke-dasharray=\"3 6\" opacity=\"0.25\"><\u002Fuse>\n        <!-- Solid path -->\n        <use href=\"#hero-curve\" stroke=\"#2A2D7E\" stroke-width=\"1.8\"><\u002Fuse>\n        <!-- Origin dot -->\n        <circle cx=\"60\" cy=\"140\" r=\"6\" fill=\"#2A2D7E\"><\u002Fcircle>\n        <!-- Destination dot with halo -->\n        <circle cx=\"740\" cy=\"80\" r=\"6\" fill=\"#6F8FCE\"><\u002Fcircle>\n        <circle cx=\"740\" cy=\"80\" r=\"12\" stroke=\"#6F8FCE\" stroke-width=\"1\" opacity=\"0.4\"><\u002Fcircle>\n        <!-- Moving dot that follows the curve -->\n        <circle r=\"9\" fill=\"#2A2D7E\">\n          <animateMotion dur=\"3.4s\" repeatCount=\"indefinite\" calcMode=\"spline\" keyTimes=\"0; 0.78; 1\" keyPoints=\"0; 1; 1\" keySplines=\"0.22 1 0.36 1; 0 0 1 1\">\n            <mpath href=\"#hero-curve\"><\u002Fmpath>\n          <\u002FanimateMotion>\n          <animate attributeName=\"opacity\" dur=\"3.4s\" repeatCount=\"indefinite\" values=\"0;1;1;0;0\" keyTimes=\"0;0.08;0.72;0.82;1\"><\u002Fanimate>\n        <\u002Fcircle>\n        <!-- Soft trailing dot a bit behind -->\n        <circle r=\"5\" fill=\"#2A2D7E\" opacity=\"0.4\">\n          <animateMotion dur=\"3.4s\" begin=\"-0.18s\" repeatCount=\"indefinite\" calcMode=\"spline\" keyTimes=\"0; 0.78; 1\" keyPoints=\"0; 1; 1\" keySplines=\"0.22 1 0.36 1; 0 0 1 1\">\n            <mpath href=\"#hero-curve\"><\u002Fmpath>\n          <\u002FanimateMotion>\n          <animate attributeName=\"opacity\" dur=\"3.4s\" repeatCount=\"indefinite\" values=\"0;0.4;0.4;0;0\" keyTimes=\"0;0.08;0.7;0.78;1\"><\u002Fanimate>\n        <\u002Fcircle>\n      <\u002Fsvg>\n      <div style=\"margin-top: 24px; display: flex; justify-content: space-between; align-items: end; gap: 24px;\">\n        <div style=\"font-family: var(--f-display); font-size: 18px; font-weight: 600; color: var(--navy-1); max-width: 480px; line-height: 1.6;\">\n          یک نقطه‌ی پُر، یک منحنی، و یک حرکت. این، DNAِ بصریِ ماست — هم در ثبات، هم در حرکت.\n        <\u002Fdiv>\n        <div style=\"font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--indigo); font-weight: 600;\">Live · Animated<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\" style=\"margin-top: 8px;\">\n      <span class=\"glyph\">۲۶ · ۰۱<\u002Fspan>\n      <h2>آناتومیِ یک حرکت<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">۰۱ · مبدأ<\u002Fdiv>\n        <h3>نقطه‌ی شروع<\u002Fh3>\n        <div style=\"margin: 14px 0; padding: 18px; background: var(--cloud); border-radius: 8px; display: grid; place-items: center;\">\n          <svg viewBox=\"0 0 100 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <circle cx=\"20\" cy=\"30\" r=\"6\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <path d=\"M 26 30 L 80 30\" stroke=\"#2A2D7E\" stroke-width=\"1.5\" stroke-dasharray=\"3 5\" opacity=\"0.5\"><\u002Fpath>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>یک دایره‌ی توپر، در ابتدای مسیر. نقطه‌ی شروع، همیشه پُررنگ‌تر و کمی بزرگ‌تر از باقی نقاط است.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۲ · مسیر<\u002Fdiv>\n        <h3>خطِ منحنی<\u002Fh3>\n        <div style=\"margin: 14px 0; padding: 18px; background: var(--cloud); border-radius: 8px; display: grid; place-items: center;\">\n          <svg viewBox=\"0 0 100 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <path d=\"M 10 50 Q 50 0, 90 30\" stroke=\"#2A2D7E\" stroke-width=\"1.8\"><\u002Fpath>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>یک منحنیِ نرم. هرگز شکسته یا تیز نیست. ضخامت: ۱.۵–۲px. به‌صورت خط ممتد یا چین‌دار، بسته به معنی.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">۰۳ · مقصد<\u002Fdiv>\n        <h3>نقطه‌ی پایان<\u002Fh3>\n        <div style=\"margin: 14px 0; padding: 18px; background: var(--cloud); border-radius: 8px; display: grid; place-items: center;\">\n          <svg viewBox=\"0 0 100 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <path d=\"M 10 30 L 70 30\" stroke=\"#2A2D7E\" stroke-width=\"1.5\" stroke-dasharray=\"3 5\" opacity=\"0.5\"><\u002Fpath>\n            <circle cx=\"80\" cy=\"30\" r=\"6\" fill=\"#6F8FCE\"><\u002Fcircle>\n            <circle cx=\"80\" cy=\"30\" r=\"11\" stroke=\"#6F8FCE\" stroke-width=\"1\" opacity=\"0.4\" fill=\"none\"><\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>یک نقطه با هاله‌ی پیرامون. رنگ‌اش معمولاً آسمانی (تأکیدی) است. هاله، حسِ «رسیدن» را اضافه می‌کند.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۶ · ۰۲<\u002Fspan>\n      <h2>چهار الگوی پایه<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-4\">\n      <!-- Single hop — straight line, two endpoints -->\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">یک گام<\u002Fdiv>\n        <div style=\"margin: 16px 0; padding: 22px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px;\">\n          <svg viewBox=\"0 0 140 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <circle cx=\"18\" cy=\"30\" r=\"5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <path d=\"M 24 30 L 116 30\" stroke=\"#2A2D7E\" stroke-width=\"1.5\"><\u002Fpath>\n            <circle cx=\"122\" cy=\"30\" r=\"5\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p style=\"font-size: 13px;\">پرداخت از یک نقطه به نقطه‌ی دیگر. ساده‌ترین الگو.<\u002Fp>\n      <\u002Fdiv>\n\n      <!-- Multi-step — straight line, evenly spaced dots -->\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">چند مرحله<\u002Fdiv>\n        <div style=\"margin: 16px 0; padding: 22px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px;\">\n          <svg viewBox=\"0 0 140 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <path d=\"M 16 30 L 124 30\" stroke=\"#2A2D7E\" stroke-width=\"1.5\"><\u002Fpath>\n            <circle cx=\"16\" cy=\"30\" r=\"5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <circle cx=\"43\" cy=\"30\" r=\"3.5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <circle cx=\"70\" cy=\"30\" r=\"3.5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <circle cx=\"97\" cy=\"30\" r=\"3.5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <circle cx=\"124\" cy=\"30\" r=\"5\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p style=\"font-size: 13px;\">چند نقطه‌ی پلکانی روی یک مسیر — مثلِ صف تسویه.<\u002Fp>\n      <\u002Fdiv>\n\n      <!-- Branching -->\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">انشعاب<\u002Fdiv>\n        <div style=\"margin: 16px 0; padding: 22px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px;\">\n          <svg viewBox=\"0 0 140 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <circle cx=\"20\" cy=\"30\" r=\"5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <path d=\"M 25 30 Q 60 30, 90 10\" stroke=\"#2A2D7E\" stroke-width=\"1.4\"><\u002Fpath>\n            <path d=\"M 25 30 Q 60 30, 90 30\" stroke=\"#2A2D7E\" stroke-width=\"1.4\"><\u002Fpath>\n            <path d=\"M 25 30 Q 60 30, 90 50\" stroke=\"#2A2D7E\" stroke-width=\"1.4\"><\u002Fpath>\n            <circle cx=\"95\" cy=\"10\" r=\"4\" fill=\"#6F8FCE\"><\u002Fcircle>\n            <circle cx=\"95\" cy=\"30\" r=\"4\" fill=\"#6F8FCE\"><\u002Fcircle>\n            <circle cx=\"95\" cy=\"50\" r=\"4\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p style=\"font-size: 13px;\">یک منبع، چند مقصد — مثلِ تقسیم سودِ تیام.<\u002Fp>\n      <\u002Fdiv>\n\n      <!-- Convergence -->\n      <div class=\"card\" style=\"padding: 22px;\">\n        <div class=\"label\">هم‌گرایی<\u002Fdiv>\n        <div style=\"margin: 16px 0; padding: 22px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px;\">\n          <svg viewBox=\"0 0 140 60\" width=\"100%\" height=\"60\" fill=\"none\" stroke-linecap=\"round\">\n            <circle cx=\"15\" cy=\"10\" r=\"4\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <circle cx=\"15\" cy=\"30\" r=\"4\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <circle cx=\"15\" cy=\"50\" r=\"4\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <path d=\"M 20 10 Q 60 30, 90 30\" stroke=\"#2A2D7E\" stroke-width=\"1.4\"><\u002Fpath>\n            <path d=\"M 20 30 Q 60 30, 90 30\" stroke=\"#2A2D7E\" stroke-width=\"1.4\"><\u002Fpath>\n            <path d=\"M 20 50 Q 60 30, 90 30\" stroke=\"#2A2D7E\" stroke-width=\"1.4\"><\u002Fpath>\n            <circle cx=\"95\" cy=\"30\" r=\"6\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p style=\"font-size: 13px;\">چند منبع، یک مقصد — مثلِ تجمیعِ تراکنش‌ها در همتا.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۶ · ۰۳<\u002Fspan>\n      <h2>الگوهای ریتمیک پس‌زمینه<\u002Fh2>\n    <\u002Fdiv>\n\n    <p class=\"body\" style=\"margin-bottom: 16px;\">گاهی به جای یک حرکتِ مشخص، می‌خواهیم بافتی از نقطه و خط داشته باشیم. این الگوها همیشه با opacity پایین (۸-۲۰٪) استفاده می‌شوند.<\u002Fp>\n\n    <div class=\"grid-3\">\n      <div style=\"aspect-ratio: 4/3; background: var(--paper); border: 1px solid var(--hairline); border-radius: 12px; padding: 16px; position: relative; overflow: hidden;\">\n        <div style=\"position: absolute; inset: 0; background-image: radial-gradient(circle at 1px 1px, rgba(42,45,126,0.22) 1.5px, transparent 0); background-size: 20px 20px;\"><\u002Fdiv>\n        <div style=\"position: relative; font-family: var(--f-en-body); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--indigo); font-weight: 600;\">گرید نقطه‌ای<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"aspect-ratio: 4/3; background: var(--paper); border: 1px solid var(--hairline); border-radius: 12px; padding: 16px; position: relative; overflow: hidden;\">\n        <svg viewBox=\"0 0 200 150\" preserveAspectRatio=\"xMidYMid slice\" style=\"position: absolute; inset: 0; width: 100%; height: 100%;\" fill=\"none\" stroke=\"#2A2D7E\" stroke-width=\"1\" opacity=\"0.55\">\n          <!-- Three parallel quadratic curves -->\n          <path d=\"M 0 130 Q 100 60, 200 90\"><\u002Fpath>\n          <path d=\"M 0 100 Q 100 30, 200 60\"><\u002Fpath>\n          <path d=\"M 0 70 Q 100 0, 200 30\"><\u002Fpath>\n          <!-- Dots ON the curves at their midpoints (t=0.5) -->\n          <circle cx=\"100\" cy=\"85\" r=\"3.2\" fill=\"#2A2D7E\"><\u002Fcircle>\n          <circle cx=\"100\" cy=\"55\" r=\"3.2\" fill=\"#2A2D7E\"><\u002Fcircle>\n          <circle cx=\"100\" cy=\"25\" r=\"3.2\" fill=\"#2A2D7E\"><\u002Fcircle>\n        <\u002Fsvg>\n        <div style=\"position: relative; font-family: var(--f-en-body); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--indigo); font-weight: 600;\">منحنی‌های موازی<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"aspect-ratio: 4/3; background: var(--navy-1); border-radius: 12px; padding: 16px; position: relative; overflow: hidden;\">\n        <svg viewBox=\"0 0 200 150\" preserveAspectRatio=\"xMidYMid slice\" style=\"position: absolute; inset: 0; width: 100%; height: 100%;\" fill=\"none\" stroke=\"#6F8FCE\" stroke-width=\"1.2\" opacity=\"0.7\">\n          <!-- Arcs from bottom-left corner. -->\n          <path d=\"M 0 150 A 80 80 0 0 1 80 70\"><\u002Fpath>\n          <path d=\"M 0 150 A 120 120 0 0 1 120 30\"><\u002Fpath>\n          <path d=\"M 0 150 A 160 160 0 0 1 160 -10\"><\u002Fpath>\n          <!-- Dots ON each arc, sampled at t=0.5 along the path -->\n          <circle cx=\"23\" cy=\"93\" r=\"3.5\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <circle cx=\"74\" cy=\"39\" r=\"3.5\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <circle cx=\"99\" cy=\"2\" r=\"3.5\" fill=\"#6F8FCE\"><\u002Fcircle>\n        <\u002Fsvg>\n        <div style=\"position: relative; font-family: var(--f-en-body); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--sky); font-weight: 600;\">آرک از گوشه<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۶ · ۰۴<\u002Fspan>\n      <h2>تزئیناتِ داخلِ کارت<\u002Fh2>\n    <\u002Fdiv>\n\n    <p class=\"body\" style=\"margin-bottom: 16px;\">جزئیاتی که یک کارت معمولی را به یک کارتِ برندشده تبدیل می‌کنند — همیشه با همان زبانِ نقطه و خط.<\u002Fp>\n\n    <div class=\"grid-3\">\n      <div class=\"card\" style=\"position: relative; overflow: hidden;\">\n        <svg viewBox=\"0 0 200 200\" style=\"position: absolute; bottom: -30%; left: -30%; width: 70%;\" fill=\"none\" stroke=\"#2A2D7E\" stroke-width=\"1\" opacity=\"0.22\">\n          <path d=\"M 0 200 A 100 100 0 0 1 100 100\"><\u002Fpath><path d=\"M 0 200 A 140 140 0 0 1 140 60\"><\u002Fpath><path d=\"M 0 200 A 180 180 0 0 1 180 20\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"label\" style=\"position: relative;\">آرک پس‌زمینه<\u002Fdiv>\n        <h3 style=\"position: relative;\">نقش‌مایه‌ی برند<\u002Fh3>\n        <p style=\"position: relative;\">آرک‌های کوچک از یک گوشه. برای کارت‌هایی که حسِ «جریان» می‌خواهند.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\" style=\"position: relative; overflow: hidden;\">\n        <div style=\"position: absolute; top: 16px; left: 18px; font-family: var(--f-display); font-size: 64px; font-weight: 800; color: rgba(42,45,126,0.06); line-height: 1; letter-spacing: -0.04em; font-feature-settings: 'tnum';\">۰۱<\u002Fdiv>\n        <div class=\"label\" style=\"position: relative;\">عددِ بزرگ<\u002Fdiv>\n        <h3 style=\"position: relative;\">برای فهرستِ مرحله‌ای<\u002Fh3>\n        <p style=\"position: relative;\">عددِ بزرگِ کم‌رنگ در گوشه. ریتم بصری برای فهرست‌های پلکانی.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\" style=\"position: relative; overflow: hidden;\">\n        <svg viewBox=\"0 0 220 130\" style=\"position: absolute; top: 0; right: 0; width: 75%; height: auto;\" fill=\"none\" stroke-linecap=\"round\">\n          <defs><path id=\"dec-curve\" d=\"M 18 100 Q 110 -10, 200 60\"><\u002Fpath><\u002Fdefs>\n          <use href=\"#dec-curve\" stroke=\"#2A2D7E\" stroke-width=\"1.4\" opacity=\"0.35\"><\u002Fuse>\n          <circle cx=\"18\" cy=\"100\" r=\"4.5\" fill=\"#2A2D7E\"><\u002Fcircle>\n          <circle cx=\"200\" cy=\"60\" r=\"4.5\" fill=\"#6F8FCE\"><\u002Fcircle>\n          <circle cx=\"200\" cy=\"60\" r=\"9\" stroke=\"#6F8FCE\" stroke-width=\"1\" opacity=\"0.4\"><\u002Fcircle>\n        <\u002Fsvg>\n        <div style=\"margin-top: 88px; position: relative;\">\n          <div class=\"label\">نقطه روی خط<\u002Fdiv>\n          <h3>یک حرکتِ ساکن<\u002Fh3>\n          <p>یک منحنی با دو نقطه در گوشه‌ی کارت. تصویرِ مینیاتوریِ یک پرداخت.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- MOTION -->\n<section class=\"page tint\" id=\"motion\" data-screen-label=\"28 Motion\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۷<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۷ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">موشن و حرکت<\u002Fh1>\n    <div class=\"title-en\">Motion Principles<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      اگر برندِ ما یک نقطه و یک منحنیست، موشن همان حرکتِ نقطه روی منحنیست. اما هر حرکتی نه — حرکتی که شخصیتِ بورس پی را داشته باشد: <em style=\"font-style: normal; color: var(--indigo);\">سریع، آرام، مطمئن، یک‌جهت<\u002Fem>.\n    <\u002Fp>\n\n    <div class=\"section-head\" style=\"margin-top: 0;\">\n      <span class=\"glyph\">۲۷ · ۰۱<\u002Fspan>\n      <h2>چهار اصلِ موشن<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-2\">\n      <div class=\"card\">\n        <div class=\"label\">۰۱ · Easing<\u002Fdiv>\n        <h3>ورودِ تیز، نشستِ نرم.<\u002Fh3>\n        <div style=\"margin: 18px 0; padding: 20px; background: var(--paper-2); border-radius: 8px;\">\n          <svg viewBox=\"0 0 200 80\" width=\"100%\" height=\"80\" fill=\"none\" stroke-linecap=\"round\">\n            <path d=\"M 10 70 L 190 10\" stroke=\"#A6ACC4\" stroke-width=\"1\" stroke-dasharray=\"3 4\"><\u002Fpath>\n            <path d=\"M 10 70 C 50 70, 90 15, 190 10\" stroke=\"#2A2D7E\" stroke-width=\"2\"><\u002Fpath>\n            <text x=\"10\" y=\"65\" font-family=\"DM Sans\" font-size=\"10\" fill=\"#6C7290\">شروع<\u002Ftext>\n            <text x=\"155\" y=\"28\" font-family=\"DM Sans\" font-size=\"10\" fill=\"#6C7290\">پایان<\u002Ftext>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>استفاده از <code style=\"font-family: var(--f-mono); font-size: 12px;\">cubic-bezier(0.22, 1, 0.36, 1)<\u002Fcode> — حرکت با شتاب وارد می‌شود و با آرامش می‌نشیند. این، حسِ «تسویه‌ی آنی» را منتقل می‌کند: سریع، اما متعهد.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\">\n        <div class=\"label\">۰۲ · Duration<\u002Fdiv>\n        <h3>کوتاه، نه تند.<\u002Fh3>\n        <div style=\"margin: 18px 0; padding: 12px 18px; background: var(--paper-2); border-radius: 8px; font-family: var(--f-mono); font-size: 13px; line-height: 2.2;\">\n          <div style=\"display: flex; justify-content: space-between;\"><span>Micro · هاور و کلیک<\u002Fspan><span style=\"color: var(--indigo);\">160–200ms<\u002Fspan><\u002Fdiv>\n          <div style=\"display: flex; justify-content: space-between;\"><span>UI · باز/بسته شدن<\u002Fspan><span style=\"color: var(--indigo);\">240–320ms<\u002Fspan><\u002Fdiv>\n          <div style=\"display: flex; justify-content: space-between;\"><span>Page · انتقال صفحه<\u002Fspan><span style=\"color: var(--indigo);\">400–600ms<\u002Fspan><\u002Fdiv>\n          <div style=\"display: flex; justify-content: space-between;\"><span>Story · روایت بصری<\u002Fspan><span style=\"color: var(--indigo);\">800–1400ms<\u002Fspan><\u002Fdiv>\n        <\u002Fdiv>\n        <p>برای حرکاتِ کوتاه، حدود ۲۰۰ میلی‌ثانیه. برای روایت‌های بصری (مثلِ نمایشِ پرداختِ روی صفحه‌ی فرود)، تا ۱.۴ ثانیه. هرگز کوتاه‌تر از ۱۲۰ یا بلندتر از ۱۵۰۰.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\">\n        <div class=\"label\">۰۳ · Path<\u002Fdiv>\n        <h3>منحنی، نه خط.<\u002Fh3>\n        <div style=\"margin: 18px 0; padding: 20px; background: var(--paper-2); border-radius: 8px;\">\n          <svg viewBox=\"0 0 200 80\" width=\"100%\" height=\"80\" fill=\"none\" stroke-linecap=\"round\">\n            <path d=\"M 20 60 L 180 20\" stroke=\"#C4373F\" stroke-width=\"1\" stroke-dasharray=\"3 3\" opacity=\"0.5\"><\u002Fpath>\n            <text x=\"20\" y=\"76\" font-family=\"Vazirmatn\" font-size=\"9\" fill=\"#C4373F\">نه: خط مستقیم<\u002Ftext>\n            <path d=\"M 20 60 Q 60 60, 100 35 T 180 20\" stroke=\"#2A2D7E\" stroke-width=\"2\"><\u002Fpath>\n            <text x=\"125\" y=\"76\" font-family=\"Vazirmatn\" font-size=\"9\" fill=\"#2A2D7E\">بله: منحنی<\u002Ftext>\n            <circle cx=\"180\" cy=\"20\" r=\"4\" fill=\"#2A2D7E\"><\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>اشیاء روی صفحه، همیشه روی یک منحنیِ نرم حرکت می‌کنند، نه روی یک خطِ مستقیم. حتی برای حرکتِ افقیِ ساده، یک ارتفاع کم اضافه کنید.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\">\n        <div class=\"label\">۰۴ · Direction<\u002Fdiv>\n        <h3>یک‌جهت، رو به جلو.<\u002Fh3>\n        <div style=\"margin: 18px 0; padding: 20px; background: var(--paper-2); border-radius: 8px;\">\n          <svg viewBox=\"0 0 200 80\" width=\"100%\" height=\"80\" fill=\"none\" stroke-linecap=\"round\">\n            <path d=\"M 20 40 L 170 40\" stroke=\"#2A2D7E\" stroke-width=\"1.6\"><\u002Fpath>\n            <circle cx=\"170\" cy=\"40\" r=\"5\" fill=\"#2A2D7E\"><\u002Fcircle>\n            <path d=\"M 162 35 L 175 40 L 162 45\" stroke=\"#2A2D7E\" stroke-width=\"1.6\" fill=\"none\"><\u002Fpath>\n            <text x=\"20\" y=\"64\" font-family=\"DM Sans\" font-size=\"10\" fill=\"#6C7290\">جلو<\u002Ftext>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>حرکت همیشه به سمتِ جلو، به سمتِ تکمیل. هیچ‌گاه bounce، elastic، یا برگشت به عقب نداریم. هر برگشت، حسِ «تأخیر در پرداخت» را تداعی می‌کند — دقیقاً برعکسِ چیزی که ما می‌فروشیم.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۷ · ۰۲<\u002Fspan>\n      <h2>کاربردهای متداول<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"grid-3\">\n      <div class=\"card\">\n        <div class=\"label\">Entrance<\u002Fdiv>\n        <h3>ورودِ عنصر<\u002Fh3>\n        <div style=\"margin: 14px 0; padding: 28px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px; overflow: hidden;\">\n          <svg viewBox=\"0 0 100 60\" width=\"120\" height=\"80\" fill=\"none\" stroke-linecap=\"round\">\n            <circle cx=\"50\" cy=\"30\" r=\"6\" fill=\"#2A2D7E\">\n              <animate attributeName=\"cx\" values=\"-10;50\" dur=\"1.6s\" repeatCount=\"indefinite\" calcMode=\"spline\" keySplines=\"0.22 1 0.36 1\"><\u002Fanimate>\n              <animate attributeName=\"opacity\" values=\"0;1\" dur=\"0.4s\" repeatCount=\"indefinite\"><\u002Fanimate>\n            <\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>عنصر از سمت راست (در RTL از چپ) با fade-in وارد می‌شود. ۳۲۰ میلی‌ثانیه.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\">\n        <div class=\"label\">Number tick<\u002Fdiv>\n        <h3>افزایشِ عدد<\u002Fh3>\n        <div style=\"margin: 14px 0; padding: 28px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px;\">\n          <div style=\"font-family: var(--f-display); font-size: 36px; font-weight: 800; color: var(--navy-1); font-feature-settings: 'tnum';\">\n            <span id=\"counter-demo\">۱۲٬۴۰۲<\u002Fspan>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <p>اعداد مالی به‌صورت پلکانی شمارش می‌شوند، نه ناگهانی. ۸۰۰ تا ۱۲۰۰ میلی‌ثانیه با ease-out.<\u002Fp>\n      <\u002Fdiv>\n\n      <div class=\"card\">\n        <div class=\"label\">Pulse<\u002Fdiv>\n        <h3>نبضِ زنده<\u002Fh3>\n        <div style=\"margin: 14px 0; padding: 28px; background: var(--paper-2); border-radius: 8px; display: grid; place-items: center; height: 100px;\">\n          <svg viewBox=\"0 0 60 60\" width=\"60\" height=\"60\" fill=\"none\">\n            <circle cx=\"30\" cy=\"30\" r=\"6\" fill=\"#1F8A5B\"><\u002Fcircle>\n            <circle cx=\"30\" cy=\"30\" r=\"6\" fill=\"#1F8A5B\" opacity=\"0.5\">\n              <animate attributeName=\"r\" values=\"6;18\" dur=\"1.8s\" repeatCount=\"indefinite\" calcMode=\"spline\" keySplines=\"0.22 1 0.36 1\"><\u002Fanimate>\n              <animate attributeName=\"opacity\" values=\"0.5;0\" dur=\"1.8s\" repeatCount=\"indefinite\"><\u002Fanimate>\n            <\u002Fcircle>\n          <\u002Fsvg>\n        <\u002Fdiv>\n        <p>برای وضعیتِ «در حالِ پردازش» یا «اتصال فعال». تنها انیمیشنی که loop می‌شود.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۲۷ · ۰۳<\u002Fspan>\n      <h2>بایدها و نبایدها<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"voice-cols\">\n      <div class=\"col do\">\n        <h4><span class=\"mark\">+<\u002Fspan>این کار را بکنید<\u002Fh4>\n        <ul>\n          <li><strong>یک حرکت در یک لحظه<\u002Fstrong> — هرگز چند انیمیشن هم‌زمان.<\u002Fli>\n          <li><strong>ease-out در ۹۰٪ موارد<\u002Fstrong> — ورود سریع، نشست نرم.<\u002Fli>\n          <li><strong>۲۰۰ میلی‌ثانیه<\u002Fstrong> به‌عنوان میانگین — مگر آنکه دلیل داشته باشید.<\u002Fli>\n          <li><strong>fade-in همراهِ slide-in<\u002Fstrong> — opacity و موقعیت با هم.<\u002Fli>\n          <li><strong>respect prefers-reduced-motion<\u002Fstrong> — همیشه.<\u002Fli>\n        <\u002Ful>\n      <\u002Fdiv>\n      <div class=\"col dont\">\n        <h4><span class=\"mark\">−<\u002Fspan>این کار را نکنید<\u002Fh4>\n        <ul>\n          <li>Bounce، elastic، spring با overshoot<\u002Fli>\n          <li>چرخش (rotate) به‌جز در آیکنِ بارگذاری<\u002Fli>\n          <li>انیمیشن‌های loop در محتوای ثابت<\u002Fli>\n          <li>حرکت با خطِ مستقیم در روایت‌های بصری<\u002Fli>\n          <li>زمانِ بیشتر از ۱.۵ ثانیه برای UI<\u002Fli>\n          <li>تأخیر (delay) بیشتر از ۲۰۰ms بینِ حرکات زنجیره‌ای<\u002Fli>\n        <\u002Ful>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n\n<!-- ICONS -->\n<section class=\"page\" id=\"icons\" data-screen-label=\"28 Iconography\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۸<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۸ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">آیکونوگرافی<\u002Fh1>\n    <div class=\"title-en\">Iconography<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      آیکن‌های ما، خطی، یکنواخت، با گردیِ ملایم در گوشه‌ها. خشن نیست، اما رسمی هست. مثلِ خودِ ما.\n    <\u002Fp>\n\n    <div class=\"grid-3\" style=\"margin-bottom: 32px;\">\n      <div class=\"card\">\n        <div class=\"label\">سبک<\u002Fdiv>\n        <h3>خطی · Stroke<\u002Fh3>\n        <p>وزنِ خط: ۱.۵px در سایزِ ۲۴px. در سایزهای بزرگ‌تر، متناسب با مقیاس.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">گوشه‌ها<\u002Fdiv>\n        <h3>گرد · Rounded<\u002Fh3>\n        <p>همه‌ی گوشه‌ها <code style=\"font-family: var(--f-mono); font-size: 12px;\">stroke-linecap: round<\u002Fcode> و <code style=\"font-family: var(--f-mono); font-size: 12px;\">stroke-linejoin: round<\u002Fcode>.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"card\">\n        <div class=\"label\">گرید<\u002Fdiv>\n        <h3>۲۴ × ۲۴<\u002Fh3>\n        <p>همه‌ی آیکن‌ها روی گریدِ ۲۴×۲۴، با ۲px پدینگِ صرف از لبه.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"icons-grid\">\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M3 12 L9 12 M15 12 L21 12\"><\u002Fpath><path d=\"M9 8 L13 12 L9 16\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">پرداختِ آنی<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <rect x=\"3\" y=\"6\" width=\"18\" height=\"14\" rx=\"2\"><\u002Frect><path d=\"M3 10 L21 10\"><\u002Fpath><path d=\"M7 15 L11 15\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">کارت<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M3 19 L21 19\"><\u002Fpath><path d=\"M4 19 L4 8 L7 8 L7 19\"><\u002Fpath><path d=\"M10 19 L10 5 L13 5 L13 19\"><\u002Fpath><path d=\"M16 19 L16 11 L19 11 L19 19\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">صندوق<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M3 21 L21 21\"><\u002Fpath><path d=\"M3 10 L21 10\"><\u002Fpath><path d=\"M5 10 L5 21 M9 10 L9 21 M15 10 L15 21 M19 10 L19 21\"><\u002Fpath><path d=\"M12 3 L21 8 L3 8 Z\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">بانک<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <circle cx=\"12\" cy=\"12\" r=\"9\"><\u002Fcircle><path d=\"M12 7 L12 12 L15 14\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">زمانِ آنی<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M12 2 L4 6 L4 12 C 4 16 8 20 12 22 C 16 20 20 16 20 12 L20 6 Z\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">امنیت<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M4 7 L20 7\"><\u002Fpath><path d=\"M4 12 L20 12\"><\u002Fpath><path d=\"M4 17 L14 17\"><\u002Fpath><path d=\"M17 16 L19 18 L22 14\" stroke=\"#1F8A5B\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">گزارش<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M8 12 L11 15 L16 9\"><\u002Fpath><circle cx=\"12\" cy=\"12\" r=\"9\"><\u002Fcircle>\n        <\u002Fsvg>\n        <div class=\"nm\">تأیید<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M12 3 L13.5 8.5 L19 9 L14.5 12.5 L16 18 L12 14.5 L8 18 L9.5 12.5 L5 9 L10.5 8.5 Z\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">ممتاز<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M21 16 L21 8 L12 3 L3 8 L3 16 L12 21 L21 16 Z\"><\u002Fpath><path d=\"M12 12 L21 8 M12 12 L12 21 M12 12 L3 8\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">بسته<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M3 17 L9 11 L13 14 L21 6\"><\u002Fpath><path d=\"M16 6 L21 6 L21 11\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">رشد<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M6 4 L6 20\"><\u002Fpath><path d=\"M18 4 L18 20\"><\u002Fpath><path d=\"M6 8 L18 8\"><\u002Fpath><path d=\"M6 14 L18 14\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">انتقال<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <circle cx=\"9\" cy=\"9\" r=\"4\"><\u002Fcircle><circle cx=\"17\" cy=\"17\" r=\"3\"><\u002Fcircle><path d=\"M12 12 L15 15\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">اتصال<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M4 9 L9 4 L20 4 L20 15 L15 20 L4 20 Z\"><\u002Fpath><path d=\"M9 4 L9 9 L4 9\"><\u002Fpath><path d=\"M15 20 L15 15 L20 15\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">سند<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M7 4 L17 4 L20 7 L20 20 L4 20 L4 7 Z\"><\u002Fpath><path d=\"M8 12 L12 16 L16 10\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">امضا<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"icon-cell\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M4 12 L7 9 L11 13 L17 7 L20 10\"><\u002Fpath><path d=\"M4 20 L20 20\"><\u002Fpath>\n        <\u002Fsvg>\n        <div class=\"nm\">روند<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- COMPONENTS -->\n<section class=\"page tint\" id=\"components\" data-screen-label=\"29 UI Components\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۲۹<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۲۹ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">کامپوننت‌های UI<\u002Fh1>\n    <div class=\"title-en\">UI Components<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      مجموعه‌ای از بلاک‌های ساختاری که در همه‌ی محصولات ما تکرار می‌شوند. ثبات این بلاک‌ها، تجربه‌ی یکپارچه می‌سازد.\n    <\u002Fp>\n\n    <div class=\"ui-row\">\n      <div class=\"row-head\">\n        <h3>دکمه‌ها<\u002Fh3>\n        <div class=\"meta\">Buttons · 3 levels<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"btn-group\">\n        <button class=\"btn primary\">ادامه<\u002Fbutton>\n        <button class=\"btn secondary\">انصراف<\u002Fbutton>\n        <button class=\"btn tertiary\">بیشتر بخوانید<\u002Fbutton>\n        <button class=\"btn primary large\">شروع تسویه<\u002Fbutton>\n        <button class=\"btn primary small\">تأیید<\u002Fbutton>\n        <button class=\"btn disabled\">غیرفعال<\u002Fbutton>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"ui-row\">\n      <div class=\"row-head\">\n        <h3>برچسب‌های وضعیت<\u002Fh3>\n        <div class=\"meta\">Badges · Status<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"badges-row\">\n        <span class=\"badge success\"><span class=\"dot\"><\u002Fspan>موفق<\u002Fspan>\n        <span class=\"badge warning\"><span class=\"dot\"><\u002Fspan>در انتظار<\u002Fspan>\n        <span class=\"badge info\"><span class=\"dot\"><\u002Fspan>اطلاع‌رسانی<\u002Fspan>\n        <span class=\"badge neutral\"><span class=\"dot\"><\u002Fspan>پیش‌نویس<\u002Fspan>\n        <span class=\"badge dark\"><span class=\"dot\"><\u002Fspan>نهادی<\u002Fspan>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"ui-row\">\n      <div class=\"row-head\">\n        <h3>فرم<\u002Fh3>\n        <div class=\"meta\">Inputs · Forms<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"form-sample\">\n        <div class=\"form-row\">\n          <labe