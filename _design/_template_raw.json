16 8 16 16 12 20 C 8 16 8 8 12 4\"><\u002Fpath><\u002Fsvg>\n              <span>boorspay.com<\u002Fspan>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"back-side\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" alt=\"\">\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"section-head\">\n      <span class=\"glyph\">۳۰ · ۰۲<\u002Fspan>\n      <h2>سربرگ — A4<\u002Fh2>\n    <\u002Fdiv>\n\n    <div style=\"background: var(--paper); border: 1px solid var(--hairline); border-radius: 8px; padding: 40px; aspect-ratio: 1/1.4; box-shadow: 0 30px 60px -20px rgba(10,14,46,0.15); max-width: 500px;\">\n      <div style=\"display: flex; justify-content: space-between; align-items: start; padding-bottom: 24px; border-bottom: 1px solid var(--hairline);\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\">\n          <img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\" style=\"width: 44px; height: 44px;\">\n          <div>\n            <div style=\"font-family: var(--f-display); font-weight: 700; font-size: 18px; color: var(--navy-1);\">بورس پی<\u002Fdiv>\n            <div style=\"font-family: var(--f-en-body); font-size: 10px; color: var(--ink-3); letter-spacing: 0.12em; text-transform: uppercase;\">Capital Market Payment Rails<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"font-family: var(--f-mono); font-size: 10px; color: var(--ink-3); line-height: 1.8; text-align: left;\">\n          تاریخ: ۱۴۰۵/۰۲/۱۵<br>\n          شناسه: BP-2024-0184\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"margin-top: 24px; color: var(--ink-2); font-size: 14px; line-height: 1.85;\">\n        <div style=\"font-family: var(--f-display); font-weight: 700; font-size: 17px; color: var(--navy-1); margin-bottom: 12px;\">جناب آقای…<\u002Fdiv>\n        با سلام و احترام،<br>\n        با عنایت به مذاکرات اولیه‌ی صورت‌گرفته، بدینوسیله…\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- SOCIAL -->\n<section class=\"page tint\" id=\"social\" data-screen-label=\"33 Social Media\">\n  <div class=\"inner\">\n    <div class=\"page-meta\">\n      <div class=\"left\"><span class=\"num\">۳۳<\u002Fspan><span>هویتِ بصری · Visual<\u002Fspan><\u002Fdiv>\n      <div class=\"right\">۳۳ / ۳۳<\u002Fdiv>\n    <\u002Fdiv>\n\n    <h1 class=\"title-fa\">شبکه‌های اجتماعی<\u002Fh1>\n    <div class=\"title-en\">Social Media Templates<\u002Fdiv>\n\n    <p class=\"lede\" style=\"margin-bottom: 32px;\">\n      الگوهای ثابت برای پست‌های ما در لینکدین، اینستاگرام و توییتر. هر پست، حتی بدونِ نوشتنِ نام، باید شناخته شود.\n    <\u002Fp>\n\n    <div class=\"section-head\" style=\"margin-top: 0;\">\n      <span class=\"glyph\">۳۱ · ۰۱<\u002Fspan>\n      <h2>الگوی پستِ مربعی — ۱۰۸۰×۱۰۸۰<\u002Fh2>\n    <\u002Fdiv>\n\n    <div class=\"social-grid\">\n      <div class=\"post dark\">\n        <div class=\"meta-strip\">\n          <div class=\"brand\"><img src=\"e6688663-a5e4-451b-9c47-47d16f602127\" style=\"\"><span>بورس پی<\u002Fspan><\u002Fdiv>\n          <span>تیام<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"post-text\">تقسیم سود گروهی،<br>از فرآیند به سیستم.<\u002Fdiv>\n        <svg viewBox=\"0 0 200 100\" style=\"position: absolute; bottom: -10%; left: -5%; width: 60%; opacity: 0.18;\" fill=\"none\" stroke=\"#6F8FCE\" stroke-width=\"1.5\">\n          <path d=\"M0 90 A 90 90 0 0 1 90 0\"><\u002Fpath><path d=\"M0 70 A 70 70 0 0 1 70 0\"><\u002Fpath><path d=\"M0 50 A 50 50 0 0 1 50 0\"><\u002Fpath>\n        <\u002Fsvg>\n      <\u002Fdiv>\n\n      <div class=\"post indigo\">\n        <div class=\"meta-strip\">\n          <div class=\"brand\"><img src=\"e6688663-a5e4-451b-9c47-47d16f602127\" style=\"\"><span>بورس پی<\u002Fspan><\u002Fdiv>\n          <span>چابک<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"post-text\">T+۰.<br>استاندارد ما، نه ادعای ما.<\u002Fdiv>\n        <svg viewBox=\"0 0 200 100\" style=\"position: absolute; bottom: -10%; left: -5%; width: 60%; opacity: 0.25;\" fill=\"none\" stroke=\"#fff\" stroke-width=\"1.5\">\n          <path d=\"M0 90 A 90 90 0 0 1 90 0\"><\u002Fpath><path d=\"M0 70 A 70 70 0 0 1 70 0\"><\u002Fpath><path d=\"M0 50 A 50 50 0 0 1 50 0\"><\u002Fpath>\n        <\u002Fsvg>\n      <\u002Fdiv>\n\n      <div class=\"post cream\">\n        <div class=\"meta-strip\">\n          <div class=\"brand\"><img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\"><span style=\"color: var(--indigo);\">بورس پی<\u002Fspan><\u002Fdiv>\n          <span>همتا<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"post-text\">صفِ پایانیِ بازار،<br>دیگر صف نیست.<\u002Fdiv>\n        <svg viewBox=\"0 0 200 100\" style=\"position: absolute; bottom: -10%; left: -5%; width: 60%; opacity: 0.12;\" fill=\"none\" stroke=\"#2A2D7E\" stroke-width=\"1.5\">\n          <path d=\"M0 90 A 90 90 0 0 1 90 0\"><\u002Fpath><path d=\"M0 70 A 70 70 0 0 1 70 0\"><\u002Fpath><path d=\"M0 50 A 50 50 0 0 1 50 0\"><\u002Fpath>\n        <\u002Fsvg>\n      <\u002Fdiv>\n\n      <div class=\"post dark\" style=\"grid-column: span 1;\">\n        <div class=\"meta-strip\">\n          <div class=\"brand\"><img src=\"e6688663-a5e4-451b-9c47-47d16f602127\" style=\"\"><span>بورس پی<\u002Fspan><\u002Fdiv>\n          <span style=\"font-family: var(--f-mono);\">آمار<\u002Fspan>\n        <\u002Fdiv>\n        <div>\n          <div style=\"font-family: var(--f-display); font-size: 64px; font-weight: 800; color: var(--sky); line-height: 1; letter-spacing: -0.03em; font-feature-settings: 'tnum';\">۲۱<\u002Fdiv>\n          <div style=\"font-family: var(--f-display); font-size: 16px; font-weight: 600; color: #fff; margin-top: 8px;\">بانک متصل<\u002Fdiv>\n          <div style=\"font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 4px;\">از طریقِ بانکداری باز<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"post\" style=\"background: linear-gradient(135deg, var(--navy-1), var(--indigo)); color: #fff; border-color: transparent;\">\n        <div class=\"meta-strip\" style=\"color: var(--sky);\">\n          <div class=\"brand\"><img src=\"e6688663-a5e4-451b-9c47-47d16f602127\" style=\"\"><span>بورس پی<\u002Fspan><\u002Fdiv>\n          <span>کارت هدیه<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"post-text\" style=\"color: #fff;\">هدیه‌ای که<br>با گذرِ زمان<br>یاد بهترش می‌شود.<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"post cream\">\n        <div class=\"meta-strip\">\n          <div class=\"brand\"><img src=\"a5687269-8c0e-4f51-922c-2e943086b10e\"><span style=\"color: var(--indigo);\">بورس پی<\u002Fspan><\u002Fdiv>\n          <span>نقل قول<\u002Fspan>\n        <\u002Fdiv>\n        <div>\n          <div style=\"font-family: var(--f-en-display); font-style: italic; font-size: 64px; color: var(--indigo); line-height: 0.5;\">\"<\u002Fdiv>\n          <div style=\"font-family: var(--f-display); font-size: 17px; font-weight: 500; color: var(--navy-1); line-height: 1.6; margin-top: 8px;\">سرعت برای ما یک ویژگیِ بازاریابانه نیست؛ ستونِ قراردادی است.<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <p class=\"small\" style=\"margin-top: 32px; max-width: 800px;\">\n      <strong style=\"color: var(--navy-1);\">قاعده‌ی پست:<\u002Fstrong>\n      هر پست، یا تماماً نیلی-تیره است یا تماماً روشن. ترکیبِ این دو در یک پست، حسِ ناخوشایندی می‌سازد. در یک کانال، توالیِ نیلی → روشن → ایندیگو → نیلی، حسِ ریتم را حفظ می‌کند.\n    <\u002Fp>\n\n    <div style=\"margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--hairline); font-family: var(--f-en-body); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3); display: flex; justify-content: space-between;\">\n      <div>End of Volume 2 · Visual Identity<\u002Fdiv>\n      <div>پایان سند — Brand Book v3.0<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<\u002Fmain>\n<\u002Fdiv>\n\n<script>\n  // ============================================================\n  // Motion + Navigation System\n  // ============================================================\n\n  const sections = document.querySelectorAll(\"section.page\");\n  const links = document.querySelectorAll(\"nav.toc a\");\n  const linkMap = new Map();\n  links.forEach(a => linkMap.set(a.dataset.target, a));\n\n  // Active section highlighting\n  const navIO = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting && entry.intersectionRatio > 0.3) {\n        links.forEach(l => l.classList.remove(\"active\"));\n        const a = linkMap.get(entry.target.id);\n        if (a) a.classList.add(\"active\");\n      }\n    });\n  }, { threshold: [0.3, 0.5, 0.7] });\n  sections.forEach(s => navIO.observe(s));\n\n  // ----- Auto-tag reveal targets -----\n  const revealSelectors = [\n    \"h1.title-fa\", \".title-en\", \".lede\", \".statement\",\n    \".section-head\", \".body\", \".small\",\n    \".final-quote\", \".scale-ladder\", \".usage-bar\",\n    \".motif\", \".specimen\", \".tone-dial\",\n    \".pyramid\", \".tagline-grid\", \".compass\",\n    \".audience-grid\", \".pillars\", \".voice-cols\",\n    \".kpi-row\", \".palette-hero\", \".neutrals\",\n    \".clearspace\", \".logo-stage\", \".logo-rules\",\n    \".sizes\", \".samples\", \".grid-demo\", \".mockup-grid\",\n    \".stationery\", \".social-grid\", \".icons-grid\",\n    \".ui-row\", \".form-sample\", \".motif-uses\",\n    \".arch\", \".vol-content\", \".num-list\"\n  ];\n  document.querySelectorAll(revealSelectors.join(\",\")).forEach(el => {\n    el.classList.add(\"reveal\");\n  });\n\n  // ----- Auto-tag staggered grids -----\n  const staggerSelectors = [\n    \".grid-2\", \".grid-3\", \".grid-4\",\n    \".pillars\", \".audience-grid\", \".tagline-grid\",\n    \".social-grid\", \".sizes\", \".mockup-grid\",\n    \".samples\", \".motif-uses\", \".kpi-row\",\n    \".palette-hero\", \".neutrals\", \".logo-rules\",\n    \".icons-grid\", \".badges-row\", \".btn-group\"\n  ];\n  document.querySelectorAll(staggerSelectors.join(\",\")).forEach(el => {\n    el.classList.add(\"stagger\");\n  });\n\n  // ----- Reveal-on-scroll observer -----\n  const revealIO = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        entry.target.classList.add(\"in\");\n        revealIO.unobserve(entry.target);\n\n        // If this is a KPI row, animate counters\n        if (entry.target.classList.contains(\"kpi-row\")) {\n          entry.target.querySelectorAll(\".kpi .n\").forEach(animateCounter);\n        }\n      }\n    });\n  }, { threshold: 0.15, rootMargin: \"0px 0px -8% 0px\" });\n\n  document.querySelectorAll(\".reveal, .stagger\").forEach(el => revealIO.observe(el));\n\n  // ----- Persian-aware counter animation -----\n  const fa = \"۰۱۲۳۴۵۶۷۸۹\";\n  const faDigits = /[۰-۹]/g;\n  function toEn(s) {\n    return s.replace(faDigits, d => \"۰۱۲۳۴۵۶۷۸۹\".indexOf(d).toString());\n  }\n  function toFa(num, withGroup) {\n    let s = String(num);\n    if (withGroup) {\n      s = s.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \"٬\");\n    }\n    return s.replace(/[0-9]/g, d => fa[+d]);\n  }\n  function animateCounter(el) {\n    const original = el.textContent.trim();\n    // Extract the leading number, preserve suffix (e.g., \"+\", \"T+۰\", etc.)\n    const m = original.match(/^([۰-۹0-9٬,]+)(.*)$/);\n    if (!m) return;\n    const numStr = toEn(m[1].replace(/[٬,]/g, \"\"));\n    const target = parseInt(numStr, 10);\n    if (isNaN(target) || target < 2) return;\n    const suffix = m[2];\n    const hasGroup = m[1].includes(\"٬\") || m[1].includes(\",\");\n    const dur = 1200;\n    const t0 = performance.now();\n    el.classList.add(\"counting\");\n    function step(t) {\n      const p = Math.min(1, (t - t0) / dur);\n      // ease-out-quart\n      const eased = 1 - Math.pow(1 - p, 4);\n      const v = Math.round(target * eased);\n      el.textContent = toFa(v, hasGroup) + suffix;\n      if (p < 1) requestAnimationFrame(step);\n      else { el.classList.remove(\"counting\"); el.textContent = original; }\n    }\n    el.textContent = toFa(0, false) + suffix;\n    requestAnimationFrame(step);\n  }\n\n  // ----- Progress bar -----\n  const fill = document.getElementById(\"progressFill\");\n  function updateProgress() {\n    const h = document.documentElement;\n    const max = h.scrollHeight - h.clientHeight;\n    const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;\n    fill.style.width = pct + \"%\";\n  }\n  document.addEventListener(\"scroll\", updateProgress, { passive: true });\n  updateProgress();\n\n  // ----- Keyboard navigation -----\n  function currentIndex() {\n    const top = window.scrollY + 100;\n    let idx = 0;\n    sections.forEach((s, i) => { if (s.offsetTop <= top) idx = i; });\n    return idx;\n  }\n  document.addEventListener(\"keydown\", (e) => {\n    if (e.target.tagName === \"INPUT\" || e.target.tagName === \"TEXTAREA\") return;\n    if (e.key === \"ArrowDown\" || e.key === \"PageDown\" || e.key === \"j\") {\n      e.preventDefault();\n      sections[Math.min(currentIndex() + 1, sections.length - 1)].scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n    } else if (e.key === \"ArrowUp\" || e.key === \"PageUp\" || e.key === \"k\") {\n      e.preventDefault();\n      sections[Math.max(currentIndex() - 1, 0)].scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n    }\n  });\n\n  // ----- Parallax-ish subtle on cover arcs -----\n  const coverArcs = document.querySelector(\".cover .arcs\");\n  const coverArcs2 = document.querySelector(\".cover .arcs-2\");\n  if (coverArcs && coverArcs2) {\n    let ticking = false;\n    function updateParallax() {\n      const y = window.scrollY;\n      if (y < 1200) {\n        coverArcs.style.transform = `translateY(${y * 0.12}px)`;\n        coverArcs2.style.transform = `translateY(${-y * 0.08}px)`;\n      }\n      ticking = false;\n    }\n    window.addEventListener(\"scroll\", () => {\n      if (!ticking) { requestAnimationFrame(updateParallax); ticking = true; }\n    }, { passive: true });\n  }\n<\u002Fscript>\n\n\n\n<\u002Fbody><\u002Fhtml>"
